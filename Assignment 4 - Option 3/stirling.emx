 implementation bg
  submodels
   CC 416 168
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\CC.emx</LibraryPath>
  <TimeStamp>2011-11-29 15:33:22</TimeStamp>
</Description>
</Information>';
    type CC
     ports
      thermal in p_thermal;
      pneumatic in p_pneumatic;
     restrictions
      causality fixed out p_thermal;
      causality fixed out p_pneumatic;
    end;
    icon bg ellipse bottom
     figures
      text 'C' 417.2 168 color 0 18 bold;
      line 416 162.9 416 173.1 color 0;
    end;
    implementation eq
parameters
	real cv = 1;
	real hidden s0;
	real hidden v0;
	real V0 = 1e-3; // 1 litre
	real p0 = 1.02e5; // STP
	real T0 = 298; // STP
	real hidden N;
variables
	real s, v, V {m3}, S {J/K};
initialequations
	// pV = nRT; everything scaled down with n later (v=V/n; s=S/n)
	N = p0*V0/(R*T0);
	v0 = V0/N;
	s0 = 100/N; // no idea what s0 should be.... we're only interested in the increase
equations
	s = int(p_thermal.f)/N + s0;
	v = int(-p_pneumatic.f)/N + v0;
	V = v*N;
	S = s*N;
	p_thermal.e = T0*(v/v0)^(-R/cv)*exp((s-s0)/cv);
	p_pneumatic.e = p0*(v/v0)^(-R/cv-1)*exp((s-s0)/cv);implementation_end;
   MSf_mechanical 520 248
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MSf.emx</LibraryPath><TimeStamp>2011-11-29 16:14:18</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type MSf
     ports
      power out p;
      signal in flow;
     restrictions
      causality fixed in p;
    end;
    icon bg ellipse bottom
     figures
      text 'MSf' 520 248 color 0 18 bold;
    end;
    implementation eq
variables
	real effort;
	real interesting power, energy;
equations
	p.f = flow; 
	effort = p.e;
	power = flow*effort;
	energy = int(power);implementation_end;
   MSf_thermal 312 248
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MSf.emx</LibraryPath><TimeStamp>2011-11-29 16:14:18</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type MSf
     ports
      power out p;
      signal in flow;
     restrictions
