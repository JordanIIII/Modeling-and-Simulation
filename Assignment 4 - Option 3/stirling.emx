   Stirling 416 248
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Cycle-Equation'
     ports
      signal out dV;
      signal out dS;
      signal in T;
      signal in p;
    end;
    implementation eq
parameters
    real period = 1 {s};
    real dV_val = 0.01e-2;   // constant volume flow magnitude
    real hidden K = 1;       // temperature regulation gain
	real hidden Th = 310;
	real hidden Tc = 298;
variables
    integer i_step;
    boolean hidden ev;
code
    i_step = 1 + ((time/period) % 4);
    ev = frequencyevent(period);

    switch i_step

    case 1 do // Isothermal Expansion (hot source)
        dV = -dV_val;              // expansion
        dS = -K*(T - Th);          // keep T ≈ Th

    case 2 do // Isometric Heat Removal (regenerator cooling)
        dV = 0;                    // constant volume
        dS = -K*(T - Tc);          // cool toward cold temperature

    case 3 do // Isothermal Compression (cold source)
        dV = dV_val;               // compression
        dS = -K*(T - Tc);          // keep T ≈ Tc

    case 4 do // Isometric Heat Addition (regenerator heating)
        dV = 0;                    // constant volume
        dS = -K*(T - Th);          // heat back toward hot temperature

    end;implementation_end;
   ZeroJunction 312 168
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\ZeroJunction.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:45:16</TimeStamp>
</Description>
</Information>';
    knot ZeroJunction
     ports
      thermal knot duplicatable none p [1];
      signal knot out effort [1];
     restrictions
      causality constraint one_in p;
    end;
    icon bg ellipse
     figures
      text '0' 312 168 color 0 18 bold;
    end;
    implementation eq
equations
	sum (direct (p.f)) = 0;
	equal (collect (p.e));
	effort = first (p.e);
implementation_end;
   ZeroJunction1 520 168
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\ZeroJunction.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:45:16</TimeStamp>
</Description>
</Information>';
    knot ZeroJunction
     ports
      pneumatic knot duplicatable none p [1];
      signal knot out effort [1];
     restrictions
      causality constraint one_in p;
    end;
    icon bg ellipse
     figures
      text '0' 520 168 color 0 18 bold;
    end;
    implementation eq
equations
	sum (direct (p.f)) = 0;
	equal (collect (p.e));
	effort = first (p.e);
implementation_end;
  end;
  connections
   MSf_mechanical\p => ZeroJunction1\p;
   MSf_thermal\p => ZeroJunction\p;
   Stirling\dS -> MSf_thermal\flow;
   Stirling\dV -> MSf_mechanical\flow;
   ZeroJunction\effort -> Stirling\T;
   ZeroJunction\p => CC\p_thermal;
   ZeroJunction1\effort -> Stirling\p;
   ZeroJunction1\p => CC\p_pneumatic;
  end;
 implementation_end;
]]></Sidops>
