   human_disturbance 992 96
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Sources\Constant.emx</LibraryPath><TimeStamp>2007-10-19 14:48:44</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Constant
     ports
      signal out output;
      signal in q;
    end;
    icon bg top
     figures
      rectangle 976.1 80 1007.9 112 color 0 fill 15132390;
      line 980.9 91.6 1002.9 91.6 color 16711680 width 2;
      line 978.2 102.7 1003.9 102.7 color 0;
      line 980.5 86.7 980.5 105 color 0;
    end;
    implementation eq
parameters
	real on = 1;
	real global L;
	real F_dist = 10;
	real t_dist_start = 5.0;
	real t_dist_stop = 10.0;
equations
if time < t_dist_start then
	output = 0;
else 
	if time >= t_dist_start and time <= t_dist_stop then
		output = on * -F_dist*L*sin(q);
	else
		output = 0;
	end;
end;implementation_end;
