      Derivative 344 232
						specifications active 'Pure'
							specification 'FO'
description '<Description>
   <Version>4.0</Version>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\Derivative.emx</LibraryPath>
  <TimeStamp>2009-1-13 13:59:22</TimeStamp>
<AllowLibraryUpdate>True</AllowLibraryUpdate>
</Description>';
 type 'Derivative-Default'
  ports
   signal in input;
   signal out output;
 end;
 icon bg bottom
  figures
   rectangle 440 312 472 344 color 0 fill 15132390;
   text 'd/dt' 456 322 color 16711680 13 bold;
   text 'FO' 455 335 color 16711680 13 bold;
 end;
 implementation eq
parameters
	real fh = 100.0 {Hz};		// Differentiation bandwidth [Hz]
	real initial = 0.0;			// Initial output
variables
	real hidden rate;
	real hidden initial_input;
	boolean hidden initialized;
initialequations
	initialized = false;
equations
	if not initialized then 
		initial_input = input; 
		initialized = true;
	end;
	rate  = - 2*pi*fh * output;
	output = 2*pi*fh * (input - initial_input)  + int (rate,initial);                implementation_end;
specification_end;
							specification 'Pure'
 description '<Description>
   <Version>4.0</Version>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\Derivative.emx</LibraryPath>
  <TimeStamp>2009-1-13 12:33:44</TimeStamp>
<AllowLibraryUpdate>True</AllowLibraryUpdate>
</Description>';
 type 'Differentiate-Default'
  ports
   signal in input;
   signal out output;
 end;
 icon bg bottom
  figures
   group
    rectangle 328 216 360 248 color 0 fill 15132390;
    text 'd/dt' 344 232 color 16711680 13 bold;
   end;
 end;
 implementation eq
parameters
	real initial = 0;		// initial value
equations
	output = ddt (input, initial);
    implementation_end;
specification_end;
						end;
