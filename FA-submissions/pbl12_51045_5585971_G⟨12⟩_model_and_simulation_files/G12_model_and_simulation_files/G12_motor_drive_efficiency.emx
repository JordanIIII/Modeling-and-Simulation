    type GY
     ports
      power in p1;
      power out p2;
     restrictions
      causality constraint equal p1 p2;
    end;
    icon bg ellipse bottom
     figures
      text 'GY' 196 108 color 0 18 bold;
    end;
    implementation eq
parameters
	real r = 0.1;
	real Kv = 2*pi;
	real Kt = 0.198;
equations
	p1.e = 0.198 * p2.f;
	p2.e = Kt * p1.f;implementation_end;
