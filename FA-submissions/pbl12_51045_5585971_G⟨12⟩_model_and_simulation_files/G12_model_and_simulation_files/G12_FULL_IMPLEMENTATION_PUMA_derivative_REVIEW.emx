   jacobian_and_gravity_calculation 664 176
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in theta1;
      signal out g [3,1];
      signal out J [3,3];
      signal in theta2;
      signal in theta3;
    end;
    implementation eq
parameters
   real global l1;
   real global l2;
   real global l3;
   real global grav;
   real global m2;
   real global m3;
	real global mc1;
	real global mc2; 
variables
	// Placeholder variables
   real sigma1;
   real sigma2;
   real sigma3;
equations
	sigma3 = l3 * sin(theta2 + theta3);
	sigma2 = sigma3 + l2 * sin(theta2);
	sigma1 = l3 * cos(theta2 + theta3) + l2 * cos(theta2);
	
	// Computation of the Jacobian.
	J = [      -sin(theta1) * sigma2,  cos(theta1) * sigma1,  l3 * cos(theta2 + theta3) * cos(theta1);       
				cos(theta1) * sigma2,  sin(theta1) * sigma1,  l3 * cos(theta2 + theta3) * sin(theta1);       
					0.0,                  -sigma3 - l2 * sin(theta2), -sigma3    ];
	
	// Computation of the effect of gravity on the joints.
	g[1] = 0.0;        
	g[2] = grav * ( (m2 * l2 / 2) + (mc1 * l2) + (m3 * l2) + (mc2 * l2) ) * -sin(theta2)   + grav * ( (m3 * l3 / 2) + (mc2 * l2) ) * -sin(theta2 + theta3);    
	g[3] = grav * ( (m3 * l3 / 2) + (mc2 * l3) ) * -sin(theta2 + theta3);
	
	

implementation_end;
