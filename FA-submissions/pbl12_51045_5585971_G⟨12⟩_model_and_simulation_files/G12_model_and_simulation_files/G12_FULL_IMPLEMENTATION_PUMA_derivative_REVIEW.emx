   params 160 8
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
    end;
    implementation eq
// This submodel contains (nearly) all parameters used in the model to make it more convenient to change things.
parameters
	// world parameters
	real global grav = 9.81;
	
	// motor parameters originally taken from https://www.cubemars.com/product/ak10-9-v2-0-kv60-robotic-actuator.html
	// then modified until the efficiency, current, power, and rpm plots matched the given plot on the website
	real global motor_i = 0.0001002;
	real global motor_k = 0.198; // Kt; 
	real global motor_r = 0.63; // 0.195 on website; 
	real global motor_ind = 181*10e-6; 
	real global current_limit = 29.8;
	real global voltage_limit = 48;
	real global torque_limit = 48;
	real global d_v_gear = 0.0001;
	real global d_c_gear = 0.088;
	
	// connection parameters
	real global shaft_friction = 0.3;	// (lubricated aluminum)
	real global motor_stiffness = 10000;
	
	// arm parameters from PUMA 560 by B. Armstrong, O. Khatib, & J. Burdick 
	// some parameters are not defined here but rather in the 3D-mechanics model of the robot arm. These parameters are also based on the PUMA 560 arm.
	// The weights here are scaled down in weight from the PUMA 560 to the PUMA 260 as we assume this is reasonable compared to more current weights of robots like seen in the ur7e
	real global l1 = 1;
   real global l2 = 0.4318;
   real global l3 = 0.4331;
	real global mc1 = 0;
	real global mc2 = 0;
	//real ratio = 13.3/83; // these total weight values are from https://en.wikipedia.org/wiki/Programmable_Universal_Machine_for_Assembly#cite_note-P1-10-6
	//real mass1 = ratio*59.56;
	//real mass2 = ratio*18.4;
	//real mass3 = ratio*4.8;
	
	// impedance controller parameters
	real global k_stiff_x = 200;
	real global k_damp_x = 50;
	real global k_stiff_y = 200;
	real global k_damp_y = 50;
	real global k_stiff_z = 200;
	real global k_damp_z = 50;
	
	// torque controller parameters
	real global kp_tau = 1 {};				// Proportional gain
	real global tauD_tau = 0{s};		// Derivative time constant: tauD > 0
	real global beta_tau = 0.5 {};		// Tameness constant: 0 < beta << 1
	real global tauI_tau = 0.02 {s};		// Integral time constant: tauI > 0
	
	// current controller parameters
	real global kp_I = 1 {};				// Proportional gain
	real global tauD_I = 0 {s};			// Derivative time constant: tauD > 0
	real global beta_I = 0.5 {};			// Tameness constant: 0 < beta << 1
	real global tauI_I = 0.0005 {s};		// Integral time constant: tauI > 0implementation_end;
   PlusMinus7 304 320
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
