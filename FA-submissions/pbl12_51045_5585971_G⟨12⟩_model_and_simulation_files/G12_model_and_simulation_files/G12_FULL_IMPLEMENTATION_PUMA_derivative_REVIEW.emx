       implementation eq
parameters
	real R = 0.2;        // radius
 	real f = 1;        // 0.2 circs per second
	real start_time = 5;
variables
	real omega;
equations
if time >= start_time then
	omega = 2 * pi * f * (time-start_time);
	output = -R * sin(omega);
else
	output =0;
end;
implementation_end;
