      x_sine -8 208
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Sources\SignalGenerator-Cycloid.emx</LibraryPath><TimeStamp>2007-9-27 16:0:53</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'SignalGenerator-Cycloid'
        ports
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle -24 192 8 224 color 0 fill 15132390;
         line -21.1 216 5.1 216 color 0;
         line -18.9 200 -18.9 218.2 color 0;
         spline -19 216 -14.2 214.1 -7.8 204.8 4.3 202.7 color 16711680 fill 15132390;
         line 1.8 216 1.8 202.7 color 0 fill 15132390 dotted;
       end;
       implementation eq
parameters
	real R = 0.2;        // radius
 	real f = 1;        // 0.2 circs per second
	real start_time = 5;
variables
	real omega;
equations
if time >= start_time then
	omega = 2 * pi * f * (time-start_time);
	output = -R * (cos(omega)-1);
else
	output = 0;
end;
implementation_end;
      y_sine -8 352
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Sources\SignalGenerator-Cycloid.emx</LibraryPath><TimeStamp>2007-9-27 16:0:53</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'SignalGenerator-Cycloid'
        ports
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle -24 336 8 368 color 0 fill 15132390;
         line -21.1 360 5.1 360 color 0;
         line -18.9 344 -18.9 362.2 color 0;
         spline -19 360 -14.2 358.1 -7.8 348.8 4.3 346.7 color 16711680 fill 15132390;
         line 1.8 360 1.8 346.7 color 0 fill 15132390 dotted;
       end;
       implementation eq
parameters
	real R = 0.1;        // radius
 	real f = 0.2;        // 0.2 circs per second
	real y_cen = 0.5;
	real start_time = 5;
variables
	real omega;

equations
if time >= 5 then
	omega = 2 * pi * f * (time-start_time);
	output = -y_cen + R * sin(omega);
else
	output =0;
end;
implementation_end;
