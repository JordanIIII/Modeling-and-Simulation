   torque_calculation 672 319
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in F_in [3,1];
      signal in J [3,3];
      signal out tau [3,1];
      signal in tau_G [3,1];
    end;
    icon bg
     figures
      rectangle 612 298 732 340 color 0 fill 15132390;
      text 'name' 672 320 color 0 16;
    end;
    implementation eq
equations
	// Control law of cartesian impedance control + gravity compensation
	tau = 1*(1*transpose(J) * F_in + 1*tau_G);implementation_end;
