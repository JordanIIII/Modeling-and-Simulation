         signal knot duplicatable in minus [1];
         signal knot out output [1];
       end;
       icon bg ellipse
        figures
         ellipse 424 80 440 96 color 0 fill 16777215;
       end;
       implementation eq
equations
    output = sum (collect (plus)) - sum (collect (minus));
    implementation_end;
