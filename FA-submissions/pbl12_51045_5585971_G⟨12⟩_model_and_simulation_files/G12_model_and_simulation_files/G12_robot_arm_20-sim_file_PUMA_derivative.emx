			-(RotationJointZ1\omega * RotationJointZ1\EndStopDamping)
		else
			0
		end;
	RotationJointZ1\EndStopMaxSpringForce = if (RotationJointZ1_phi > RotationJointZ1\MaximumEndStop) then
			(RotationJointZ1\MaximumEndStop - RotationJointZ1_phi) * RotationJointZ1\EndStopSpring
		else
			0
		end;
	RotationJointZ1\EndStopMaxDampingForce = if (RotationJointZ1_phi > RotationJointZ1\MaximumEndStop) then
			-(RotationJointZ1\omega * RotationJointZ1\EndStopDamping)
		else
			0
		end;
	RotationJointZ1\ConnectionPoint2\AbsHinverse = inverseH (RotationJointZ1\ConnectionPoint2\AbsH);
	RotationJointZ1\Wrench = [0, 0, RotationJointZ1\EndStopMinSpringForce + RotationJointZ1\EndStopMinDampingForce + RotationJointZ1\EndStopMaxSpringForce + RotationJointZ1\EndStopMaxDampingForce + RotationJointZ1\torque, 0, 0, 0] * Adjoint (RotationJointZ1\ConnectionPoint2\AbsHinverse);
	AdjX2[1:3] = RotationJointZ1\ConnectionPoint1\AbsH[1:3, 3];
	AdjX2[4] = RotationJointZ1\ConnectionPoint1\AbsH[2, 4] * RotationJointZ1\ConnectionPoint1\AbsH[3, 3] - RotationJointZ1\ConnectionPoint1\AbsH[3, 4] * RotationJointZ1\ConnectionPoint1\AbsH[2, 3];
	AdjX2[5] = RotationJointZ1\ConnectionPoint1\AbsH[3, 4] * RotationJointZ1\ConnectionPoint1\AbsH[1, 3] - RotationJointZ1\ConnectionPoint1\AbsH[1, 4] * RotationJointZ1\ConnectionPoint1\AbsH[3, 3];
	AdjX2[6] = RotationJointZ1\ConnectionPoint1\AbsH[1, 4] * RotationJointZ1\ConnectionPoint1\AbsH[2, 3] - RotationJointZ1\ConnectionPoint1\AbsH[2, 4] * RotationJointZ1\ConnectionPoint1\AbsH[1, 3];
	AdjX2_T = transpose (AdjX2);
	adjAdjX2 = adjoint (AdjX2);
	AdjX3[1:3] = RotationJointY1\ConnectionPoint1\AbsH[1:3, 2];
	AdjX3[4] = RotationJointY1\ConnectionPoint1\AbsH[2, 4] * RotationJointY1\ConnectionPoint1\AbsH[3, 2] - RotationJointY1\ConnectionPoint1\AbsH[3, 4] * RotationJointY1\ConnectionPoint1\AbsH[2, 2];
	AdjX3[5] = RotationJointY1\ConnectionPoint1\AbsH[3, 4] * RotationJointY1\ConnectionPoint1\AbsH[1, 2] - RotationJointY1\ConnectionPoint1\AbsH[1, 4] * RotationJointY1\ConnectionPoint1\AbsH[3, 2];
	AdjX3[6] = RotationJointY1\ConnectionPoint1\AbsH[1, 4] * RotationJointY1\ConnectionPoint1\AbsH[2, 2] - RotationJointY1\ConnectionPoint1\AbsH[2, 4] * RotationJointY1\ConnectionPoint1\AbsH[1, 2];
	AdjX3_T = transpose (AdjX3);
	adjAdjX3 = adjoint (AdjX3);
	AdjX4[1:3] = RotationJointY2\ConnectionPoint1\AbsH[1:3, 2];
	AdjX4[4] = RotationJointY2\ConnectionPoint1\AbsH[2, 4] * RotationJointY2\ConnectionPoint1\AbsH[3, 2] - RotationJointY2\ConnectionPoint1\AbsH[3, 4] * RotationJointY2\ConnectionPoint1\AbsH[2, 2];
	AdjX4[5] = RotationJointY2\ConnectionPoint1\AbsH[3, 4] * RotationJointY2\ConnectionPoint1\AbsH[1, 2] - RotationJointY2\ConnectionPoint1\AbsH[1, 4] * RotationJointY2\ConnectionPoint1\AbsH[3, 2];
	AdjX4[6] = RotationJointY2\ConnectionPoint1\AbsH[1, 4] * RotationJointY2\ConnectionPoint1\AbsH[2, 2] - RotationJointY2\ConnectionPoint1\AbsH[2, 4] * RotationJointY2\ConnectionPoint1\AbsH[1, 2];
	AdjX4_T = transpose (AdjX4);
	adjAdjX4 = adjoint (AdjX4);
	J2[1:6, 1] = AdjX2;
	J3[1:6, 1] = AdjX2;
	J3[1:6, 2] = AdjX3;
	J4[1:6, 1] = AdjX2;
	J4[1:6, 2] = AdjX3;
	J4[1:6, 3] = AdjX4;
	J5[1:6, 1] = AdjX2;
	J5[1:6, 2] = AdjX3;
	J5[1:6, 3] = AdjX4;
	T1_00 = J1 * v;
	T1_00T = transpose (T1_00);
	T2_00 = J2 * v;
	T2_00T = transpose (T2_00);
	T3_00 = J3 * v;
	T3_00T = transpose (T3_00);
	T4_00 = J4 * v;
	T4_00T = transpose (T4_00);
	T5_00 = J5 * v;
	T5_00T = transpose (T5_00);
	AdjInv2 = Adjoint (inverseH (Body1\AbsH));
	M2 = (transpose (AdjInv2) .* Body1\InDiag) * AdjInv2;
	TM2 = T2_00T * M2;
	AdjInv3 = Adjoint (inverseH (Body2\AbsH));
	M3 = (transpose (AdjInv3) .* Body2\InDiag) * AdjInv3;
	TM3 = T3_00T * M3;
	AdjInv4 = Adjoint (inverseH (Body3\AbsH));
	M4 = (transpose (AdjInv4) .* Body3\InDiag) * AdjInv4;
	TM4 = T4_00T * M4;
	AdjInv5 = Adjoint (inverseH (Body4\AbsH));
	M5 = (transpose (AdjInv5) .* Body4\InDiag) * AdjInv5;
	TM5 = T5_00T * M5;
	M2_2 = AdjX2_T * ((M2 + M3 + M4 + M5) * AdjX2);
	M3_2 = AdjX3_T * ((M3 + M4 + M5) * AdjX2);
	M3_3 = AdjX3_T * ((M3 + M4 + M5) * AdjX3);
	M4_2 = AdjX4_T * ((M4 + M5) * AdjX2);
	M4_3 = AdjX4_T * ((M4 + M5) * AdjX3);
	M4_4 = AdjX4_T * ((M4 + M5) * AdjX4);
	MassMatrix[1, 1] = M2_2;
	MassMatrix[1, 2] = M3_2;
	MassMatrix[1, 3] = M4_2;
	MassMatrix[2, 1] = M3_2;
	MassMatrix[2, 2] = M3_3;
	MassMatrix[2, 3] = M4_3;
	MassMatrix[3, 1] = M4_2;
	MassMatrix[3, 2] = M4_3;
	MassMatrix[3, 3] = M4_4;
	wrenchGrav2 = Body1\mass * [gravity[3] * Body1\AbsH[2, 4] - gravity[2] * Body1\AbsH[3, 4], gravity[1] * Body1\AbsH[3, 4] - gravity[3] * Body1\AbsH[1, 4], gravity[2] * Body1\AbsH[1, 4] - gravity[1] * Body1\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav3 = Body2\mass * [gravity[3] * Body2\AbsH[2, 4] - gravity[2] * Body2\AbsH[3, 4], gravity[1] * Body2\AbsH[3, 4] - gravity[3] * Body2\AbsH[1, 4], gravity[2] * Body2\AbsH[1, 4] - gravity[1] * Body2\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav4 = Body3\mass * [gravity[3] * Body3\AbsH[2, 4] - gravity[2] * Body3\AbsH[3, 4], gravity[1] * Body3\AbsH[3, 4] - gravity[3] * Body3\AbsH[1, 4], gravity[2] * Body3\AbsH[1, 4] - gravity[1] * Body3\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav5 = Body4\mass * [gravity[3] * Body4\AbsH[2, 4] - gravity[2] * Body4\AbsH[3, 4], gravity[1] * Body4\AbsH[3, 4] - gravity[3] * Body4\AbsH[1, 4], gravity[2] * Body4\AbsH[1, 4] - gravity[1] * Body4\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	P_ee = P_ee\ConnectionPoint1\AbsH[1:3, 4];
	PDotBodies[1] = -((TM2 + TM3 + TM4 + TM5) * (adjAdjX2 * T2_00));
	PDotBodies[2] = -((TM3 + TM4 + TM5) * (adjAdjX3 * T3_00));
	PDotBodies[3] = -((TM4 + TM5) * (adjAdjX4 * T4_00));
	PDot = PDotBodies + transpose (wrenchGrav2 * J2 + wrenchGrav3 * J3 + wrenchGrav4 * J4 + wrenchGrav5 * J5 + RotationJointZ1\Wrench * (J2 - J1) + RotationJointY1\Wrench * (J3 - J2) + RotationJointY2\Wrench * (J4 - J3));
	P = int (PDot) + PDotInitial;
	v = linsolve (MassMatrix, P, 'cholesky');
	RotationJointZ1\omega = v[1];
	RotationJointY1\omega = v[2];
	RotationJointY2\omega = v[3];
	RotationJointZ1\torque = RotationJointZ1.e;
	RotationJointZ1.f = RotationJointZ1\omega;
	RotationJointY1\torque = RotationJointY1.e;
	RotationJointY1.f = RotationJointY1\omega;
	RotationJointY2\torque = RotationJointY2.e;
	RotationJointY2.f = RotationJointY2\omega;
implementation_end;
]]>
    </Sidops>
  </Model>
