    type Submodel
    end;
    implementation eq
parameters
	// motor parameters
	real global motor_i = 0.0001002; // https://www.cubemars.com/product/ak10-9-v2-0-kv60-robotic-actuator.html
	real global motor_k = 0.45; // 0.45 not used in ideal model
	real global motor_r = 0.195; // not used in ideal model https://www.cubemars.com/product/ak10-9-v2-0-kv60-robotic-actuator.html
	real global motor_ind = 181*10e-6; // not used in ideal model
	
	// connection parameters
	real global shaft_friction = 0.3; // (lubricated aluminum)
	real global motor_stiffness = 31;
	
	// arm parameters
	real global g = 9.81;
	real global m = 2; // Should be 2
	real global L = 1.0; // Should be 1.0
	real r = 0.1;
	real global arm_inertia = (1/12)*m*(3*r^2+h^2);
	
	// controller parameters;
	real global k_stiff = 57.8;
	real global k_damp = 2*0.3;implementation_end;
