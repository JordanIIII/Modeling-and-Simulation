 implementation eq
parameters
	real global shaft_friction;
	real d = shaft_friction;		// viscous friction
	real Tc = shaft_friction;				// coulomb coefficient from https://www.engineeringtoolbox.com/friction-coefficients-d_778.html
	real slope = 500.0 {s/rad};	// steepness of coulomb friction curve
equations
	p.T = Tc * tanh( slope * p.v ) + d * p.v;implementation_end;
specification_end;
