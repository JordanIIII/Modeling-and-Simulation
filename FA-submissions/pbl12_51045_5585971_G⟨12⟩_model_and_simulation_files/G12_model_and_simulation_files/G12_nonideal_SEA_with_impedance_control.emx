       type 'SignalLimiter-Limit'
        ports
         signal in input;
         signal out output;
       end;
       icon bg bottom
        figures
         group
          rectangle 360 256 392 288 color 0 fill 15132390;
          line 375.9 260.5 375.9 285 color 0 fill 15132390;
          line 363 272.2 388.7 272.2 color 0 fill 15132390;
          spline 369.9 279.1 381.9 265.4 color 16711680 fill 15132390 width 2;
          spline 381.3 266.2 389.9 265.8 color 16711680 fill 15132390 width 2;
          spline 363 279.6 369.9 279.1 color 16711680 fill 15132390 width 2;
