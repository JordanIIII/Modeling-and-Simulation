       implementation bg
        submodels
         AD_deflection 200 432
          description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Discrete\AD.emx</LibraryPath><TimeStamp>2017-09-08 16:16:00</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type AD
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 184 416 216 448 color 0 fill 15132390;
            spline 190.4 441.3 208 423.7 color 16711680;
            text 'A' 193.1 426.1 color 16711680 14;
            text 'D' 206.4 437.3 color 16711680 14;
          end;
          implementation eq
parameters
	real bits = 24;         // Quantization levels (bits)
	real minimum = -0.02;     // Minimum output value
	real maximum = 0.02;      // Maximum output value
	real initial = 0;       // Initial output
variables
	real hold_signal, windowed_signal, quantisized_signal;
	real lsb, half_lsb;
equations
	lsb = (maximum - minimum) / (exp2 (bits) - 1);
	half_lsb = lsb / 2;
	hold_signal = sample (input,initial);
	windowed_signal = if hold_signal <= minimum then
		 minimum + half_lsb
	else
		if hold_signal >= maximum then 
			maximum -half_lsb
		else 
			hold_signal
		end
	end;
	quantisized_signal = if windowed_signal < 0.0 then
		windowed_signal - half_lsb
	else
		 windowed_signal + half_lsb
	end;

	output =  quantisized_signal - (quantisized_signal mod lsb);
    implementation_end;
         Delay_deflection 112 432
          description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Block Diagram\Delay-Time.emx</LibraryPath><TimeStamp>2007-12-6 15:29:52</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type 'Delay-Time'
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 96 416 128 448 color 0 fill 15132390;
            line 100.5 422.4 100.5 441.6 color 0;
            line 126.1 432 97.3 432 color 0;
            spline 100.8 425.8 105.8 425.3 108.8 430.4 111.7 436.3 115.9 438.6 color 16711680;
            spline 111.5 425.3 116.3 425.3 118.9 429.3 121.6 434.7 126.4 438.1 color 16711680;
            group
             line 116.8 427.9 116.8 429.3 color 16711680;
             group
              line 116.8 429.3 116.8 427.9 color 16711680;
              line 109.5 428.7 116.8 428.7 color 16711680;
             end;
            end;
          end;
          implementation eq
parameters
	real delay = 1.0e-5 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
         Friction_observer 416 320
          description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type Submodel
           ports
            signal in torque_cmd;
            signal in motor_speed;
            signal in deflection;
            signal out tau_fric_est;
            signal out dbg_mu_c;
            signal out dbg_mu_v;
            signal out dbg_state;
            signal out dbg_det_A;
            signal out dbg_E_m;
            signal out dbg_alpha;
          end;
          implementation eq
parameters
    real J_motor = 2.918e-05; 
    real K_s = 13000.0; 
    real gear_r = 120.0; 
    real v_init = 0.2 {rad/s}; 
    real v_term = 0.05 {rad/s}; 

variables
    real hidden P_in, E_m;
    real hidden E_kinetic, E_potential, E_stored, E_stored_start;
    real hidden state;
    real hidden int_abs_v, int_sq_v, int_P;
    real hidden S11, S12, S21, S22;
    real hidden E1, E2;
    real hidden det_A;
    real hidden mu_c, mu_v;
    real hidden mu_c_safe, mu_v_safe;
    real hidden alpha, E_tdpa;

equations
	// Model-free energy-based friction compensator based on: H. T. Dinc, J.- K. Lee, and J.- H. Ryu, “Model-free energy-based friction compensation for industrial	collaborative robots as haptic displays"
   // Continuous energy and TDPA
   P_in = (previous(torque_cmd) / gear_r) * motor_speed;
    
   // [Paper Eq. 2]: Net energy input E_m(T) calculated via integration
   E_m = previous(E_m) + (P_in * sampletime);

   // [Paper Eq. 4]: Kinetic energy calculation (modified for SEA to include spring potential)
   E_kinetic = 0.5 * J_motor * (motor_speed * motor_speed);
   E_potential = 0.5 * K_s * (deflection * deflection);
   E_stored = E_kinetic + E_potential;

   // [Paper Eq. 22]: TDPA adaptive damping calculation
   alpha = if (E_m < 0.0) and (abs(motor_speed) > 1.0e-3) then
       -E_m / (sampletime * motor_speed * motor_speed)
   else
       0.0
   end;

   // Hysteresis cycle detection
   state = if (previous(state) == 0.0) and (abs(motor_speed) > v_init) then
       1.0
   else
       if (previous(state) == 1.0) and (abs(motor_speed) < v_term) then
           0.0
       else
           previous(state) + 0.0
       end
   end;

   E_stored_start = if (state == 1.0) and (previous(state) == 0.0) then
       E_stored
   else
       previous(E_stored_start) + 0.0
   end;

   // [Paper Eq. 24]: Dissipated energy by passivity controller E^n_TDPA
   E_tdpa = if (state == 1.0) and (previous(state) == 0.0) then
       alpha * motor_speed * motor_speed * sampletime
   else
       if (state == 1.0) then
           previous(E_tdpa) + (alpha * motor_speed * motor_speed * sampletime)
       else
           0.0
       end
   end;

   // Cycle integrators
   // Derived from the right-hand side terms of [Paper Eq. 16] for Coulomb and Viscous
   int_abs_v = if (state == 1.0) and (previous(state) == 0.0) then
       abs(motor_speed) * sampletime
   else
       if (state == 1.0) then
           previous(int_abs_v) + (abs(motor_speed) * sampletime)
       else
           0.0
       end
   end;

   int_sq_v = if (state == 1.0) and (previous(state) == 0.0) then
       (motor_speed * motor_speed) * sampletime
   else
       if (state == 1.0) then
           previous(int_sq_v) + ((motor_speed * motor_speed) * sampletime)
       else
           0.0
       end
    end;

   int_P = if (state == 1.0) and (previous(state) == 0.0) then
       P_in * sampletime
   else
       if (state == 1.0) then
           previous(int_P) + (P_in * sampletime)
       else
           0.0
       end
   end;

   // Math update
   S11 = if (previous(state) == 1.0) and (state == 0.0) then previous(S21) else previous(S11) + 0.0 end;
   S12 = if (previous(state) == 1.0) and (state == 0.0) then previous(S22) else previous(S12) + 0.0 end;
   E1  = if (previous(state) == 1.0) and (state == 0.0) then previous(E2)  else previous(E1) + 0.0 end;
   S21 = if (previous(state) == 1.0) and (state == 0.0) then previous(int_abs_v) else previous(S21) + 0.0 end;
   S22 = if (previous(state) == 1.0) and (state == 0.0) then previous(int_sq_v)  else previous(S22) + 0.0 end;
    
   // [Paper Eq. 25]: Incorporating the TDPA energy drop and initial stored energy
   E2 = if (previous(state) == 1.0) and (state == 0.0) then
       previous(int_P) - (E_stored - previous(E_stored_start)) - previous(E_tdpa)
   else
       previous(E2) + 0.0
   end;

   // Inverse & friction estimation
   // [Paper Eq. 18 & 20]: 2x2 matrix determinant and inverse for k=2 cycles
   det_A = (S11 * S22) - (S12 * S21);

   mu_c = if (previous(state) == 1.0) and (state == 0.0) and (abs(det_A) > 1.0e-3) then
       ((S22 * E1) - (S12 * E2)) / det_A
   else
       previous(mu_c) + 0.0
   end;

   mu_v = if (previous(state) == 1.0) and (state == 0.0) and (abs(det_A) > 1.0e-3) then
       ((-S21 * E1) + (S11 * E2)) / det_A
   else
       previous(mu_v) + 0.0
   end;

   mu_c_safe = if mu_c < 0.0 then 0.0 else mu_c end;
   mu_v_safe = if mu_v < 0.0 then 0.0 else mu_v end;

   // Output compensation to torque
   // [Paper Eq. 23]: Final compensator torque combined with TDPA, viscous term left out
   tau_fric_est = ((mu_c_safe * sign(motor_speed)) + (0.0 * motor_speed) - (alpha * motor_speed)) * gear_r;

   // Debug outputs
   dbg_mu_c = mu_c_safe;
   dbg_state = state;
   dbg_det_A = det_A;
   dbg_E_m = E_m;
   dbg_alpha = alpha;implementation_end;
