            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 128 208 160 240 color 0 fill 15132390;
            line 132.5 214.4 132.5 233.6 color 0;
            line 158.1 224 129.3 224 color 0;
            spline 132.8 217.8 137.8 217.3 140.8 222.4 143.7 228.3 147.9 230.6 color 16711680;
            spline 143.5 217.3 148.3 217.3 150.9 221.3 153.6 226.7 158.4 230.1 color 16711680;
            group
             line 148.8 219.9 148.8 221.3 color 16711680;
             group
              line 148.8 221.3 148.8 219.9 color 16711680;
              line 141.5 220.7 148.8 220.7 color 16711680;
             end;
            end;
          end;
          implementation eq
parameters
	real delay = 1.0e-4 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
         Delay2 576 352
          description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\Delay-Time.emx</LibraryPath>
  <TimeStamp>2007-12-6 15:29:52</TimeStamp>
</Description>';
          type 'Delay-Time'
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 560 336 592 368 color 0 fill 15132390;
            line 564.5 342.4 564.5 361.6 color 0;
            line 590.1 352 561.3 352 color 0;
            spline 564.8 345.8 569.8 345.3 572.8 350.4 575.7 356.3 579.9 358.6 color 16711680;
            spline 575.5 345.3 580.3 345.3 582.9 349.3 585.6 354.7 590.4 358.1 color 16711680;
            group
             line 580.8 347.9 580.8 349.3 color 16711680;
             group
              line 580.8 349.3 580.8 347.9 color 16711680;
              line 573.5 348.7 580.8 348.7 color 16711680;
             end;
            end;
          end;
          implementation eq
parameters
	real delay = 1.0e-4 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
