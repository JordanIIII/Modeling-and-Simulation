         PI 384 288
          description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Control\PID Control\Discrete\PI.emx</LibraryPath>
  <TimeStamp>2007-9-27 14:49:39</TimeStamp>
</Description>';
          type PI
           ports
            signal out output;
            signal in error;
          end;
          icon bg bottom
           figures
            rectangle 368 272 400 304 color 0 fill 15132390;
            text 'PI' 384 288 color 1336868 18 bold;
          end;
          implementation eq
parameters
	real kp = 1.3354614147183168 {};			// Proportional gain
	real tauI = 7.350671334681414e-4 {s};		// Integral time constant: tauI > 0
variables
	real bi;
	real uP;
	real uI;
equations
	bi = kp*sampletime / tauI;
	uP = kp * error;
	uI = previous(uI) + bi*error;
	output = uP+uI;
              implementation_end;
