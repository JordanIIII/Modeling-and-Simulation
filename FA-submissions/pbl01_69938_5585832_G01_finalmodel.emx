         PD_torque_error 352 216
          description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Control\PID Control\Discrete\PD.emx</LibraryPath><TimeStamp>2007-9-27 14:50:12</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type PD
           ports
            signal in error;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 336 200 368 232 color 0 fill 15132390;
            text 'PD' 352 215.5 color 1336868 18 bold;
          end;
          implementation eq
parameters
	real kp = 10.0 {};			// Proportional gain
	real tauD = 0.00002 {s};		// Derivative time constant: tauD > 0
	real beta = 0.3 {};		// Tameness constant: 0 < beta << 1
variables
	real hidden factor,uD;
equations
	factor = 1 / ( sampletime + tauD * beta );
	uD = factor * ( tauD * previous ( uD ) * beta + tauD * kp * ( error - previous ( error )) + sampletime * kp * error );
	output = uD;implementation_end;
