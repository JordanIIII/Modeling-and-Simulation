										specification 'nanotec'
description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
 type Submodel
  ports
   signal in motor_speed;
   signal out v_limited;
   signal in v_cmd;
 end;
 icon bg
  figures
   rectangle 576 144 656 176 color 0 fill 15132390;
   text 'name' 616 160 color 0 16;
 end;
 implementation eq
parameters
    real I_max = 22.5;      // Maximum allowed current in Amps
    real R = 0.57;         // Motor winding resistance
    real k_e = 0.08;     // Motor torque/speed constant

variables
    real V_max_dynamic;
    real V_min_dynamic;

equations
    // Calculate dynamic voltage bounds based on current speed
    V_max_dynamic = (I_max * R) + (k_e * motor_speed);
    V_min_dynamic = (-I_max * R) + (k_e * motor_speed);
    
    // Limit the commanded voltage to these bounds
    v_limited = limit(v_cmd, max(V_min_dynamic, -36), min(V_max_dynamic, 36));implementation_end;
specification_end;
									end;
        end;
        connections
         DA1\output -> V_I_Limiter1\v_cmd;
         Delay1\output -> Sample1\input;
         Delay2\output -> Sample2\input;
         i_meas -> Delay2\input;
         i_ref -> PlusMinus\plus;
         K_e\output -> PlusMinus1\plus;
         omega_motor -> Delay1\input;
         PI\output -> PlusMinus1\plus;
         PlusMinus\output -> PI\error;
         PlusMinus1\output -> DA1\input;
         Sample1\output -> Splitter1\input;
         Sample2\output -> PlusMinus\minus;
         Splitter1\output -> K_e\input;
         Splitter1\output -> motor_speed;
         V_I_Limiter1\v_limited -> V_cmd;
        end;
       implementation_end;
