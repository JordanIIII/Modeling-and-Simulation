            spline 143.5 217.3 148.3 217.3 150.9 221.3 153.6 226.7 158.4 230.1 color 16711680;
            group
             line 148.8 219.9 148.8 221.3 color 16711680;
             group
              line 148.8 221.3 148.8 219.9 color 16711680;
              line 141.5 220.7 148.8 220.7 color 16711680;
             end;
            end;
          end;
          implementation eq
parameters
	real delay = 1.0e-4 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
