    type Submodel
     ports
      signal in q_in [3,1];
      signal in x_d_in [3,1];
      signal in dx_d_in [3,1];
      signal out q_out [3,1];
      signal out dq_out [3,1];
      signal out x_d_out [3,1];
      signal out dx_d_out [3,1];
    end;
    implementation eq
// AD boundary: samples continuous joint positions and Cartesian setpoints/velocities into the discrete control loop
parameters
	real initial = 0.0;
equations
	q_out[1,1] = sample(q_in[1,1], initial);
	q_out[2,1] = sample(q_in[2,1], initial);
	q_out[3,1] = sample(q_in[3,1], initial);
	dq_out[1,1] = (q_out[1,1] - previous(q_out[1,1], 0)) / sampletime;
	dq_out[2,1] = (q_out[2,1] - previous(q_out[2,1], 0)) / sampletime;
	dq_out[3,1] = (q_out[3,1] - previous(q_out[3,1], 0)) / sampletime;
	x_d_out[1,1] = sample(x_d_in[1,1], initial);
	x_d_out[2,1] = sample(x_d_in[2,1], initial);
	x_d_out[3,1] = sample(x_d_in[3,1], initial);
	dx_d_out[1,1] = sample(dx_d_in[1,1], initial);
	dx_d_out[2,1] = sample(dx_d_in[2,1], initial);
	dx_d_out[3,1] = sample(dx_d_in[3,1], initial);implementation_end;
