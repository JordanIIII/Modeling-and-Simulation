   PlusMinus 624 256
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\PlusMinus.emx</LibraryPath>
  <TimeStamp>2007-9-27 10:15:13</TimeStamp>
</Description>';
    knot PlusMinus
     ports
      signal knot duplicatable in plus [3,1];
      signal knot duplicatable in minus [3,1];
      signal knot out output [3,1];
    end;
    icon bg ellipse
     figures
      ellipse 616 248 632 264 color 0 fill 16777215;
    end;
    implementation eq
equations
    output = sum (collect (plus)) - sum (collect (minus));
    implementation_end;
   Setpoints 56 80
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal out output_set [3,1];
    end;
    implementation eq
parameters
	real pos1[3,1] = [ 0.35;  0.0;  0.55]; // home position
	real pos2[3,1] = [ 0.0;   0.35; 0.25];
	real pos3[3,1] = [ 0.0;   0.35; 0.45];
	real pos4[3,1] = [ 0.0;  -0.35; 0.45];
equations
	if time < 10.0 then
		output_set = pos1;
	elsif time <20.0 then
		output_set = pos2;
	elsif time <30.0 then
		output_set = pos3;
	elsif time <40.0 then
		output_set = pos4;
	end;
implementation_end;
   Trajectory_supervisor 176 256
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in setpoint_in [3,1];
      signal out setpoint_out [3,1];
      signal in current_pos [3,1];
    end;
    implementation eq
parameters
	real global L1;
	real global L2;
	real global base;
	real base_radius = 0.2;
	real floor_z = 0; //0.05;
	real global L3;
variables
	real r_xy;
	real target_distance;
equations
	r_xy = sqrt(setpoint_in[1,1]^2 + setpoint_in[2,1]^2);
	target_distance = sqrt(r_xy^2 + (setpoint_in[3,1] - (L1 + base))^2);
	setpoint_out = setpoint_in;
	/* Workspace safety limiter - disables for now
	if target_distance > (L2 + L3 - 0.01) then
		setpoint_out = current_pos;
	elsif (r_xy < base_radius) and (setpoint_in[3,1] < (L1 + base)) then
		setpoint_out = current_pos;
	elsif setpoint_in[3,1] < floor_z then
		setpoint_out = current_pos;
	else
		setpoint_out = setpoint_in;
	end; */implementation_end;
  end;
  connections
   AD_sensors\dq_out -> Cartesian_impedance_controller\dq;
   AD_sensors\dx_d_out -> Cartesian_impedance_controller\dx_d;
   ArmFR3\joint1_yaw_phi -> Mux1\q1 1080 80;
   ArmFR3\joint2_pitch <= Joint2\q_meas;
   ArmFR3\joint2_pitch_phi -> Mux1\q2 1080 80;
   ArmFR3\joint3_pitch_phi -> Mux1\q3 1080 80;
   Cartesian_impedance_controller\J -> DA_meas\J_in 320 304;
   Cartesian_impedance_controller\q <- AD_sensors\q_out;
   Cartesian_impedance_controller\x_d <- AD_sensors\x_d_out;
   Cartesian_impedance_controller\x_meas -> DA_meas\x_meas_in 320 304;
   DA_meas\J_out -> External_force\J;
   DA_meas\x_meas_out -> Trajectory_supervisor\current_pos;
   DA_tau\torque_in <- Cartesian_impedance_controller\torque_d;
   DA_tau\torque_out -> PlusMinus\plus;
   External_force\tau_ext -> PlusMinus\plus 624 320;
   Joint1\q_meas => ArmFR3\joint1_yaw;
   Joint3\q_meas => ArmFR3\joint3_pitch;
   MJT\setpoint_out -> Trajectory_supervisor\setpoint_in;
   MJT\velocity_out -> AD_sensors\dx_d_in;
   Mux\tau1 -> Joint1\t_ref 704 248 704 216;
   Mux\tau2 -> Joint2\t_ref;
   Mux\tau3 -> Joint3\t_ref 704 264 704 296;
   Mux1\q -> AD_sensors\q_in;
   PlusMinus\output -> Mux\tau;
   Setpoints\output_set -> MJT\setpoint_in;
   Trajectory_supervisor\setpoint_out -> AD_sensors\x_d_in 224 96;
  end;
 implementation_end;
]]></Sidops>
