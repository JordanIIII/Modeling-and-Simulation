   MJT 176 80
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in setpoint_in [3,1];
      signal out setpoint_out [3,1];
      signal out velocity_out [3,1];
    end;
    implementation eq
parameters
	real v_avg = 0.5 {rad/s}; // average joint speed
	real global L1;
	real global L2;
	real global L3;
	real global base = 0.0 {m};
	real q_0[3,1] = [0.0; 0.0; 0.0] {rad};
variables
	// Cartesian inputs
	real x_target, y_target, z_target;
	real r, z_prime, cos_q3, incoming_q[3,1], alpha, beta;
	
	// State memory
	real q_start[3,1];
	real q_target[3,1];
	real q_d[3,1];
	real dq_d[3,1];
	real t_start, diff, distance_q, t_f, tau, scalar_poly, scalar_vel;
	
initialequations
	q_start = q_0;
	q_target = q_0;
	q_d = q_0;
	t_start = 0.0;

equations
	// Inverse kinematics
	x_target = setpoint_in[1,1];
	y_target = setpoint_in[2,1];
	z_target = setpoint_in[3,1];

	r = sqrt(x_target^2 + y_target^2);
	z_prime = z_target - (L1 + base);
	
	cos_q3 = limit((r^2 + z_prime^2 - L2^2 - L3^2) / (2 * L2 * L3), -1.0, 1.0); // clamp to [-1,1] to prevent NaN
	
	// Calculate joint angles
	incoming_q[1,1] = atan2(y_target, x_target);
	incoming_q[3,1] = arccos(cos_q3); 
	
	beta = atan2(r, z_prime);
	alpha = atan2(L3 * sin(incoming_q[3,1]), L2 + L3 * cos_q3);
	incoming_q[2,1] = beta - alpha;

	// State logic
	diff = abs(incoming_q[1,1] - q_target[1,1]) + abs(incoming_q[2,1] - q_target[2,1]) + abs(incoming_q[3,1] - q_target[3,1]);
	
	// Avoid floating point triggering
	if diff > 0.001 then
		q_start = q_d;               // Lock in current intermediate joint position
		q_target = incoming_q;       // Lock in new joint target
		t_start = time;
	end;

	// Motion duration
	distance_q = max(max(abs(q_target[1,1]-q_start[1,1]), abs(q_target[2,1]-q_start[2,1])), abs(q_target[3,1]-q_start[3,1]));
	t_f = (distance_q / v_avg) + 0.001; 
	
	// MJT interpolation
	tau = limit((time - t_start) / t_f, 0.0, 1.0);
	scalar_poly = 6*tau^5 - 15*tau^4 + 10*tau^3;
	scalar_vel = (1.0 / t_f) * (30*tau^4 - 60*tau^3 + 30*tau^2);
	
	q_d = q_start + (q_target - q_start) * scalar_poly;
	dq_d = (q_target - q_start) * scalar_vel;

	// Forward kinematics
	setpoint_out[1,1] = cos(q_d[1,1]) * (L2*sin(q_d[2,1]) + L3*sin(q_d[2,1]+q_d[3,1]));
	setpoint_out[2,1] = sin(q_d[1,1]) * (L2*sin(q_d[2,1]) + L3*sin(q_d[2,1]+q_d[3,1]));
	setpoint_out[3,1] = (L1 + base) + L2*cos(q_d[2,1]) + L3*cos(q_d[2,1]+q_d[3,1]);

	velocity_out[1,1] = -sin(q_d[1,1])*dq_d[1,1]*(L2*sin(q_d[2,1]) + L3*sin(q_d[2,1]+q_d[3,1])) + cos(q_d[1,1])*(L2*cos(q_d[2,1])*dq_d[2,1] + L3*cos(q_d[2,1]+q_d[3,1])*(dq_d[2,1]+dq_d[3,1]));
	velocity_out[2,1] = cos(q_d[1,1])*dq_d[1,1]*(L2*sin(q_d[2,1]) + L3*sin(q_d[2,1]+q_d[3,1])) + sin(q_d[1,1])*(L2*cos(q_d[2,1])*dq_d[2,1] + L3*cos(q_d[2,1]+q_d[3,1])*(dq_d[2,1]+dq_d[3,1]));
	velocity_out[3,1] = -L2*sin(q_d[2,1])*dq_d[2,1] - L3*sin(q_d[2,1]+q_d[3,1])*(dq_d[2,1]+dq_d[3,1]);implementation_end;
