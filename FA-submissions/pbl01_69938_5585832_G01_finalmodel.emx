	TM3 = T3_00T * M3;
	AdjInv4 = Adjoint (inverseH (EE\AbsH));
	M4 = (transpose (AdjInv4) .* EE\InDiag) * AdjInv4;
	TM4 = T4_00T * M4;
	SumM = M2 + M3 + M4;
	pCOMTilde = SumM[1:3, 4:6] / SumM[6, 6];
	pCOM[1] = pCOMTilde[3, 2];
	pCOM[2] = pCOMTilde[1, 3];
	pCOM[3] = pCOMTilde[2, 1];
	M2_2 = AdjX2_T * ((M2 + M3 + M4) * AdjX2);
	M3_2 = AdjX3_T * ((M3 + M4) * AdjX2);
	M3_3 = AdjX3_T * ((M3 + M4) * AdjX3);
	M4_2 = AdjX4_T * (M4 * AdjX2);
	M4_3 = AdjX4_T * (M4 * AdjX3);
	M4_4 = AdjX4_T * (M4 * AdjX4);
	MassMatrix[1, 1] = M2_2;
	MassMatrix[1, 2] = M3_2;
	MassMatrix[1, 3] = M4_2;
	MassMatrix[2, 1] = M3_2;
	MassMatrix[2, 2] = M3_3;
	MassMatrix[2, 3] = M4_3;
	MassMatrix[3, 1] = M4_2;
	MassMatrix[3, 2] = M4_3;
	MassMatrix[3, 3] = M4_4;
	wrenchGrav2 = link1\mass * [gravity[3] * link1\AbsH[2, 4] - gravity[2] * link1\AbsH[3, 4], gravity[1] * link1\AbsH[3, 4] - gravity[3] * link1\AbsH[1, 4], gravity[2] * link1\AbsH[1, 4] - gravity[1] * link1\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav3 = link2\mass * [gravity[3] * link2\AbsH[2, 4] - gravity[2] * link2\AbsH[3, 4], gravity[1] * link2\AbsH[3, 4] - gravity[3] * link2\AbsH[1, 4], gravity[2] * link2\AbsH[1, 4] - gravity[1] * link2\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav4 = EE\mass * [gravity[3] * EE\AbsH[2, 4] - gravity[2] * EE\AbsH[3, 4], gravity[1] * EE\AbsH[3, 4] - gravity[3] * EE\AbsH[1, 4], gravity[2] * EE\AbsH[1, 4] - gravity[1] * EE\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	PositionVector1 = PositionVector1\ConnectionPoint1\AbsH[1:3, 4];
	JMatrix1 = J4;
	vel_ee\ConnectionPoint1\AbsHPos = vel_ee\ConnectionPoint1\AbsH[1:3, 4];
	vel_ee\ConnectionPoint1\invAdjointNoOriH = Adjoint (eye (3), -vel_ee\ConnectionPoint1\AbsHPos);
	vel_ee_Flow = vel_ee\ConnectionPoint1\invAdjointNoOriH * J4 * v;
	vel_ee = vel_ee_Flow[4:6];
	PDotBodies[1] = -((TM2 + TM3 + TM4) * (adjAdjX2 * T2_00));
	PDotBodies[2] = -((TM3 + TM4) * (adjAdjX3 * T3_00));
	PDotBodies[3] = -(TM4 * (adjAdjX4 * T4_00));
	PDot = PDotBodies + transpose (wrenchGrav2 * J2 + wrenchGrav3 * J3 + wrenchGrav4 * J4 + joint1_yaw\Wrench * (J2 - J1) + joint2_pitch\Wrench * (J3 - J2) + joint3_pitch\Wrench * (J4 - J3));
	P = int (PDot) + PDotInitial;
	v = linsolve (MassMatrix, P, 'cholesky');
	joint1_yaw_omega = v[1];
	joint2_pitch_omega = v[2];
	joint3_pitch_omega = v[3];
	joint1_yaw\torque = joint1_yaw.e;
	joint1_yaw.f = joint1_yaw_omega;
	joint2_pitch\torque = joint2_pitch.e;
	joint2_pitch.f = joint2_pitch_omega;
	joint3_pitch\torque = joint3_pitch.e;
	joint3_pitch.f = joint3_pitch_omega;
implementation_end;
   Cartesian_impedance_controller 400 256
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in q [3,1];
      signal in dq [3,1];
      signal in x_d [3,1];
      signal in dx_d [3,1];
      signal out torque_d [3,1];
      signal out x_meas [3,1];
      signal out J [3,3];
    end;
    implementation eq
parameters
	real global base;
	real global L1;
	real global L2;
	real global L3;
	real global m3;
	real global m2;
	real global c2x, c2z, c3x, c3z;
	real gz = -9.81 {m/s2};
	real K[3,3] = [400, 0, 0;0, 400, 0;0, 0, 400] {N/m};
	real D[3,3] = [65, 0, 0;0, 65, 0;0, 0, 65] {Ns/m};
	real g_on = 1;
	real c_on = 1;
	real global a4;
variables
	real pc3[3,1];
	real Jc3[3,3];
	real pc2[3,1];
	real Jc2[3,3];
	real Rz1[3,3], Ry2[3,3], Ry3[3,3];
	real T1[4,4], T2[4,4], T3[4,4], Tee[4,4], T12[4,4], T123[4,4], T[4,4];
	real xh[4,1], x[3,1], dx[3,1];
	real z0[3,1], z1[3,1], z2[3,1];
	real p0[3,1], p1w[3,1], p2w[3,1], p_ee_world[3,1];
	real e_x[3,1], de_x[3,1], F[3,1], g_ff[3,1];
	real s2, c2, s3, c3, s23, c23;
	real dM11_dq2, dM11_dq3;
	real M[3,3], C[3,3];
	real e_z;
equations
	// Forward kinematics
	Rz1 = [cos(q[1,1]), -sin(q[1,1]), 0; sin(q[1,1]), cos(q[1,1]), 0; 0, 0, 1];
	Ry2 = [cos(q[2,1]), 0, sin(q[2,1]); 0, 1, 0; -sin(q[2,1]), 0, cos(q[2,1])];
	Ry3 = [cos(q[3,1]), 0, sin(q[3,1]); 0, 1, 0; -sin(q[3,1]), 0, cos(q[3,1])];
	T1 = homogeneous(Rz1, [0;0;0]);
	T2 = homogeneous(Ry2, [0;0;L1 + base]);
	T3 = homogeneous(Ry3, [a4; 0; L2]);
	Tee = homogeneous(eye(3), [-a4; 0; L3]);
	T12 = T1 * T2;
	T123 = T12 * T3;
	T = T123 * Tee;
	xh = T * [0;0;0;1];
	x  = xh[1:3,1];

	// Jacobian
	z0 = [0;0;1];          // shoulder yaw
	z1 = T1[1:3,2];        // elbow pitch
	z2 = T12[1:3,2];       // wrist pitch
	p0  = [0;0;0];        
	p1w = T12[1:3,4];      
	p2w = T123[1:3,4];    
	p_ee_world = x;
	J[1:3,1] = cross(z0, p_ee_world - p0);
	J[1:3,2] = cross(z1, p_ee_world - p1w);
	J[1:3,3] = cross(z2, p_ee_world - p2w);
	dx = J * dq;

	e_x  = x - x_d;
	de_x = dx - dx_d;

	// Gravity compensation
	pc2 = p1w + c2x * T12[1:3,1]  + c2z * T12[1:3,3];
	Jc2[1:3,1] = cross(z0, pc2 - p0);
	Jc2[1:3,2] = cross(z1, pc2 - p1w);
	Jc2[1:3,3] = [0;0;0];
	pc3 = p2w + c3x * T123[1:3,1] + c3z * T123[1:3,3];
	Jc3[1:3,1] = cross(z0, pc3 - p0);
	Jc3[1:3,2] = cross(z1, pc3 - p1w);
	Jc3[1:3,3] = cross(z2, pc3 - p2w);
	g_ff = transpose(Jc3) * [0; 0; -m3*gz] + transpose(Jc2) * [0; 0; -m2*gz];

	// Inertiamatrix M(q)
	s2  = sin(q[2,1]);          c2  = cos(q[2,1]);
	s3  = sin(q[3,1]);          c3  = cos(q[3,1]);
	s23 = sin(q[2,1]+q[3,1]);   c23 = cos(q[2,1]+q[3,1]);

	M[1,1] = m2*(L2/2*s2)^2 + m3*(L2*s2 + L3/2*s23)^2;
	M[1,2] = 0;   M[1,3] = 0;
	M[2,1] = 0;   M[3,1] = 0;

	M[2,2] = m2*(L2/2)^2 + m3*(L2^2 + L2*L3*c3 + (L3/2)^2);
	M[2,3] = m3*(L2*L3/2*c3 + (L3/2)^2);
	M[3,2] = M[2,3];
	M[3,3] = m3*(L3/2)^2;

	// Coriolismatrix C(q,dq)
	dM11_dq2 = m2*2*(L2/2*s2)*(L2/2*c2)
             + m3*2*(L2*s2 + L3/2*s23)*(L2*c2 + L3/2*c23);
	dM11_dq3 = m3*2*(L2*s2 + L3/2*s23)*(L3/2*c23);

	C[1,1] =  (dM11_dq2*dq[2,1] + dM11_dq3*dq[3,1]) / 2;
	C[1,2] =  dM11_dq2/2 * dq[1,1];
	C[1,3] =  dM11_dq3/2 * dq[1,1];

	C[2,1] = -dM11_dq2/2 * dq[1,1];
	C[2,2] = -m3*L2*(L3/2)*s3 * dq[3,1];
	C[2,3] = -m3*L2*(L3/2)*s3 * (dq[2,1] + dq[3,1]);
	
	C[3,1] = -dM11_dq3/2 * dq[1,1];
	C[3,2] =  m3*L2*(L3/2)*s3 * dq[2,1];
	C[3,3] = 0;

	// Cartesian virtual force
	F = -(D * de_x + K * e_x);

	// Output desired torque
	// Coriolos matrix and gravity compensation can be switched on/off by setting c_on/g_on to 1/0
	torque_d = transpose(J) * F + C * c_on* dq + g_on * g_ff;

	x_meas = x;
	e_z = x[3,1] - x_d[3,1];implementation_end;
   DA_meas 176 320
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in x_meas_in [3,1];
      signal in J_in [3,3];
      signal out x_meas_out [3,1];
      signal out J_out [3,3];
    end;
    implementation eq
// DA boundary: holds continuous time x_meas and J at the discrete sample rate for the impedance controller
equations
	x_meas_out[1,1] = hold(x_meas_in[1,1]);
	x_meas_out[2,1] = hold(x_meas_in[2,1]);
	x_meas_out[3,1] = hold(x_meas_in[3,1]);
	J_out[1,1] = hold(J_in[1,1]);
	J_out[1,2] = hold(J_in[1,2]);
	J_out[1,3] = hold(J_in[1,3]);
	J_out[2,1] = hold(J_in[2,1]);
	J_out[2,2] = hold(J_in[2,2]);
	J_out[2,3] = hold(J_in[2,3]);
	J_out[3,1] = hold(J_in[3,1]);
	J_out[3,2] = hold(J_in[3,2]);
	J_out[3,3] = hold(J_in[3,3]);implementation_end;
   DA_tau 560 256
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in torque_in [3,1];
      signal out torque_out [3,1];
    end;
    implementation eq
// DA boundary: holds discrete torque command and applies a computational delay
parameters
	real t_calc = 5.0e-4 {s};	// calculation time (half of sample time Ts)
variables
	real tau_h[3,1];
equations
	tau_h[1,1] = hold(torque_in[1,1]);
	tau_h[2,1] = hold(torque_in[2,1]);
	tau_h[3,1] = hold(torque_in[3,1]);
	torque_out[1,1] = tdelay(tau_h[1,1], t_calc);
	torque_out[2,1] = tdelay(tau_h[2,1], t_calc);
	torque_out[3,1] = tdelay(tau_h[3,1], t_calc);implementation_end;
   External_force 432 320
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in J [3,3];
      signal out tau_ext [3,1];
    end;
    implementation eq
// Simulates picking up a block with external load
parameters
    real m_block = 2.0 {kg};
    real g_load  = 9.81 {m/s2};
    real t_pickup  = 19.0 {s};
    real t_release = 30.0 {s};
variables
    real F_vec[3,1];
equations
    if (time >= t_pickup) and (time < t_release) then
        F_vec = [0; 0; -m_block * g_load];
    else
        F_vec = [0; 0; 0];
    end;
    tau_ext = transpose(J) * F_vec;implementation_end;
   Joint1 824 216
