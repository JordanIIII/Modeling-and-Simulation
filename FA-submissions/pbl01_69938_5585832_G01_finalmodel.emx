         DA1 384 151.5
          description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Discrete\DA-Delay.emx</LibraryPath>
  <TimeStamp>2017-09-08 16:16:00</TimeStamp>
</Description>';
          type 'DA-Delay'
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 368 135.3 400 167.8 color 0 fill 15132390;
            spline 374.4 161 388.6 146.5 color 16711680;
            text 'A' 390.2 157 color 16711680 14;
            text 'D' 377.2 146.3 color 16711680 14;
            text 'T' 394.1 141.3 color 0;
            group
             line 387.5 144.5 389.9 139.8 392.3 144.5 387.5 144.5 color 0;
            end;
          end;
          implementation eq
parameters
	real bits = 16;         // Quantization levels (bits)
	real minimum = -48;     // Minimum output value
	real maximum = 48;      // Maximum output value
	real t_calc = 5.0e-5 {s};	// Time needed to perfom all calculations of the discrete loop
variables
	real hidden windowed_signal, quantisized_signal, rounded_signal;
	real hidden lsb, half_lsb,calc_output;
equations
	lsb = (maximum - minimum) / (exp2 (bits) -1);
	half_lsb = lsb / 2;
	windowed_signal = if input <= minimum then
		minimum+ half_lsb
	else
		if input >= maximum then 
			maximum - half_lsb
		else 
			input
		end
	end;
	quantisized_signal = if windowed_signal < 0.0 then
		windowed_signal - half_lsb
	else
		 windowed_signal + half_lsb
	end;

	rounded_signal =  quantisized_signal - (quantisized_signal mod lsb);
	calc_output = hold (rounded_signal);
	output = tdelay(calc_output,t_calc);
      implementation_end;
         Delay1 144 224
          description '<Description>
