         DA1 384 151.5
          description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Discrete\DA-Delay.emx</LibraryPath>
  <TimeStamp>2017-09-08 16:16:00</TimeStamp>
</Description>';
          type 'DA-Delay'
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 368 135.3 400 167.8 color 0 fill 15132390;
            spline 374.4 161 388.6 146.5 color 16711680;
            text 'A' 390.2 157 color 16711680 14;
            text 'D' 377.2 146.3 color 16711680 14;
            text 'T' 394.1 141.3 color 0;
            group
             line 387.5 144.5 389.9 139.8 392.3 144.5 387.5 144.5 color 0;
            end;
          end;
          implementation eq
parameters
	real bits = 16;         // Quantization levels (bits)
	real minimum = -48;     // Minimum output value
	real maximum = 48;      // Maximum output value
	real t_calc = 5.0e-5 {s};	// Time needed to perfom all calculations of the discrete loop
variables
	real hidden windowed_signal, quantisized_signal, rounded_signal;
	real hidden lsb, half_lsb,calc_output;
equations
	lsb = (maximum - minimum) / (exp2 (bits) -1);
	half_lsb = lsb / 2;
	windowed_signal = if input <= minimum then
		minimum+ half_lsb
	else
		if input >= maximum then 
			maximum - half_lsb
		else 
			input
		end
	end;
	quantisized_signal = if windowed_signal < 0.0 then
		windowed_signal - half_lsb
	else
		 windowed_signal + half_lsb
	end;

	rounded_signal =  quantisized_signal - (quantisized_signal mod lsb);
	calc_output = hold (rounded_signal);
	output = tdelay(calc_output,t_calc);
      implementation_end;
         Delay1 144 224
          description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\Delay-Time.emx</LibraryPath>
  <TimeStamp>2007-12-6 15:29:52</TimeStamp>
</Description>';
          type 'Delay-Time'
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 128 208 160 240 color 0 fill 15132390;
            line 132.5 214.4 132.5 233.6 color 0;
            line 158.1 224 129.3 224 color 0;
            spline 132.8 217.8 137.8 217.3 140.8 222.4 143.7 228.3 147.9 230.6 color 16711680;
            spline 143.5 217.3 148.3 217.3 150.9 221.3 153.6 226.7 158.4 230.1 color 16711680;
            group
             line 148.8 219.9 148.8 221.3 color 16711680;
             group
              line 148.8 221.3 148.8 219.9 color 16711680;
              line 141.5 220.7 148.8 220.7 color 16711680;
             end;
            end;
          end;
          implementation eq
parameters
	real delay = 1.0e-4 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
