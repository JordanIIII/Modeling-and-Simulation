         Sample1 224 224
          description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Discrete\AD.emx</LibraryPath>
  <TimeStamp>2017-09-08 16:16:00</TimeStamp>
</Description>';
          type AD
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 208 208 240 240 color 0 fill 15132390;
            spline 214.4 233.3 232 215.7 color 16711680;
            text 'A' 217.1 218.1 color 16711680 14;
            text 'D' 230.4 229.3 color 16711680 14;
          end;
          implementation eq
parameters
	real bits = 16;         // Quantization levels (bits)
	real minimum = -50;     // Minimum output value
	real maximum = 50;      // Maximum output value
	real initial = 0;       // Initial output
variables
	real hold_signal, windowed_signal, quantisized_signal;
	real lsb, half_lsb;
equations
	lsb = (maximum - minimum) / (exp2 (bits) - 1);
	half_lsb = lsb / 2;
	hold_signal = sample (input,initial);
	windowed_signal = if hold_signal <= minimum then
		 minimum + half_lsb
	else
		if hold_signal >= maximum then 
			maximum -half_lsb
		else 
			hold_signal
		end
	end;
	quantisized_signal = if windowed_signal < 0.0 then
		windowed_signal - half_lsb
	else
		 windowed_signal + half_lsb
	end;

	output =  quantisized_signal - (quantisized_signal mod lsb);
    implementation_end;
         Sample2 488 352
          description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Discrete\AD.emx</LibraryPath>
  <TimeStamp>2017-09-08 16:16:00</TimeStamp>
</Description>';
          type AD
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 472 336 504 368 color 0 fill 15132390;
            spline 478.4 361.3 496 343.7 color 16711680;
            text 'A' 481.1 346.1 color 16711680 14;
            text 'D' 494.4 357.3 color 16711680 14;
          end;
          implementation eq
parameters
	real bits = 16;         // Quantization levels (bits)
	real minimum = -50;     // Minimum output value
	real maximum = 50;      // Maximum output value
	real initial = 0;       // Initial output
variables
	real hold_signal, windowed_signal, quantisized_signal;
	real lsb, half_lsb;
equations
	lsb = (maximum - minimum) / (exp2 (bits) - 1);
	half_lsb = lsb / 2;
	hold_signal = sample (input,initial);
	windowed_signal = if hold_signal <= minimum then
		 minimum + half_lsb
	else
		if hold_signal >= maximum then 
			maximum -half_lsb
		else 
			hold_signal
		end
	end;
	quantisized_signal = if windowed_signal < 0.0 then
		windowed_signal - half_lsb
	else
		 windowed_signal + half_lsb
	end;

	output =  quantisized_signal - (quantisized_signal mod lsb);
    implementation_end;
