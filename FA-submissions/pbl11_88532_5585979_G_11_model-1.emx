	Arm3\InDiag[6, 1:6] = [Arm3\Ixx, Arm3\Iyy, Arm3\Izz, Arm3\mass, Arm3\mass, Arm3\mass];
	WeldJoint4\ConnectionPoint1\AbsH = multiplyH (Arm3\AbsH, WeldJoint4\ConnectionPoint1\RelH);
	WeldJoint4\AbsH = WeldJoint4\ConnectionPoint1\AbsH;
	WeldJoint4\ConnectionPoint2\AbsH = WeldJoint4\AbsH;
	EE\AbsH = multiplyH (WeldJoint4\ConnectionPoint2\AbsH, EE\RelH);
	EE\InDiag[1, 1:6] = [EE\Ixx, EE\Iyy, EE\Izz, EE\mass, EE\mass, EE\mass];
	EE\InDiag[2, 1:6] = [EE\Ixx, EE\Iyy, EE\Izz, EE\mass, EE\mass, EE\mass];
	EE\InDiag[3, 1:6] = [EE\Ixx, EE\Iyy, EE\Izz, EE\mass, EE\mass, EE\mass];
	EE\InDiag[4, 1:6] = [EE\Ixx, EE\Iyy, EE\Izz, EE\mass, EE\mass, EE\mass];
	EE\InDiag[5, 1:6] = [EE\Ixx, EE\Iyy, EE\Izz, EE\mass, EE\mass, EE\mass];
	EE\InDiag[6, 1:6] = [EE\Ixx, EE\Iyy, EE\Izz, EE\mass, EE\mass, EE\mass];
	Force1\ConnectionPoint1\AbsH = multiplyH (Arm3\AbsH, Force1\ConnectionPoint1\RelH);
	RotationJointY2\ConnectionPoint2\AbsHinverse = inverseH (RotationJointY2\ConnectionPoint2\AbsH);
	RotationJointY2\Wrench = [0, RotationJointY2\torque, 0, 0, 0, 0] * Adjoint (RotationJointY2\ConnectionPoint2\AbsHinverse);
	WeldJoint3\ConnectionPoint1\AbsH = multiplyH (Arm2\AbsH, WeldJoint3\ConnectionPoint1\RelH);
	WeldJoint3\AbsH = WeldJoint3\ConnectionPoint1\AbsH;
	WeldJoint3\ConnectionPoint2\AbsH = WeldJoint3\AbsH;
