         Submodel2 504 416
          description '<Information>
 <Description>
    <Version>4.7</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Signal\Discrete\LowPassFilter-FO.emx</LibraryPath>
  <TimeStamp>2018-4-23 14:25:43</TimeStamp>
<AllowLibraryUpdate>True</AllowLibraryUpdate>
  <ModelVersion>
   <MajorVersion>1</MajorVersion>
   <MinorVersion>0</MinorVersion>
   <PatchVersion>1</PatchVersion>
  </ModelVersion>
  <Keywords>filter</Keywords>
  <Author>Paul Weustink</Author>
  <Company>Controllab Products B.V.</Company>
  <Configuration></Configuration>
 </Description>
</Information>';
          type 'Submodel-FO'
           ports
            signal in input;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle 488 400 520 432 color 0 fill 15132390;
            text 'LPF' 504.5 408.7 color 16711680 14;
            text 'FO' 504.5 422.6 color 16711680 14;
          end;
          implementation eq
parameters
	real BW = 157 {Hz};			// Bandwidth
	real initial = 0.0;		// initial value of the output
variables
   real hidden rate;
	real hidden w {rad/s};
	real state;
equations
	w = twopi * BW;
	rate = (input - state) * w;
	next (state, initial) = state + rate * sampletime;
	output = state;     
implementation_end;
        end;
        connections
         Current_torque -> PlusMinus1\minus;
         Desired_torque -> Hold2\input;
         DiscreteDifferential\output -> Gain3\input;
