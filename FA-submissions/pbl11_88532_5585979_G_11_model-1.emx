         Gain3\output -> Submodel2\input;
         Hold2\output -> Sample2\input;
         PlusMinus1\output -> Splitter2\input;
         PlusMinus4\output -> Output_current;
         PlusMinus6\output -> PlusMinus4\plus;
         Sample2\output -> Splitter1\input;
         Splitter1\output -> Gain1\input;
         Splitter1\output -> PlusMinus1\plus;
         Splitter2\output -> DiscreteDifferential\input;
         Splitter2\output -> Gain2\input;
         Submodel2\output -> PlusMinus6\plus;
        end;
       implementation_end;
     end;
