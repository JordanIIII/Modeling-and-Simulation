equations
	World\AbsH = World\H;
	BaseWeld\ConnectionPoint1\AbsH = multiplyH (World\AbsH, BaseWeld\ConnectionPoint1\RelH);
	BaseWeld\AbsH = BaseWeld\ConnectionPoint1\AbsH;
	BaseWeld\ConnectionPoint2\AbsH = BaseWeld\AbsH;
	Base\AbsH = multiplyH (BaseWeld\ConnectionPoint2\AbsH, Base\RelH);
	RotationJointZ1\ConnectionPoint1\AbsH = multiplyH (Base\AbsH, RotationJointZ1\ConnectionPoint1\RelH);
	RotationJointZ1_phi = int (RotationJointZ1\omega) + RotationJointZ1_phiInitial;
	RotationJointZ1\sinTh = sin (RotationJointZ1_phi);
	RotationJointZ1\CosTh = cos (RotationJointZ1_phi);
	RotationJointZ1\Rot = [RotationJointZ1\CosTh, -RotationJointZ1\sinTh, 0;
				RotationJointZ1\sinTh, RotationJointZ1\CosTh, 0;
				0, 0, 1];
	RotationJointZ1\Pos = 0;
	RotationJointZ1\RelH = homogeneous (RotationJointZ1\Rot, RotationJointZ1\Pos);
	RotationJointZ1\AbsH = multiplyH (RotationJointZ1\ConnectionPoint1\AbsH, RotationJointZ1\RelH);
	RotationJointZ1\ConnectionPoint2\AbsH = RotationJointZ1\AbsH;
	Arm1\AbsH = multiplyH (RotationJointZ1\ConnectionPoint2\AbsH, Arm1\RelH);
	Arm1\AbsHCOM = multiplyH (Arm1\AbsH, Arm1\RelHCOM);
	Arm1\InDiag[1, 1:6] = [Arm1\Ixx, Arm1\Iyy, Arm1\Izz, Arm1\mass, Arm1\mass, Arm1\mass];
	Arm1\InDiag[2, 1:6] = [Arm1\Ixx, Arm1\Iyy, Arm1\Izz, Arm1\mass, Arm1\mass, Arm1\mass];
	Arm1\InDiag[3, 1:6] = [Arm1\Ixx, Arm1\Iyy, Arm1\Izz, Arm1\mass, Arm1\mass, Arm1\mass];
