       implementation eq
// 20-sim User Editor
// MotionProfileWizard.dll
parameters
	real hidden period = 60;	// the total period of all regions
	real hidden totalStroke = -0.2;
	integer nrTimes = 1;

variables
	real hidden fu;
	real hidden dfu;
	real hidden offsetTime, modTime, divTime;
	real hidden stroke;
	real hidden duration;
	real hidden normalizedRegionTime;
	real hidden runningTime;
	integer hidden localProfileCounter;
	integer hidden region;
	integer hidden ProfileCounter;

	real hidden globalStrokeOffset;
	real hidden lastposition;
	real hidden localStrokeOffset;

	// dll-variables
	real hidden dllInput;

	real hidden dllOutput[3];

initialequations

	fu = 0.0;
	dfu = 0.0;
	offsetTime = 0.0;
	modTime = 0.0;
	region = 0;
	stroke = 1.0;
	duration = 1.0;

	dllInput = 0.0;

	dllOutput = 0.0;

	modTime = 0.0;
	divTime = 0.0;
	offsetTime = 0.0;	

	globalStrokeOffset = 0.0;
	position = 0.2;
	velocity = 0.0;
	localStrokeOffset = 0.2;
	normalizedRegionTime = 1.0;

	runningTime = 0.0;
	ProfileCounter = 1;
	localProfileCounter = 1;
	
	lastposition = 0.0;
code

		runningTime = time - offsetTime;
		modTime = runningTime mod period;
		divTime = runningTime div period;
		localProfileCounter = 1 + round(divTime);

		if localProfileCounter <= nrTimes then
			ProfileCounter = localProfileCounter;
			globalStrokeOffset = divTime * totalStroke;
			// determine in which region we are
			if modTime < 10 then
				region = 1;
				normalizedRegionTime = modTime / 10;
			else
				if modTime < 12.5 then
					region = 2;
					normalizedRegionTime = ( modTime - 10) / 2.5;
				else
					if modTime < 17.5 then
						region = 3;
						normalizedRegionTime = ( modTime - 12.5) / 5;
					else
						if modTime < 20 then
							region = 4;
							normalizedRegionTime = ( modTime - 17.5) / 2.5;
						else
							region = 5;
							normalizedRegionTime = ( modTime - 20) / 40;
						end;
					end;
				end;
			end;

			switch(region)

				case 1 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0.2;
					stroke = 0;
					duration = 10;

				case 2 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0.2;
					stroke = 0.7;
					duration = 2.5;

				case 3 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0.9;
					stroke = -1.8;
					duration = 5;

				case 4 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = -0.9;
					stroke = 0.9;
					duration = 2.5;

				case 5 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 40;

			end;

			fu = dllOutput[1];
			dfu = dllOutput[2];

			position = (globalStrokeOffset + localStrokeOffset) + stroke * fu;
			lastposition = position;
			velocity = dfu * stroke / duration;
		else
			position = lastposition;
			velocity = 0.0;
		end; //nrTimes
implementation_end;
