	motor3\InDiag[2, 1:6] = [motor3\Ixx, motor3\Iyy, motor3\Izz, motor3\mass, motor3\mass, motor3\mass];
	motor3\InDiag[3, 1:6] = [motor3\Ixx, motor3\Iyy, motor3\Izz, motor3\mass, motor3\mass, motor3\mass];
	motor3\InDiag[4, 1:6] = [motor3\Ixx, motor3\Iyy, motor3\Izz, motor3\mass, motor3\mass, motor3\mass];
	motor3\InDiag[5, 1:6] = [motor3\Ixx, motor3\Iyy, motor3\Izz, motor3\mass, motor3\mass, motor3\mass];
	motor3\InDiag[6, 1:6] = [motor3\Ixx, motor3\Iyy, motor3\Izz, motor3\mass, motor3\mass, motor3\mass];
	RotationJointY1\ConnectionPoint2\AbsHinverse = inverseH (RotationJointY1\ConnectionPoint2\AbsH);
	RotationJointY1\Wrench = [0, RotationJointY1\torque, 0, 0, 0, 0] * Adjoint (RotationJointY1\ConnectionPoint2\AbsHinverse);
	WeldJoint2\ConnectionPoint1\AbsH = multiplyH (Arm1\AbsH, WeldJoint2\ConnectionPoint1\RelH);
	WeldJoint2\AbsH = WeldJoint2\ConnectionPoint1\AbsH;
	WeldJoint2\ConnectionPoint2\AbsH = WeldJoint2\AbsH;
	motor2\AbsH = multiplyH (WeldJoint2\ConnectionPoint2\AbsH, motor2\RelH);
	motor2\InDiag[1, 1:6] = [motor2\Ixx, motor2\Iyy, motor2\Izz, motor2\mass, motor2\mass, motor2\mass];
	motor2\InDiag[2, 1:6] = [motor2\Ixx, motor2\Iyy, motor2\Izz, motor2\mass, motor2\mass, motor2\mass];
	motor2\InDiag[3, 1:6] = [motor2\Ixx, motor2\Iyy, motor2\Izz, motor2\mass, motor2\mass, motor2\mass];
	motor2\InDiag[4, 1:6] = [motor2\Ixx, motor2\Iyy, motor2\Izz, motor2\mass, motor2\mass, motor2\mass];
	motor2\InDiag[5, 1:6] = [motor2\Ixx, motor2\Iyy, motor2\Izz, motor2\mass, motor2\mass, motor2\mass];
