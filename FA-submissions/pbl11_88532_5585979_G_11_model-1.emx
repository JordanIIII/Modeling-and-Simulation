	RotationJointY2\ConnectionPoint1\AbsH = multiplyH (Arm2\AbsH, RotationJointY2\ConnectionPoint1\RelH);
	RotationJointY2_phi = int (RotationJointY2\omega) + RotationJointY2_phiInitial;
	RotationJointY2\sinTh = sin (RotationJointY2_phi);
	RotationJointY2\CosTh = cos (RotationJointY2_phi);
	RotationJointY2\Rot = [RotationJointY2\CosTh, 0, RotationJointY2\sinTh;
