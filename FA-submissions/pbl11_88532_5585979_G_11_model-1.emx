parameters
	
	// mass of motors
	real global m_motor1= 0.95;
	real global m_motor2= 2.282;
	real global m_motor3= 1.443;
	real global M_ee = 0.1;
	
	// links lenghts and masses 
	real global l1= 0.2;
	real global l2= 0.6;
	real global l3= 0.4;
	
	real global m1= 0.13;
	real global m2= 0.57;
	real global m3= 0.19;

	real global r= 0.1;
	
	
	//Motor and gearbox constants
	//M1
	real global gear_ratio1=12;
	real global torque_const1=0.0919;
	

	real global kp_torque1=1.1335;
	real global kd_torque1=0.01995;
	
	
	//M2
	real global gear_ratio2=62;
	real global torque_const2=0.0836;

	
	real global kp_torque2=0.0622;
	real global kd_torque2= 0.00901; //0.04668
	
	
	//M3
	real global gear_ratio3=12;
	real global torque_const3=0.0919;
	

	real global kp_torque3=1.1335;
	real global kd_torque3=0.01152;	


	//SEA stiffnesses
	real global stiffness_1=50;
	real global stiffness_2=300;
	real global stiffness_3=150;

	
	real global offset_const1=0.9;
	real global offset_const2=0.3;
	real global offset_const3=0.6;
	implementation_end;
   Impedance_Controller 144 264
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in Pos_error [3,1];
      signal out Force [3,1];
      signal in Vel_error [3,1];
    end;
    implementation eq
/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/
parameters
	
	real kd=10;
	real kp=100;
	
	real Kd[3,3]=kd*eye(3);
	real Kp[3,3]=kp*eye(3);
	
equations
	// start typing here
	Force = Kp*Pos_error+Kd*Vel_error;
 implementation_end;
   Joint_Torque 288 264
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in Force [3,1];
      signal in Jacobian [3,3];
      signal in q1;
      signal in q2;
      signal in q3;
      signal out Tau [3,1];
    end;
    implementation eq
/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/
parameters
	real global m1;
	real global m2;
	real global m3;
	
	real global m_motor3;
	real global M_ee;
	
	real global l1;
	real global l2;
	real global l3;
	
variables
	real grav_comp[3,1];
	real T_out[3,1];
	
	
equations
	//calculate the desired joint torques
	T_out=transpose(Jacobian)*Force;
	
	//Include gravity compensation
	grav_comp=[0;
	-g_n* ( (m2/2+m3+m_motor3+M_ee)*l2*sin(q2)+(m3/2+M_ee)*l3*sin(q2+q3));
	-g_n* ((m3/2+M_ee)*l3*sin(q2+q3))];
	
	
	Tau = T_out+grav_comp;
 implementation_end;
