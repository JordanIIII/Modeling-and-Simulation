   End_vel 984 360
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in qdot1;
      signal out end_vel [3,1];
      signal in qdot2;
      signal in qdot3;
      signal in theta1;
      signal in theta2;
      signal in theta3;
      signal out Jacobian [3,3];
    end;
    implementation eq
/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/
parameters
	real global l1;
	real global l2;
	real global l3;
	
variables
	real sig1;
	real sig2;
	real sig3;
	real qdot[3,1];
	real Jac[3,3];
equations
	sig1= l3*cos(theta2 + theta3) + l2*cos(theta2);
	sig3=l3*sin(theta2 + theta3);
	sig2=sig3 + l2*sin(theta2);
	Jac=[-sin(theta1)*sig2, cos(theta1)*sig1, l3*cos(theta2 + theta3)*cos(theta1);
	cos(theta1)*sig2, sin(theta1)*sig1, l3*cos(theta2 + theta3)*sin(theta1); 
	0, - sig3 - l2*sin(theta2), -sig3];
	qdot=[qdot1;qdot2;qdot3];
	
	Jacobian=Jac;
	end_vel = Jac*qdot;
 implementation_end;
   Forward_kinematics 1144 272
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in q1;
      signal out Pos [3,1];
      signal in q2;
      signal in q3;
    end;
    implementation eq
/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/

parameters
	real global l1;
	real global l2;
	real global l3;

variables
	real x;
	real y;
	real z;
	
equations
	x=cos(q1)*(l2*sin(q2)+l3*sin(q2+q3));
	y=sin(q1)*(l2*sin(q2)+l3*sin(q2+q3));
	z=l1+l2*cos(q2)+l3*cos(q2+q3);
	
	Pos = [x;y;z];
 implementation_end;
