      MotionProfile 256 288
       description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\MotionProfile.emx</LibraryPath>
  <TimeStamp>2007-12-19 13:45:54</TimeStamp>
  <AllowLibraryUpdate>False</AllowLibraryUpdate>
</Description>';
       type 'MotionProfile-Wizard'
        ports
         signal out x;
        parameters
         real stroke = 10;
         real start_time = 30;
         real stop_time = 32;
         real return_time = 36;
         real end_time = 38;
       end;
       icon bg bottom
        figures
         rectangle 241 273 271 303 color 0 fill 15132390;
         line 243.7 295.5 268.3 295.5 color 0;
         line 245.8 280.5 245.8 297.6 color 0;
         line 246.2 295.2 249.5 295.2 254.5 282.2 259 282.2 264.2 295.2 268.2 295 color 16711680;
         rectangle 241 273 271 303 color -1;
         line 261.6 277.3 263.6 277.1 color 16711680;
         line 262.8 275.3 264.8 275 color 16711680;
         line 265.1 277.2 267.1 277 color 16711680;
         line 264.7 278.3 267.5 289 color 5855577 width 2;
       end;
       implementation eq
// 20-sim User Editor
// MotionProfile.dll
/*
MotionType	Pulse
Stroke	10
StartTime	30
StopTime	32
ReturnTime	36
EndTime	38
Period	5
CV	0.2
CA	0.2
n	3
alpha	0.1
BB	0
BM	0
ProfileType	Cycloidal
DoOutputPosition	1
DoOutputVelocity	0
DoOutputAcceleration	0
InputChoice	0
GenerateEvents	1
DescriptionEnd
*/
 variables
  real hidden u;
  real hidden fu;
  real hidden rise_time;
  real hidden fall_time;
  boolean hidden evt1, evt2;
  boolean hidden evt3, evt4;
  real hidden two_pi;
 equations
	rise_time = (stop_time - start_time);
	fall_time = (end_time - return_time);
	if time < return_time then
		x = stroke * fu;
	else
		x = stroke * (1 - fu);
	end;

	if time < start_time then
		u = 0;
	else
		if time < stop_time then
			u = ( time - start_time ) / rise_time;
		else
			if time < return_time then
				u = 1;
			else
				if time < end_time then
					u = ( time - return_time ) / fall_time;
				else
					u = 1;
				end;
			end;
		end;
	end;
	evt1 = timeevent(start_time);
	evt2 = timeevent(stop_time);
	evt3 = timeevent(return_time);
	evt4 = timeevent(end_time);
	two_pi = 6.283185307179586;
	if u == 0 then
		fu = 0;
	else
		if u == 1 then
			fu = 1;
		else
			fu = (u - ( sin ( two_pi * u ) ) / two_pi );
		end;
	end;
implementation_end;
