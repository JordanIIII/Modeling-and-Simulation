	RotationJointZ1\Wrench = [0, 0, RotationJointZ1\torque, 0, 0, 0] * Adjoint (RotationJointZ1\ConnectionPoint2\AbsHinverse);
	WeldJoint1\ConnectionPoint1\AbsH = multiplyH (Base\AbsH, WeldJoint1\ConnectionPoint1\RelH);
	WeldJoint1\AbsH = WeldJoint1\ConnectionPoint1\AbsH;
	WeldJoint1\ConnectionPoint2\AbsH = WeldJoint1\AbsH;
	motor1\AbsH = multiplyH (WeldJoint1\ConnectionPoint2\AbsH, motor1\RelH);
	motor1\InDiag[1, 1:6] = [motor1\Ixx, motor1\Iyy, motor1\Izz, motor1\mass, motor1\mass, motor1\mass];
	motor1\InDiag[2, 1:6] = [motor1\Ixx, motor1\Iyy, motor1\Izz, motor1\mass, motor1\mass, motor1\mass];
	motor1\InDiag[3, 1:6] = [motor1\Ixx, motor1\Iyy, motor1\Izz, motor1\mass, motor1\mass, motor1\mass];
	motor1\InDiag[4, 1:6] = [motor1\Ixx, motor1\Iyy, motor1\Izz, motor1\mass, motor1\mass, motor1\mass];
	motor1\InDiag[5, 1:6] = [motor1\Ixx, motor1\Iyy, motor1\Izz, motor1\mass, motor1\mass, motor1\mass];
	motor1\InDiag[6, 1:6] = [motor1\Ixx, motor1\Iyy, motor1\Izz, motor1\mass, motor1\mass, motor1\mass];
	AdjX2[1:3] = RotationJointZ1\ConnectionPoint1\AbsH[1:3, 3];
	AdjX2[4] = RotationJointZ1\ConnectionPoint1\AbsH[2, 4] * RotationJointZ1\ConnectionPoint1\AbsH[3, 3] - RotationJointZ1\ConnectionPoint1\AbsH[3, 4] * RotationJointZ1\ConnectionPoint1\AbsH[2, 3];
	AdjX2[5] = RotationJointZ1\ConnectionPoint1\AbsH[3, 4] * RotationJointZ1\ConnectionPoint1\AbsH[1, 3] - RotationJointZ1\ConnectionPoint1\AbsH[1, 4] * RotationJointZ1\ConnectionPoint1\AbsH[3, 3];
	AdjX2[6] = RotationJointZ1\ConnectionPoint1\AbsH[1, 4] * RotationJointZ1\ConnectionPoint1\AbsH[2, 3] - RotationJointZ1\ConnectionPoint1\AbsH[2, 4] * RotationJointZ1\ConnectionPoint1\AbsH[1, 3];
	AdjX2_T = transpose (AdjX2);
	adjAdjX2 = adjoint (AdjX2);
	AdjX3[1:3] = RotationJointY1\ConnectionPoint1\AbsH[1:3, 2];
	AdjX3[4] = RotationJointY1\ConnectionPoint1\AbsH[2, 4] * RotationJointY1\ConnectionPoint1\AbsH[3, 2] - RotationJointY1\ConnectionPoint1\AbsH[3, 4] * RotationJointY1\ConnectionPoint1\AbsH[2, 2];
	AdjX3[5] = RotationJointY1\ConnectionPoint1\AbsH[3, 4] * RotationJointY1\ConnectionPoint1\AbsH[1, 2] - RotationJointY1\ConnectionPoint1\AbsH[1, 4] * RotationJointY1\ConnectionPoint1\AbsH[3, 2];
	AdjX3[6] = RotationJointY1\ConnectionPoint1\AbsH[1, 4] * RotationJointY1\ConnectionPoint1\AbsH[2, 2] - RotationJointY1\ConnectionPoint1\AbsH[2, 4] * RotationJointY1\ConnectionPoint1\AbsH[1, 2];
	AdjX3_T = transpose (AdjX3);
	adjAdjX3 = adjoint (AdjX3);
	AdjX4[1:3] = RotationJointY2\ConnectionPoint1\AbsH[1:3, 2];
	AdjX4[4] = RotationJointY2\ConnectionPoint1\AbsH[2, 4] * RotationJointY2\ConnectionPoint1\AbsH[3, 2] - RotationJointY2\ConnectionPoint1\AbsH[3, 4] * RotationJointY2\ConnectionPoint1\AbsH[2, 2];
	AdjX4[5] = RotationJointY2\ConnectionPoint1\AbsH[3, 4] * RotationJointY2\ConnectionPoint1\AbsH[1, 2] - RotationJointY2\ConnectionPoint1\AbsH[1, 4] * RotationJointY2\ConnectionPoint1\AbsH[3, 2];
	AdjX4[6] = RotationJointY2\ConnectionPoint1\AbsH[1, 4] * RotationJointY2\ConnectionPoint1\AbsH[2, 2] - RotationJointY2\ConnectionPoint1\AbsH[2, 4] * RotationJointY2\ConnectionPoint1\AbsH[1, 2];
	AdjX4_T = transpose (AdjX4);
	adjAdjX4 = adjoint (AdjX4);
	J2[1:6, 1] = AdjX2;
	J3[1:6, 1] = AdjX2;
	J3[1:6, 2] = AdjX3;
	J4[1:6, 1] = AdjX2;
	J4[1:6, 2] = AdjX3;
	J4[1:6, 3] = AdjX4;
	J5[1:6, 1] = AdjX2;
	J5[1:6, 2] = AdjX3;
	J5[1:6, 3] = AdjX4;
	J6[1:6, 1] = AdjX2;
	J6[1:6, 2] = AdjX3;
	J7[1:6, 1] = AdjX2;
	T1_00 = J1 * v;
	T1_00T = transpose (T1_00);
	T2_00 = J2 * v;
	T2_00T = transpose (T2_00);
	T3_00 = J3 * v;
	T3_00T = transpose (T3_00);
	T4_00 = J4 * v;
	T4_00T = transpose (T4_00);
	T5_00 = J5 * v;
	T5_00T = transpose (T5_00);
	T6_00 = J6 * v;
	T6_00T = transpose (T6_00);
	T7_00 = J7 * v;
	T7_00T = transpose (T7_00);
	T8_00 = J8 * v;
	T8_00T = transpose (T8_00);
	AdjInv2 = Adjoint (inverseH (Arm1\AbsHCOM));
	M2 = (transpose (AdjInv2) .* Arm1\InDiag) * AdjInv2;
	TM2 = T2_00T * M2;
	AdjInv3 = Adjoint (inverseH (Arm2\AbsHCOM));
	M3 = (transpose (AdjInv3) .* Arm2\InDiag) * AdjInv3;
	TM3 = T3_00T * M3;
	AdjInv4 = Adjoint (inverseH (Arm3\AbsHCOM));
	M4 = (transpose (AdjInv4) .* Arm3\InDiag) * AdjInv4;
	TM4 = T4_00T * M4;
	AdjInv5 = Adjoint (inverseH (EE\AbsH));
	M5 = (transpose (AdjInv5) .* EE\InDiag) * AdjInv5;
	TM5 = T5_00T * M5;
	AdjInv6 = Adjoint (inverseH (motor3\AbsH));
	M6 = (transpose (AdjInv6) .* motor3\InDiag) * AdjInv6;
	TM6 = T6_00T * M6;
	AdjInv7 = Adjoint (inverseH (motor2\AbsH));
	M7 = (transpose (AdjInv7) .* motor2\InDiag) * AdjInv7;
	TM7 = T7_00T * M7;
	AdjInv8 = Adjoint (inverseH (motor1\AbsH));
	M8 = (transpose (AdjInv8) .* motor1\InDiag) * AdjInv8;
	TM8 = T8_00T * M8;
	M2_2 = AdjX2_T * ((M2 + M3 + M4 + M5 + M6 + M7) * AdjX2);
	M3_2 = AdjX3_T * ((M3 + M4 + M5 + M6) * AdjX2);
	M3_3 = AdjX3_T * ((M3 + M4 + M5 + M6) * AdjX3);
	M4_2 = AdjX4_T * ((M4 + M5) * AdjX2);
	M4_3 = AdjX4_T * ((M4 + M5) * AdjX3);
	M4_4 = AdjX4_T * ((M4 + M5) * AdjX4);
	MassMatrix[1, 1] = M2_2;
	MassMatrix[1, 2] = M3_2;
	MassMatrix[1, 3] = M4_2;
	MassMatrix[2, 1] = M3_2;
	MassMatrix[2, 2] = M3_3;
	MassMatrix[2, 3] = M4_3;
	MassMatrix[3, 1] = M4_2;
	MassMatrix[3, 2] = M4_3;
	MassMatrix[3, 3] = M4_4;
	wrenchGrav2 = Arm1\mass * [gravity[3] * Arm1\AbsHCOM[2, 4] - gravity[2] * Arm1\AbsHCOM[3, 4], gravity[1] * Arm1\AbsHCOM[3, 4] - gravity[3] * Arm1\AbsHCOM[1, 4], gravity[2] * Arm1\AbsHCOM[1, 4] - gravity[1] * Arm1\AbsHCOM[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav3 = Arm2\mass * [gravity[3] * Arm2\AbsHCOM[2, 4] - gravity[2] * Arm2\AbsHCOM[3, 4], gravity[1] * Arm2\AbsHCOM[3, 4] - gravity[3] * Arm2\AbsHCOM[1, 4], gravity[2] * Arm2\AbsHCOM[1, 4] - gravity[1] * Arm2\AbsHCOM[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav4 = Arm3\mass * [gravity[3] * Arm3\AbsHCOM[2, 4] - gravity[2] * Arm3\AbsHCOM[3, 4], gravity[1] * Arm3\AbsHCOM[3, 4] - gravity[3] * Arm3\AbsHCOM[1, 4], gravity[2] * Arm3\AbsHCOM[1, 4] - gravity[1] * Arm3\AbsHCOM[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav5 = EE\mass * [gravity[3] * EE\AbsH[2, 4] - gravity[2] * EE\AbsH[3, 4], gravity[1] * EE\AbsH[3, 4] - gravity[3] * EE\AbsH[1, 4], gravity[2] * EE\AbsH[1, 4] - gravity[1] * EE\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav6 = motor3\mass * [gravity[3] * motor3\AbsH[2, 4] - gravity[2] * motor3\AbsH[3, 4], gravity[1] * motor3\AbsH[3, 4] - gravity[3] * motor3\AbsH[1, 4], gravity[2] * motor3\AbsH[1, 4] - gravity[1] * motor3\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav7 = motor2\mass * [gravity[3] * motor2\AbsH[2, 4] - gravity[2] * motor2\AbsH[3, 4], gravity[1] * motor2\AbsH[3, 4] - gravity[3] * motor2\AbsH[1, 4], gravity[2] * motor2\AbsH[1, 4] - gravity[1] * motor2\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav8 = motor1\mass * [gravity[3] * motor1\AbsH[2, 4] - gravity[2] * motor1\AbsH[3, 4], gravity[1] * motor1\AbsH[3, 4] - gravity[3] * motor1\AbsH[1, 4], gravity[2] * motor1\AbsH[1, 4] - gravity[1] * motor1\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	Force1\ConnectionPoint1\AbsHPos = Force1\ConnectionPoint1\AbsH[1:3, 4];
	Force1\ConnectionPoint1\invAdjointNoOriH = Adjoint (eye (3), -Force1\ConnectionPoint1\AbsHPos);
	Force1_Effort[1:3] = 0;
	Force1_Effort[4:6] = Force1.e;
	Force1_Flow = Force1\ConnectionPoint1\invAdjointNoOriH * T4_00;
	Force1.f = Force1_Flow[4:6];
	PDotBodies[1] = -((TM2 + TM3 + TM4 + TM5 + TM6 + TM7) * (adjAdjX2 * T2_00));
	PDotBodies[2] = -((TM3 + TM4 + TM5 + TM6) * (adjAdjX3 * T3_00));
	PDotBodies[3] = -((TM4 + TM5) * (adjAdjX4 * T4_00));
	PDot = PDotBodies + transpose (wrenchGrav2 * J2 + wrenchGrav3 * J3 + wrenchGrav4 * J4 + wrenchGrav5 * J5 + wrenchGrav6 * J6 + wrenchGrav7 * J7 + wrenchGrav8 * J8 + transpose (Force1_Effort) * Force1\ConnectionPoint1\invAdjointNoOriH * J4 + RotationJointZ1\Wrench * (J2 - J1) + RotationJointY1\Wrench * (J3 - J2) + RotationJointY2\Wrench * (J4 - J3));
	P = int (PDot) + PDotInitial;
	v = linsolve (MassMatrix, P, 'cholesky');
	RotationJointZ1\omega = v[1];
	RotationJointY1\omega = v[2];
	RotationJointY2\omega = v[3];
	RotationJointZ1\torque = RotationJointZ1.e;
	RotationJointZ1.f = RotationJointZ1\omega;
	RotationJointY1\torque = RotationJointY1.e;
	RotationJointY1.f = RotationJointY1\omega;
	RotationJointY2\torque = RotationJointY2.e;
	RotationJointY2.f = RotationJointY2\omega;
implementation_end;
