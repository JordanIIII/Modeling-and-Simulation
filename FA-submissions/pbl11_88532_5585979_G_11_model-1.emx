         R_gearbox 944 192
          description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type R
           ports
            power in p;
          end;
          icon bg ellipse bottom
           figures
            text 'R' 944 192 color 0 18 bold;
          end;
          implementation eq
parameters
    // Datasheet reference values
    real eta_ref = 0.83;        // gearbox efficiency [-]
    real T_ref = 4.21;          // max continuous output torque [Nm]
    real P_ref = 180;            // max continuous output power [W], (rated torque of the gearbox and rated output speed of the motor)

    // Friction loss split, input as percentages
    real percC = 90;            // Coulomb friction percentage [%]
    real percV = 100 - percC;   // Viscous friction percentage [%]

    // Smoothing velocity for tanh
    real w_eps = 2000;          // [rad/s]

    // Automatically calculated values
    real w_ref = P_ref / T_ref; 
    real T_loss_ref = T_ref * (1 / eta_ref - 1);

    real fracC = percC / (percC + percV);
    real fracV = percV / (percC + percV);

    real dC = fracC * T_loss_ref;           // Coulomb friction torque [Nm]
    real dV = fracV * T_loss_ref / w_ref;   // Viscous friction coefficient [Nm/(rad/s)]

equations
    p.e = dC * tanh(p.f * w_eps) + dV * p.f;
implementation_end;
