      implementation_end;
      Splitter1 -64 240
       description '<Description><Version>4.0</Version>
   <LibraryPath>Signal\Block Diagram\Splitter.emx</LibraryPath>
  <TimeStamp>2008-01-17 11:28:29</TimeStamp>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
</Description>';
       knot Splitter
        ports
         signal knot duplicatable out output [1];
         signal knot in input [1];
       end;
       icon bg ellipse
        figures
         ellipse -67.2 236.8 -60.8 243.2 color -1 fill 0;
         ellipse -68.3 235.7 -59.7 244.3 color -1;
        terminals
         input -64 240 fixed;
       end;
       implementation eq
equations
    collect (output) = input;
implementation_end;
      Tspring 216 88
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Block Diagram\Gain.emx</LibraryPath><TimeStamp>2007-9-26 12:15:12</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type Gain
        ports
         signal in input;
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle 200.1 72 231.9 104 color 0 fill 15132390;
         text 'K' 216 88 color 16711680 16 bold;
       end;
       implementation eq
parameters
	real global k1;		// spring stiffness
equations
	output = k1 * input;
    implementation_end;
      ZeroJunction1 376 240
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\ZeroJunction.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:45:16</TimeStamp>
</Description>
</Information>';
       knot ZeroJunction
        ports
         rotation knot duplicatable none p [1];
         signal knot out effort [1];
        restrictions
         causality constraint one_in p;
       end;
       icon bg ellipse
        figures
         text '0' 376 240 color 0 18 bold;
       end;
       implementation eq
equations
	sum (direct (p.f)) = 0;
	equal (collect (p.e));
	effort = first (p.e);
implementation_end;
     end;
     connections
      C1\state -> Sample\input 376 88;
      dQspring\p2 => C1\p;
      Feedforward\output -> PlusMinus1\plus;
      Hold1\output -> Sample2\input;
      input -> Hold1\input;
      MaxonMotor\p2 => ZeroJunction1\p;
      p <= LinkEncoder1\p2;
      PID\output -> PlusMinus1\plus;
      PlusMinus1\output -> MaxonMotor\Ides;
      PlusMinus2\output -> PID\error;
      Sample\output -> Tspring\input;
      Sample2\output -> Splitter1\input;
      Splitter1\output -> Feedforward\input -64 312;
      Splitter1\output -> PlusMinus2\plus;
      Tspring\output -> PlusMinus2\minus -16 88;
      ZeroJunction1\p => dQspring\p1;
      ZeroJunction1\p => LinkEncoder1\p1;
     end;
    implementation_end;
  end;
  connections
   Control\torques -> Demux\input;
   Demux\output1 -> SEA_1\Tdes;
   Demux\output3 -> SEA_3\input;
   Desired_position\pos_des -> Control\pos_des;
   EE_disturbance\disturbance -> MSe\effort;
   Final_arm\Arm1_Arm2 <= SEA_3\p;
   Final_arm\Arm1_Arm2_phi -> Position\input3;
   Final_arm\Base_Rot <= SEA_1\Load;
   Final_arm\Base_Rot_phi -> Position\input1;
   Final_arm\Rot_Arm1 <= SEA_2\p;
   Final_arm\Rot_Arm1_phi -> Position\input2;
   MSe\p => Final_arm\Force1;
   Position\output -> Control\joint_pos 1056 256 544 256;
   SEA_2\input <- Demux\output2;
  end;
 implementation_end;
