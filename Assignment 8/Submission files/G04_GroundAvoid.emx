         OneJunction\p => InductanceMotor\p;
         OneJunction\p => Rmotor\p;
         OneJunction1\p => MotorGearboxInertia\p;
         OneJunction3\p <= PowerSensorIn\p2;
         OneJunction3\p => GearFriction\p;
