       icon bg bottom
        figures
         group
          rectangle 320 224 352 256 color 0 fill 15132390;
          line 324.5 230.4 324.5 249.6 color 0;
          line 350.1 240 321.3 240 color 0;
          spline 324.9 239.9 328.1 231.8 331.3 239.9 334.6 248 337.7 239.9 340.8 231.8 344.1 239.9 347.6 248.2 350.8 240.2 color 16711680;
