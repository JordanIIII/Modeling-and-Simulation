         rectangle 120.1 296 151.9 328 color 0 fill 15132390;
         text 'K' 136 312 color 16711680 16 bold;
       end;
       implementation eq
parameters
	real gearratio = 33.0;		// gain
	real geareff = 1.0;			// should be 0.75
	real motorconst = 53.8e-3;
	real motoreff = 0.88;
variables 
	real Tmotor;
	real Imotor;
equations
	Tmotor = (input/gearratio)/geareff;
	Imotor = (Tmotor/motorconst)/motoreff;
	output = Imotor; // all together are approx 0.85
    implementation_end;
