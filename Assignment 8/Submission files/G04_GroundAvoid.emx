   Control_gains 544 432
    description '<Description>
 <Version>4.0</Version>
   <LibraryPath>System\Submodel.emx</LibraryPath>
  <TimeStamp>2007-10-31 11:32:54</TimeStamp>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
</Description>';
    type Submodel
    end;
    implementation eq
parameters
	// arm parameters
	real global l1;
	real global l2;
	real global l3;
	real global L[3];
	real global r_int;
	real global r_ext;
	real global p;
	real global Maxon_m;
	real global Maxon_r;
	real global Maxon_l;
	real global m[3];
	
	real global k1; // stiffness of elastic elements
	
	real i = 34.7e-7 + 0.8e-7; // motor + gearbox inertia
	
	// inertias of links
	real I1x = pi*l1*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l1^2*(r_ext^2 - r_int^2));
	real I1y = pi*l1*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l1^2*(r_ext^2 - r_int^2));
	real I1z = (1/2)*pi*l1*p*(r_ext^4 - r_int^4);
	
	real I2x = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
	real I2y = (1/2)*pi*l2*p*(r_ext^4 - r_int^4);
	real I2z = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
	
	real I3x = pi*l3*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l3^2*(r_ext^2 - r_int^2));
	real I3y = (1/2)*pi*l3*p*(r_ext^4 - r_int^4);
	real I3z = pi*l3*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l3^2*(r_ext^2 - r_int^2));
	
	// inertias of motors
 	real Maxon_Ix = (1/2)*Maxon_m*Maxon_r^2;
	real Maxon_Iy = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
	real Maxon_Iz = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
	
	// load inertias for each motor in the stretched out configuration
	real m1I_stretched = (I1z) + (I2z + m[2]*(l2/2)^2) + (I3z + m[3]*(l2+l3/2)^2) + (Maxon_Iz + Maxon_m*(0.04)^2) + (Maxon_Iz + Maxon_m*(l2^2+0.04^2));
	real m2I_stretched = (I2x + m[2]*(l2/2)^2) + (I3x + m[3]*(l2+l3/2)^2) + (Maxon_Ix + Maxon_m*l2^2);
	real m3I_stretched = I3x + m[3]*(l3/2)^2;
	
	real eff_inertia = m1I_stretched/(l2+l3)^2;  // effective inertia at the end effector in z in the stretched out configuration
	
	// imp control parameters
	real omega_n_i = 4;
	real xi_i = 2;
	real global K_i = omega_n_i^2 * eff_inertia;
	real global b_i = 2*eff_inertia*omega_n_i*xi_i;

	// toque control parameters
	real alpha_t = 3.5;
	real xi_t = 1;
	real global Kt_p = alpha_t^2 - 1;
	real omega_0_t = sqrt(k1*(Kt_p+1)/i);
	real global Kt_d = 2*i*omega_0_t*xi_t / k1;
	real omega_n_t = sqrt(k1/i); // locked-output natural resonance frequency
	

implementation_end;
