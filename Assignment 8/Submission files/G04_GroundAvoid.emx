          text 'd' 418.2 424.7 color 16711680 14;
          text 'dt' 418.2 437.8 color 16711680 14;
          line 412.2 431.3 423 431.3 color 16711680;
         end;
       end;
       implementation eq
parameters
	real initial[3] = [0; 0; 0];  	// initial output value
variables
	real hidden initial_input[3];
	boolean hidden initialized;
initialequations
	initialized = false;
equations
	if not initialized then 
		initial_input = initial - input/sampletime; 
		initialized = true;
	else
		initial_input = [0; 0; 0];
	end;
	output = (input - previous (input,initial))/sampletime + initial_input;
implementation_end;
      Imp_contr 504 360
       description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type Submodel
        ports
         signal in q [3,1];
         signal in pos_des [3,1] {m} ;
         signal in dq [3,1] {rad} ;
         signal out u [3,1] {N.m} ;
         signal in vel_des [3,1];
       end;
       implementation eq
parameters
	real global grav = 9.81;

	// arm parameters
	real global l1;
	real global l2;
	real global l3;
	real global L[3] = [l1;l2;l3];
	real global r_int;
	real global r_ext;
	real global p;
	real global Maxon_m; // mass of motor-gearbox assembly
	
	// links masses
	real global m[3] = [pi*(r_ext^2-r_int^2)*l1*p;pi*(r_ext^2-r_int^2)*l2*p;pi*(r_ext^2-r_int^2)*l3*p];
	
	// impedance parameters
	real global K_i;
	real global b_i;
	real K_imp[3,3] = [K_i,0,0; 0,K_i,0; 0,0,K_i];
	real b_imp[3,3] = [b_i,0,0; 0,b_i,0; 0,0,b_i];
	
variables
	real J[3,3];   // Jacobian
	real g[3];     // gravity
	real pos[3];   // EE positioin
	real vel[3];   // EE velocity
	real F_imp[3]; // Desired force at the EE
	
equations
	pos = [
				-(L[2]*cos(q[2]) +  L[3]*cos(q[2]+q[3]))*sin(q[1]);	
				(L[2]*cos(q[2]) +  L[3]*cos(q[2]+q[3]))*cos(q[1]);	
				L[1] + L[2]*sin(q[2]) +  L[3]*sin(q[2]+q[3])
			];
	
	J = [
	    -(L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]))*cos(q[1]),
	    (L[2]*sin(q[2]) + L[3]*sin(q[2]+q[3]))*sin(q[1]),
	    L[3]*sin(q[2]+q[3])*sin(q[1]);
	
	    -(L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]))*sin(q[1]),
	    (-L[2]*sin(q[2]) - L[3]*sin(q[2]+q[3]))*cos(q[1]),
	    -L[3]*sin(q[2]+q[3])*cos(q[1]);
	
	    0,
	    L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]),
	    L[3]*cos(q[2]+q[3])
	];
	
	g = 	[	    			
				0;    			
				m[2]*grav*L[2]/2*cos(q[2]) + m[3]*grav*(L[2]*cos(q[2]) + L[3]/2*cos(q[2] + q[3])) + Maxon_m*grav*L[2]*cos(q[2]);    // Last term is gravity acting on motor		
				m[3]*grav*L[3]/2*cos(q[2] + q[3])
			];
			
	vel = J * dq;
	F_imp = K_imp*(pos_des - pos) + b_imp*(vel_des - vel);
		
	//u = transpose(J)*F_imp + g;  // motors control torque
	u = g;
	// u = [1;1];

	
	implementation_end;
      plug joint_pos 856 216;
      plug torques 688 360;
      plug pos_des 208 360;
      PlusMinus4 592 360
