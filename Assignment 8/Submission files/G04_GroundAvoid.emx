initialequations
	RotHinge\mass = pi*(r_ext^2-r_int^2)*l1*p;
	RotHinge\Ixx = pi*l1*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l1^2*(r_ext^2 - r_int^2));
	RotHinge\Iyy = pi*l1*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l1^2*(r_ext^2 - r_int^2));
	RotHinge\Izz = (1/2)*pi*l1*p*(r_ext^4 - r_int^4);
	Arm1\mass = pi*(r_ext^2-r_int^2)*l2*p;
	Arm1\Ixx = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
	Arm1\Iyy = (1/2)*pi*l2*p*(r_ext^4 - r_int^4);
	Arm1\Izz = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
