       end;
       implementation eq
parameters
	real global l1;
	real amplitude = l1/2;			// amplitude of the wave
	real omega = 2 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * cos ( omega * time);
implementation_end;
     end;
     connections
      Constant1\output -> PlusMinus2\plus;
      Constant2\output -> PlusMinus1\plus;
      Constant3\output -> PlusMinus3\plus;
      Mux\output -> pos_des;
      PlusMinus1\output -> Mux\input3;
      PlusMinus2\output -> Mux\input2;
      PlusMinus3\output -> Mux\input1;
      WaveGenerator1\output -> PlusMinus1\plus;
      WaveGenerator2\output -> PlusMinus2\plus;
      WaveGenerator3\output -> PlusMinus3\plus;
     end;
    implementation_end;
