         TF 448 264
          description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\TF.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:43:47</TimeStamp>
</Description>
</Information>';
          type TF
           ports
            power in p1;
            power out p2;
            signal in Pin;
           restrictions
            causality constraint not_equal p1 p2;
          end;
          icon bg ellipse bottom
           figures
            text 'TF' 448 264 color 0 18 bold;
          end;
          implementation eq
parameters
	real r = 1/33;
variables
	real eff;
	real efftest;
initialequations
	eff = 1.0;
	efftest = 1.0;
equations
	p1.e = r * p2.e;
	p2.f = r * p1.f;
	// efficiency check
	if Pin <> 0 then
		eff = if Pin >= 0 then
			max(min((p2.e*p2.f)/(Pin),1.0),0.0)
		else
			max(min(Pin/(p1.e*p1.f),1.0),0.0)
		end;
	else 
		eff = 1.0;
	end;
	efftest = int(eff)/(time+1e-5);implementation_end;
        end;
        connections
         ADcurr\output -> PlusMinus1\minus;
         DA\output -> MSe\effort;
         GY\p2 => OneJunction1\p;
         Hold1\output -> Sample2\input;
         Ides -> Hold1\input 40 32;
         MSe\p => OneJunction\p;
         OneJunction\flow -> ADcurr\input;
         OneJunction\p => GY\p1;
         OneJunction\p => HBridge\p;
         OneJunction\p => Inductance\p;
         OneJunction\p => R\p;
         OneJunction1\p => MotorLoadInertia\p;
         OneJunction3\p <= PowerSensorIn\p2;
         OneJunction3\p => GearFric\p;
         OneJunction3\p => TF\p1;
         PI3\output -> DA\input;
         PlusMinus1\output -> PI3\error;
         PowerSensorIn\P -> TF\Pin 344 224 448 224;
         PowerSensorIn\p1 <= OneJunction1\p;
         PowerSensorIn1\p2 => p2;
         Sample2\output -> PlusMinus1\plus;
         TF\p2 => PowerSensorIn1\p1;
        end;
       implementation_end;
      plug p 518.9 240;
      plug input -199 240;
      PID 56 240
       description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Control\PID Control\Discrete\PID.emx</LibraryPath>
  <TimeStamp>2007-9-27 14:49:14</TimeStamp>
</Description>';
       type PID
        ports
         signal in error;
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle 40 224 72 256 color 0 fill 15132390;
         text 'PID' 56 239.5 color 1336868 18 bold;
       end;
       implementation eq
parameters
	real global Kt_p;
	real global Kt_d;
	real kp = Kt_p {};			// Proportional gain
	real tauD = Kt_d / Kt_p {s};		// Derivative time constant: tauD > 0
	real beta = 0.4 {};		// Tameness constant: 0 < beta << 1
	real tauI = 0.05 {s};		// Integral time constant: tauI > 0
variables
	real hidden factor,uD,uI;
equations
	factor = 1 / ( sampletime + tauD * beta );
	uD = factor * ( tauD * previous ( uD ) * beta + tauD * kp * ( error - previous ( error )) + sampletime * kp * error );
	uI = previous( uI ) +  sampletime * uD / tauI;
	output = uI + uD;implementation_end;
