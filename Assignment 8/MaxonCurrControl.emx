<?xml version="1.0" encoding="UTF-8"?>
<Document>
 <Model version="5.1" build="5.1.6.14106">
  <Sidops>
<![CDATA[MaxonMotor 256 240 description '<Information>
  <Description>
    <Version>5.1</Version>
    <IsMainModel>1</IsMainModel>
    <KeepParameterValues>False</KeepParameterValues>
    <AllowLibraryUpdate>True</AllowLibraryUpdate>
    <LibraryPath>C:\Users\solis\Documents\M-ROB\Q2B\MS\Proj\MaxonCurrControl.emx</LibraryPath>
    <TimeStamp>2026-6-10 12:21:53</TimeStamp>
  </Description>
</Information>'; type Submodel  ports   signal in Ides;   power out p2; end; implementation bg  submodels   ADcurr 104 200    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Discrete\AD.emx</LibraryPath><TimeStamp>2017-09-08 16:16:00</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';    type AD     ports      signal in input;      signal out output;    end;    icon bg bottom     figures      rectangle 88 184 120 216 color 0 fill 15132390;      spline 94.4 209.3 112 191.7 color 16711680;      text 'A' 97.1 194.1 color 16711680 14;      text 'D' 110.4 205.3 color 16711680 14;    end;    implementation eqparameters	real bits = 12;         // Quantization levels (bits)	real minimum = -20;     // Minimum output value	real maximum = 20;      // Maximum output value	real initial = 0;       // Initial outputvariables	real hold_signal, windowed_signal, quantisized_signal;	real lsb, half_lsb;equations	lsb = (maximum - minimum) / (exp2 (bits) - 1);	half_lsb = lsb / 2;	hold_signal = sample (input,initial);	windowed_signal = if hold_signal <= minimum then		 minimum + half_lsb	else		if hold_signal >= maximum then 			maximum -half_lsb		else 			hold_signal		end	end;	quantisized_signal = if windowed_signal < 0.0 then		windowed_signal - half_lsb	else		 windowed_signal + half_lsb	end;	output =  quantisized_signal - (quantisized_signal mod lsb);    implementation_end;   DA -8 200    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>  <LibraryPath>Signal\Discrete\DA.emx</LibraryPath>  <TimeStamp>2017-09-08 16:16:00</TimeStamp></Description>';    type DA     ports      signal in input;      signal out output;    end;    icon bg bottom     figures      rectangle -24 184 8 216 color 0 fill 15132390;      spline -17.6 209.3 0 191.7 color 16711680;      text 'A' -1.8 205.5 color 16711680 14;      text 'D' -14.8 194.8 color 16711680 14;      text '_max' 24 200 color 0 16;    end;    implementation eqparameters	real bits = 12;         // Quantization levels (bits)	real minimum = -48;     // Minimum output value	real maximum = 48;      // Maximum output valuevariables	real windowed_signal, quantisized_signal, rounded_signal;	real lsb, half_lsb;equations	lsb = (maximum - minimum) / (exp2 (bits) -1);	half_lsb = lsb / 2;	windowed_signal = if input <= minimum then		minimum+ half_lsb	else		if input >= maximum then 			maximum - half_lsb		else 			input		end	end;	quantisized_signal = if windowed_signal < 0.0 then		windowed_signal - half_lsb	else		 windowed_signal + half_lsb	end;	rounded_signal =  quantisized_signal - (quantisized_signal mod lsb);	output = hold (rounded_signal);      implementation_end;   GearFric 400 320    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';    type R     ports      power in p;    end;    icon bg ellipse bottom     figures      text 'R' 400 320 color 0 18 bold;    end;    implementation eqparameters    real tau_c = 9.4e-5;     // Coulomb friction torque [Nm] (old 1.0e-4)    real b = 6.8e-5;        // viscous friction coefficient (old 3.22e-4)    real k = 50.0;          // smoothing factorvariables	real P;equations    p.e =        tau_c * tanh(k * p.f)        + b * p.f;	P = p.e * p.f;	implementation_end;   GY 200 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\GY.emx</LibraryPath>  <TimeStamp>2011-11-29 15:53:45</TimeStamp></Description></Information>';    type GY     ports      electric in p1;      power out p2;     restrictions      causality constraint equal p1 p2;    end;    icon bg ellipse bottom     figures      text 'GY_eff' 200 264 color 0 18 bold;    end;    implementation eqparameters	real r = 53.8e-3;	real eff = 0.88; variables	real dyn_eff;initialequations	dyn_eff = eff;equations	p1.e * dyn_eff = r * p2.f;	p2.e = r * p1.f; //ideal based on torque constant	dyn_eff = if (sign(p1.e)*sign(p1.f)) >= 0 then eff else 1/eff end;implementation_end;   HBridge 32 328    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';    type R     ports      power in p;    end;    icon bg ellipse bottom     figures      text 'R' 32 328 color 0 18 bold;    end;    implementation eqparameters	real r = 0.3;variables	real P;equations	p.e = r * p.f;	P = p.e * p.f;implementation_end;   Inductance 168 328    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';    type I     ports      power in p;      signal out state;     restrictions      causality preferred in p;    end;    icon bg ellipse right     figures      text 'I' 168 328 color 0 18 bold;    end;    implementation eqparameters	real i = 0.513;equations    //state = state + p.e*sampletime;	 state = int(p.e);    p.f = state / i;implementation_end;   MotorLoadInertia 288 200    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';    type I     ports      power in p;      signal out state;     restrictions      causality preferred in p;    end;    icon bg ellipse right     figures      text 'I_max' 288 200 color 0 18 bold;    end;    implementation eqparameters	real i = 34.7e-7 + 0.8e-7; //motor, gearbox	real lim = 120000/60*2*pi; 	// max rpmequations    //state = state + p.e*sampletime;	 state = int(p.e);    p.f = if abs(state / i) >= lim then sign(state/i)*lim else state/i end; //max rpmimplementation_end;   MSe -8 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\MSe.emx</LibraryPath>  <TimeStamp>2011-11-29 16:12:33</TimeStamp></Description></Information>';    type MSe     ports      power out p;      signal in effort;     restrictions      causality fixed out p;    end;    icon bg ellipse bottom     figures      text 'MSe' -8 264 color 0 18 bold;    end;    implementation eqvariables	real flow;	real P;equations	p.e = effort;	flow = p.f;	P = p.e * p.f;implementation_end;   plug p2 566.1 264;   plug Ides 232 40;   OneJunction 104 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\OneJunction.emx</LibraryPath>  <TimeStamp>2011-11-29 16:17:51</TimeStamp></Description></Information>';    knot OneJunction     ports      electric knot duplicatable none p [1];      signal knot out flow [1];     restrictions      causality constraint one_out p;    end;    icon bg ellipse     figures      text '1' 104 264 color 0 18 bold;    end;    implementation eqequations	sum (direct (p.e)) = 0;	equal (collect (p.f));	flow = first (p.f);implementation_end;   OneJunction1 288 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\OneJunction.emx</LibraryPath>  <TimeStamp>2011-11-29 16:17:51</TimeStamp></Description></Information>';    knot OneJunction     ports      rotation knot duplicatable none p [1];      signal knot out flow [1];     restrictions      causality constraint one_out p;    end;    icon bg ellipse     figures      text '1' 288 264 color 0 18 bold;    end;    implementation eqequations	sum (direct (p.e)) = 0;	equal (collect (p.f));	flow = first (p.f);implementation_end;   OneJunction3 400 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\OneJunction.emx</LibraryPath>  <TimeStamp>2011-11-29 16:17:51</TimeStamp></Description></Information>';    knot OneJunction     ports      rotation knot duplicatable none p [1];      signal knot out flow [1];     restrictions      causality constraint one_out p;    end;    icon bg ellipse     figures      text '1' 400 264 color 0 18 bold;    end;    implementation eqequations	sum (direct (p.e)) = 0;	equal (collect (p.f));	flow = first (p.f);implementation_end;   PI3 -8 136    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>   <LibraryPath>Signal\Control\PID Control\Discrete\PI.emx</LibraryPath>  <TimeStamp>2007-9-27 14:49:39</TimeStamp></Description>';    type PI     ports      signal out output;      signal in error;    end;    icon bg bottom     figures      rectangle -24 120 8 152 color 0 fill 15132390;      text 'PI' -8 136 color 1336868 18 bold;    end;    implementation eqparameters	//real kp = 1.0 {};			// Proportional gain	//real tauI = 1.0 {s};		// Integral time constant: tauI > 0	real kp = 50.0 {};			// Proportional gain	real tauI = 0.1 {s};		// Integral time constant: tauI > 0variables	real bi;	real uP;	real uI;equations	bi = kp*sampletime / tauI;	uP = kp * error;	uI = previous(uI) + bi*error;	output = uP+uI;              implementation_end;   PlusMinus1 104 136    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>   <LibraryPath>Signal\Block Diagram\PlusMinus.emx</LibraryPath>  <TimeStamp>2007-9-27 10:15:13</TimeStamp></Description>';    knot PlusMinus     ports      signal knot duplicatable in plus [1];      signal knot duplicatable in minus [1];      signal knot out output [1];    end;    icon bg ellipse     figures      ellipse 96 128 112 144 color 0 fill 16777215;    end;    implementation eqequations    output = sum (collect (plus)) - sum (collect (minus));    implementation_end;   PowerSensorIn 344 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\PowerSensor.emx</LibraryPath>  <TimeStamp>2011-11-29 16:29:42</TimeStamp></Description></Information>';    knot PowerSensor     ports      rotation knot in p1 [1];      rotation knot out p2 [1];      signal knot out P [1] {W} ;     restrictions      causality constraint not_equal p1 p2;    end;    icon bg ellipse     figures      ellipse 337.1 256.8 350.9 271.2 color 0 fill 16777215;      text 'P' 344.5 263.8 color 0;    end;    implementation eqequations	p2.e = p1.e;	p1.f = p2.f;	P = p1.e .* p1.f;implementation_end;   PowerSensorIn1 512 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\PowerSensor.emx</LibraryPath>  <TimeStamp>2011-11-29 16:29:42</TimeStamp></Description></Information>';    knot PowerSensor     ports      rotation knot in p1 [1];      rotation knot out p2 [1];      signal knot out P [1] {W} ;     restrictions      causality constraint not_equal p1 p2;    end;    icon bg ellipse     figures      ellipse 505.1 256.8 518.9 271.2 color 0 fill 16777215;      text 'P' 512.5 263.8 color 0;    end;    implementation eqequations	p2.e = p1.e;	p1.f = p2.f;	P = p1.e .* p1.f;implementation_end;   R 104 328    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\R.emx</LibraryPath>  <TimeStamp>2011-11-29 16:35:37</TimeStamp></Description></Information>';    type R     ports      power in p;    end;    icon bg ellipse bottom     figures      text 'R' 104 328 color 0 18 bold;    end;    implementation eqparameters	real r = 2.48;variables	real P;equations	p.e = r * p.f;	P = p.e * p.f;implementation_end;   TF 448 264    description '<Information> <Description>    <Version>4.2</Version><IsMainModel>1</IsMainModel>  <KeepParameterValues>False</KeepParameterValues>    <LibraryPath>Bond Graph\TF.emx</LibraryPath>  <TimeStamp>2011-11-29 16:43:47</TimeStamp></Description></Information>';    type TF     ports      power in p1;      power out p2;      signal in Pin;     restrictions      causality constraint not_equal p1 p2;    end;    icon bg ellipse bottom     figures      text 'TF' 448 264 color 0 18 bold;    end;    implementation eqparameters	real r = 1/33;variables	real eff;	real efftest;initialequations	eff = 1.0;	efftest = 1.0;equations	p1.e = r * p2.e;	p2.f = r * p1.f;	// efficiency check	if Pin <> 0 then		eff = if Pin >= 0 then			max(min((p2.e*p2.f)/(Pin),1.0),0.0)		else			max(min(Pin/(p1.e*p1.f),1.0),0.0)		end;	else 		eff = 1.0;	end;	efftest = int(eff)/(time+1e-5);implementation_end;  end;  connections   ADcurr\output -> PlusMinus1\minus;   DA\output -> MSe\effort;   GY\p2 => OneJunction1\p;   Ides -> PlusMinus1\plus;   MSe\p => OneJunction\p;   OneJunction\flow -> ADcurr\input;   OneJunction\p => GY\p1;   OneJunction\p => HBridge\p;   OneJunction\p => Inductance\p;   OneJunction\p => R\p;   OneJunction1\p => MotorLoadInertia\p;   OneJunction3\p <= PowerSensorIn\p2;   OneJunction3\p => GearFric\p;   OneJunction3\p => TF\p1;   PI3\output -> DA\input;   PlusMinus1\output -> PI3\error;   PowerSensorIn\P -> TF\Pin 344 224 448 224;   PowerSensorIn\p1 <= OneJunction1\p;   PowerSensorIn1\p2 => p2;   TF\p2 => PowerSensorIn1\p1;  end; implementation_end;]]>  </Sidops>
 </Model>
</Document>
