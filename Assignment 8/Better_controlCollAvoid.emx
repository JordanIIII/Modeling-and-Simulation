         MotorLoadInertia 288 200
          description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type I
           ports
            power in p;
            signal out state;
           restrictions
            causality preferred in p;
          end;
          icon bg ellipse right
           figures
            text 'I_max' 288 200 color 0 18 bold;
          end;
          implementation eq
parameters
	real i = 34.7e-7 + 0.8e-7; //motor, gearbox
	real lim = 120000/60*2*pi; 	// max rpm
equations
    //state = state + p.e*sampletime;
	 state = int(p.e);
    p.f = if abs(state / i) >= lim then sign(state/i)*lim else state/i end; //max rpm
implementation_end;
