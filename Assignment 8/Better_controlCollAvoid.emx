      group
       rectangle 32 216 64 248 color 0 fill 15132390;
       line 36.5 222.4 36.5 241.6 color 0;
       line 62.1 232 33.3 232 color 0;
       spline 36.9 231.9 40.1 223.8 43.3 231.9 46.6 240 49.7 231.9 52.8 223.8 56.1 231.9 59.6 240.2 62.8 232.2 color 16711680;
      end;
    end;
    implementation eq
parameters
	real global l1;
	real amplitude = l1/2;			// amplitude of the wave
	real omega = 1 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * cos ( omega * time);
implementation_end;
  end;
  connections
   Coll_avoid\tauAvoid -> PlusMinus4\plus;
   Constant1\output -> PlusMinus2\plus;
   Constant2\output -> PlusMinus1\plus;
   Constant3\output -> PlusMinus3\plus;
   Constant4\output -> Mux1\input1;
   Constant5\output -> Mux1\input3;
   Demux\output1 -> MaxonT_control_X\input;
   Demux\output2 -> MaxonT_control_Y\input;
   Demux\output3 -> MaxonT_control_Z\input;
   DiscreteDifferential\output -> Imp_contr\dq 480 128;
   DiscreteDifferential1\output -> Imp_contr\vel_des 488 432;
   Final_arm\Arm1_Arm2_phi -> Position\input3;
   Final_arm\Base_Rot_phi -> Position\input1;
   Final_arm\Rot_Arm1_phi -> Position\input2;
   Imp_contr\u -> PlusMinus4\plus;
   MaxonT_control_X\p => Final_arm\Base_Rot;
   MaxonT_control_Y\p => Final_arm\Rot_Arm1;
   MaxonT_control_Z\p => Final_arm\Arm1_Arm2;
   MSe\p => Final_arm\Force1;
   Mux\output -> Sample_ref\input;
   Mux1\output -> MSe\effort;
   PlusMinus1\output -> Mux\input3;
   PlusMinus2\output -> Mux\input2;
   PlusMinus3\output -> Mux\input1;
   PlusMinus4\output -> Demux\input;
   Position\output -> Sample_pos\input 1056 208;
   Pulse\output -> Mux1\input2;
   Sample_pos\output -> Splitter2\input;
   Sample_ref\output -> Splitter\input;
   Splitter\output -> DiscreteDifferential1\input 264 432;
   Splitter\output -> Imp_contr\pos_des;
   Splitter2\output -> DiscreteDifferential\input 768 128;
   Splitter2\output -> Splitter3\input;
   Splitter3\output -> Coll_avoid\q;
   Splitter3\output -> Imp_contr\q 520 208;
   WaveGenerator1\output -> PlusMinus1\plus;
   WaveGenerator2\output -> PlusMinus2\plus;
   WaveGenerator3\output -> PlusMinus3\plus;
  end;
 implementation_end;
]]></Sidops>
