          icon bg bottom
           figures
            rectangle 96 48 128 80 color 0 fill 15132390;
            line 98.3 54.8 101.2 54.8 101.2 50.9 105.3 50.9 105.3 54.8 109.2 54.8 109.2 50.9 111.1 50.9 color 16711680 fill 15132390;
