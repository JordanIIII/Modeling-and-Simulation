	M2\Iyy = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
	M2\Izz = (1/2)*Maxon_m*Maxon_r^2;
	M1\mass = Maxon_m;
	M1\Ixx = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
	M1\Iyy = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
