	Arm1\Ixx = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
	Arm1\Iyy = (1/2)*pi*l2*p*(r_ext^4 - r_int^4);
	Arm1\Izz = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
