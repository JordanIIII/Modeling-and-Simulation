    implementation eq
parameters
	real initial[3] = [0; 0; 0];  	// initial output value
variables
	real hidden initial_input[3];
	boolean hidden initialized;
initialequations
	initialized = false;
equations
	if not initialized then 
		initial_input = initial - input/sampletime; 
		initialized = true;
	else
		initial_input = [0;0;0];
	end;
	output = (input - previous (input,initial))/sampletime + initial_input;
implementation_end;
