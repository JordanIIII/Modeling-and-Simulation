   Submodel5 648 520
    description '<Description>
 <Version>4.0</Version>
   <LibraryPath>System\Submodel.emx</LibraryPath>
  <TimeStamp>2007-10-31 11:32:54</TimeStamp>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
</Description>';
    type Submodel
    end;
    implementation eq
parameters
	real global l1;
	real global l2;
	real global l3;
	real global L[3];
	real global r_int;
	real global r_ext;
	real global p;
	real global Maxon_m;
	real global Maxon_r;
	real global Maxon_l;
	real global m[3];
	
	real global k1;
	
	real i = 34.7e-7 + 0.8e-7; //motor + gearbox inertia
	
	// inertias of arms
	real I1x = pi*l1*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l1^2*(r_ext^2 - r_int^2));
	real I1y = pi*l1*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l1^2*(r_ext^2 - r_int^2));
	real I1z = (1/2)*pi*l1*p*(r_ext^4 - r_int^4);
	
	real I2x = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
	real I2y = (1/2)*pi*l2*p*(r_ext^4 - r_int^4);
	real I2z = pi*l2*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l2^2*(r_ext^2 - r_int^2));
	
	real I3x = pi*l3*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l3^2*(r_ext^2 - r_int^2));
	real I3y = (1/2)*pi*l3*p*(r_ext^4 - r_int^4);
	real I3z = pi*l3*p*((1/4)*(r_ext^4 - r_int^4) + (1/12)*l3^2*(r_ext^2 - r_int^2));
	
	// inertias of motors
 	real Maxon_Ix = (1/2)*Maxon_m*Maxon_r^2;
	real Maxon_Iy = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
	real Maxon_Iz = (1/4)*Maxon_m*Maxon_r^2 + (1/12)*Maxon_m*Maxon_l^2;
	
	// configuration in the middle of task trajectory
	real q1_task = 0;
	real q2_task = -0.505;
	real q3_task = 1.318; 
	
	// configuration of maximal inertia
	real q1_worst = 0;
	real q2_worst = 0;
	real q3_worst = 0; 

	// control parameters
	real alpha = 3.5;
	real ksi = 1;
	real global Kt_p = alpha^2 - 1;
	real omega_0 = sqrt(k1*(Kt_p+1)/i);
	real global Kt_d = 2*i*omega_0*ksi / k1;
	real omega_n = sqrt(k1/i); // locked-output natural resonance frequency
	
variables
	real m1I_task;
	real m2I_task;
	real m3I_task;
	
	real m1I_worst;
	real m2I_worst;
	real m3I_worst;
	

	
equations
	// load inertias for each motor in the stretched out configuration
	m1I_worst = (I1z) + (I2z + m[2]*(l2/2)^2) + (I3z + m[3]*(l2+l3/2)^2) + (Maxon_Iz + Maxon_m*(0.04)^2) + (Maxon_Iz + Maxon_m*(l2^2+0.04^2));
	m2I_worst = (I2x + m[2]*(l2/2)^2) + (I3x + m[3]*(l2+l3/2)^2) + (Maxon_Ix + Maxon_m*l2^2);
	m3I_worst = I3x + m[3]*(l3/2)^2;implementation_end;
   WaveGenerator1 32 472
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\WaveGenerator-Sine.emx</LibraryPath>
  <TimeStamp>2007-9-27 16:12:6</TimeStamp>
</Description>';
    type 'WaveGenerator-Sine'
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      group
       rectangle 16 456 48 488 color 0 fill 15132390;
       line 20.5 462.4 20.5 481.6 color 0;
       line 46.1 472 17.3 472 color 0;
       spline 20.9 471.9 24.1 463.8 27.3 471.9 30.6 480 33.7 471.9 36.8 463.8 40.1 471.9 43.6 480.2 46.8 472.2 color 16711680;
      end;
    end;
    implementation eq
parameters
	real global l1;
	real amplitude = l1/2;			// amplitude of the wave
	real omega = 2.0 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * sin ( omega * time);
implementation_end;
