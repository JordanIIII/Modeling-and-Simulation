	Base_Rot\Wrench = [0, 0, Base_Rot\torque, 0, 0, 0] * Adjoint (Base_Rot\ConnectionPoint2\AbsHinverse);
	AdjX2[1:3] = Base_Rot\ConnectionPoint1\AbsH[1:3, 3];
	AdjX2[4] = Base_Rot\ConnectionPoint1\AbsH[2, 4] * Base_Rot\ConnectionPoint1\AbsH[3, 3] - Base_Rot\ConnectionPoint1\AbsH[3, 4] * Base_Rot\ConnectionPoint1\AbsH[2, 3];
	AdjX2[5] = Base_Rot\ConnectionPoint1\AbsH[3, 4] * Base_Rot\ConnectionPoint1\AbsH[1, 3] - Base_Rot\ConnectionPoint1\AbsH[1, 4] * Base_Rot\ConnectionPoint1\AbsH[3, 3];
	AdjX2[6] = Base_Rot\ConnectionPoint1\AbsH[1, 4] * Base_Rot\ConnectionPoint1\AbsH[2, 3] - Base_Rot\ConnectionPoint1\AbsH[2, 4] * Base_Rot\ConnectionPoint1\AbsH[1, 3];
	AdjX2_T = transpose (AdjX2);
	adjAdjX2 = adjoint (AdjX2);
	AdjX3[1:3] = Rot_Arm1\ConnectionPoint1\AbsH[1:3, 1];
	AdjX3[4] = Rot_Arm1\ConnectionPoint1\AbsH[2, 4] * Rot_Arm1\ConnectionPoint1\AbsH[3, 1] - Rot_Arm1\ConnectionPoint1\AbsH[3, 4] * Rot_Arm1\ConnectionPoint1\AbsH[2, 1];
	AdjX3[5] = Rot_Arm1\ConnectionPoint1\AbsH[3, 4] * Rot_Arm1\ConnectionPoint1\AbsH[1, 1] - Rot_Arm1\ConnectionPoint1\AbsH[1, 4] * Rot_Arm1\ConnectionPoint1\AbsH[3, 1];
	AdjX3[6] = Rot_Arm1\ConnectionPoint1\AbsH[1, 4] * Rot_Arm1\ConnectionPoint1\AbsH[2, 1] - Rot_Arm1\ConnectionPoint1\AbsH[2, 4] * Rot_Arm1\ConnectionPoint1\AbsH[1, 1];
	AdjX3_T = transpose (AdjX3);
	adjAdjX3 = adjoint (AdjX3);
	AdjX4[1:3] = Arm1_Arm2\ConnectionPoint1\AbsH[1:3, 1];
	AdjX4[4] = Arm1_Arm2\ConnectionPoint1\AbsH[2, 4] * Arm1_Arm2\ConnectionPoint1\AbsH[3, 1] - Arm1_Arm2\ConnectionPoint1\AbsH[3, 4] * Arm1_Arm2\ConnectionPoint1\AbsH[2, 1];
	AdjX4[5] = Arm1_Arm2\ConnectionPoint1\AbsH[3, 4] * Arm1_Arm2\ConnectionPoint1\AbsH[1, 1] - Arm1_Arm2\ConnectionPoint1\AbsH[1, 4] * Arm1_Arm2\ConnectionPoint1\AbsH[3, 1];
	AdjX4[6] = Arm1_Arm2\ConnectionPoint1\AbsH[1, 4] * Arm1_Arm2\ConnectionPoint1\AbsH[2, 1] - Arm1_Arm2\ConnectionPoint1\AbsH[2, 4] * Arm1_Arm2\ConnectionPoint1\AbsH[1, 1];
	AdjX4_T = transpose (AdjX4);
	adjAdjX4 = adjoint (AdjX4);
	J2[1:6, 1] = AdjX2;
	J3[1:6, 1] = AdjX2;
	J3[1:6, 2] = AdjX3;
	J4[1:6, 1] = AdjX2;
	J4[1:6, 2] = AdjX3;
	J4[1:6, 3] = AdjX4;
	J5[1:6, 1] = AdjX2;
	J5[1:6, 2] = AdjX3;
	J5[1:6, 3] = AdjX4;
	J6[1:6, 1] = AdjX2;
	J6[1:6, 2] = AdjX3;
	J7[1:6, 1] = AdjX2;
	T1_00 = J1 * v;
	T1_00T = transpose (T1_00);
	T2_00 = J2 * v;
	T2_00T = transpose (T2_00);
	T3_00 = J3 * v;
	T3_00T = transpose (T3_00);
	T4_00 = J4 * v;
	T4_00T = transpose (T4_00);
	T5_00 = J5 * v;
	T5_00T = transpose (T5_00);
	T6_00 = J6 * v;
	T6_00T = transpose (T6_00);
	T7_00 = J7 * v;
	T7_00T = transpose (T7_00);
	AdjInv2 = Adjoint (inverseH (RotHinge\AbsH));
	M2 = (transpose (AdjInv2) .* RotHinge\InDiag) * AdjInv2;
	TM2 = T2_00T * M2;
	AdjInv3 = Adjoint (inverseH (Arm1\AbsH));
	M3 = (transpose (AdjInv3) .* Arm1\InDiag) * AdjInv3;
	TM3 = T3_00T * M3;
	AdjInv4 = Adjoint (inverseH (Arm2\AbsH));
	M4 = (transpose (AdjInv4) .* Arm2\InDiag) * AdjInv4;
	TM4 = T4_00T * M4;
	AdjInv5 = Adjoint (inverseH (EE\AbsH));
	M5 = (transpose (AdjInv5) .* EE\InDiag) * AdjInv5;
	TM5 = T5_00T * M5;
	AdjInv6 = Adjoint (inverseH (M2\AbsH));
	M6 = (transpose (AdjInv6) .* M2\InDiag) * AdjInv6;
	TM6 = T6_00T * M6;
	AdjInv7 = Adjoint (inverseH (M1\AbsH));
	M7 = (transpose (AdjInv7) .* M1\InDiag) * AdjInv7;
	TM7 = T7_00T * M7;
	M2_2 = AdjX2_T * ((M2 + M3 + M4 + M5 + M6 + M7) * AdjX2);
	M3_2 = AdjX3_T * ((M3 + M4 + M5 + M6) * AdjX2);
	M3_3 = AdjX3_T * ((M3 + M4 + M5 + M6) * AdjX3);
	M4_2 = AdjX4_T * ((M4 + M5) * AdjX2);
	M4_3 = AdjX4_T * ((M4 + M5) * AdjX3);
	M4_4 = AdjX4_T * ((M4 + M5) * AdjX4);
	MassMatrix[1, 1] = M2_2;
	MassMatrix[1, 2] = M3_2;
	MassMatrix[1, 3] = M4_2;
	MassMatrix[2, 1] = M3_2;
	MassMatrix[2, 2] = M3_3;
	MassMatrix[2, 3] = M4_3;
	MassMatrix[3, 1] = M4_2;
	MassMatrix[3, 2] = M4_3;
	MassMatrix[3, 3] = M4_4;
	wrenchGrav2 = RotHinge\mass * [gravity[3] * RotHinge\AbsH[2, 4] - gravity[2] * RotHinge\AbsH[3, 4], gravity[1] * RotHinge\AbsH[3, 4] - gravity[3] * RotHinge\AbsH[1, 4], gravity[2] * RotHinge\AbsH[1, 4] - gravity[1] * RotHinge\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav3 = Arm1\mass * [gravity[3] * Arm1\AbsH[2, 4] - gravity[2] * Arm1\AbsH[3, 4], gravity[1] * Arm1\AbsH[3, 4] - gravity[3] * Arm1\AbsH[1, 4], gravity[2] * Arm1\AbsH[1, 4] - gravity[1] * Arm1\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav4 = Arm2\mass * [gravity[3] * Arm2\AbsH[2, 4] - gravity[2] * Arm2\AbsH[3, 4], gravity[1] * Arm2\AbsH[3, 4] - gravity[3] * Arm2\AbsH[1, 4], gravity[2] * Arm2\AbsH[1, 4] - gravity[1] * Arm2\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav5 = EE\mass * [gravity[3] * EE\AbsH[2, 4] - gravity[2] * EE\AbsH[3, 4], gravity[1] * EE\AbsH[3, 4] - gravity[3] * EE\AbsH[1, 4], gravity[2] * EE\AbsH[1, 4] - gravity[1] * EE\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav6 = M2\mass * [gravity[3] * M2\AbsH[2, 4] - gravity[2] * M2\AbsH[3, 4], gravity[1] * M2\AbsH[3, 4] - gravity[3] * M2\AbsH[1, 4], gravity[2] * M2\AbsH[1, 4] - gravity[1] * M2\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav7 = M1\mass * [gravity[3] * M1\AbsH[2, 4] - gravity[2] * M1\AbsH[3, 4], gravity[1] * M1\AbsH[3, 4] - gravity[3] * M1\AbsH[1, 4], gravity[2] * M1\AbsH[1, 4] - gravity[1] * M1\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	Force1\ConnectionPoint1\AbsHinverse = inverseH (Force1\ConnectionPoint1\AbsH);
	Force1\ConnectionPoint1\invAdjointH = Adjoint (Force1\ConnectionPoint1\AbsHinverse);
	Force1_Effort[1:3] = 0;
	Force1_Effort[4:6] = Force1.e;
	Force1_Flow = Force1\ConnectionPoint1\invAdjointH * T5_00;
	Force1.f = Force1_Flow[4:6];
	PDotBodies[1] = -((TM2 + TM3 + TM4 + TM5 + TM6 + TM7) * (adjAdjX2 * T2_00));
	PDotBodies[2] = -((TM3 + TM4 + TM5 + TM6) * (adjAdjX3 * T3_00));
	PDotBodies[3] = -((TM4 + TM5) * (adjAdjX4 * T4_00));
	PDot = PDotBodies + transpose (wrenchGrav2 * J2 + wrenchGrav3 * J3 + wrenchGrav4 * J4 + wrenchGrav5 * J5 + wrenchGrav6 * J6 + wrenchGrav7 * J7 + transpose (Force1_Effort) * Force1\ConnectionPoint1\invAdjointH * J5 + Base_Rot\Wrench * (J2 - J1) + Rot_Arm1\Wrench * (J3 - J2) + Arm1_Arm2\Wrench * (J4 - J3));
	P = int (PDot) + PDotInitial;
	v = linsolve (MassMatrix, P, 'cholesky');
	Base_Rot\omega = v[1];
	Rot_Arm1\omega = v[2];
	Arm1_Arm2\omega = v[3];
	Base_Rot\torque = Base_Rot.e;
	Base_Rot.f = Base_Rot\omega;
	Rot_Arm1\torque = Rot_Arm1.e;
	Rot_Arm1.f = Rot_Arm1\omega;
	Arm1_Arm2\torque = Arm1_Arm2.e;
	Arm1_Arm2.f = Arm1_Arm2\omega;
implementation_end;
   Imp_contr 496 352
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in q [3,1];
      signal in pos_des [3,1] {m} ;
      signal in dq [3,1] {rad} ;
      signal out u [3,1] {N.m} ;
      signal in vel_des [3,1];
    end;
    implementation eq
parameters
	real global grav = g_n;		// m/s^2

	real global l1;
	real global l2;
	real global l3;
	real global L[3] = [l1;l2;l3];
	real global r_int;
	real global r_ext;
	real global p;
	real global Maxon_m;
	
	real global m[3] = [pi*(r_ext^2-r_int^2)*l1*p;pi*(r_ext^2-r_int^2)*l2*p;pi*(r_ext^2-r_int^2)*l3*p];
	real K_imp[3,3] = [36,0,0; 0,36,0; 0,0,36];
	real b_imp[3,3] = [8,0,0; 0,8,0; 0,0,8];
	
variables
	real J[3,3];  // Jacobian
	real g[3];
	real pos[3];
	real vel[3];
	real F_imp[3];
	
equations
	pos = [
				-(L[2]*cos(q[2]) +  L[3]*cos(q[2]+q[3]))*sin(q[1]);	
				(L[2]*cos(q[2]) +  L[3]*cos(q[2]+q[3]))*cos(q[1]);	
				L[1] + L[2]*sin(q[2]) +  L[3]*sin(q[2]+q[3])
			];
	
	J = [
	    -(L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]))*cos(q[1]),
	    (L[2]*sin(q[2]) + L[3]*sin(q[2]+q[3]))*sin(q[1]),
	    L[3]*sin(q[2]+q[3])*sin(q[1]);
	
	    -(L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]))*sin(q[1]),
	    (-L[2]*sin(q[2]) - L[3]*sin(q[2]+q[3]))*cos(q[1]),
	    -L[3]*sin(q[2]+q[3])*cos(q[1]);
	
	    0,
	    L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]),
	    L[3]*cos(q[2]+q[3])
	];
	
	g = 	[	    			
				0;    			
				m[2]*grav*L[2]/2*cos(q[2]) + m[3]*grav*(L[2]*cos(q[2]) + L[3]/2*cos(q[2] + q[3])) + Maxon_m*grav*L[2]*cos(q[2]);    			
				m[3]*grav*L[3]/2*cos(q[2] + q[3])
			];
			
	vel = J * dq;
	F_imp = K_imp*(pos_des - pos) + b_imp*(vel_des - vel);
		
	//u = transpose(J)*F_imp + g;
	u = g;
	// u = [1;1];

	
	implementation_end;
