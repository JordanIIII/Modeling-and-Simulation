      PD 56 240
       description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Control\PID Control\Discrete\PD.emx</LibraryPath>
  <TimeStamp>2007-9-27 14:50:12</TimeStamp>
</Description>';
       type PD
        ports
         signal in error;
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle 40 224 72 256 color 0 fill 15132390;
         text 'PD' 56 239.5 color 1336868 18 bold;
       end;
       implementation eq
parameters
	real kp = 0.0 {};			// Proportional gain
	real tauD = 0.01 {s};		// Derivative time constant: tauD > 0
	real beta = 0.1 {};		// Tameness constant: 0 < beta << 1
variables
	real hidden factor,uD;
equations
	factor = 1 / ( sampletime + tauD * beta );
	uD = factor * ( tauD * previous ( uD ) * beta + tauD * kp * ( error - previous ( error )) + sampletime * kp * error );
	output = uD;implementation_end;
