       end;
       implementation eq
parameters
	real global k1 = 2.0; // k = Nm/(rad) 
equations
	state = int(p.f);
	p.e = state * k1;
implementation_end;
      dQspring 376 183.9
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\QSensor.emx</LibraryPath><TimeStamp>2011-11-29 16:34:15</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       knot QSensor
        ports
         rotation knot in p1 [1];
         rotation knot out p2 [1];
         signal knot out q [1];
        restrictions
         causality constraint not_equal p1 p2;
       end;
