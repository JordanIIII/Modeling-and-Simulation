	Arm1\InDiag[4, 1:6] = [Arm1\Ixx, Arm1\Iyy, Arm1\Izz, Arm1\mass, Arm1\mass, Arm1\mass];
	Arm1\InDiag[5, 1:6] = [Arm1\Ixx, Arm1\Iyy, Arm1\Izz, Arm1\mass, Arm1\mass, Arm1\mass];
	Arm1\InDiag[6, 1:6] = [Arm1\Ixx, Arm1\Iyy, Arm1\Izz, Arm1\mass, Arm1\mass, Arm1\mass];
	Arm1_Arm2\ConnectionPoint1\RelH = homogeneous ([1.0, 0.0, 0.0;
