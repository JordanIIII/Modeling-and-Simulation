	Arm2\AbsH = multiplyH (Arm1_Arm2\ConnectionPoint2\AbsH, Arm2\RelH);
	Arm2\InDiag[1, 1:6] = [Arm2\Ixx, Arm2\Iyy, Arm2\Izz, Arm2\mass, Arm2\mass, Arm2\mass];
	Arm2\InDiag[2, 1:6] = [Arm2\Ixx, Arm2\Iyy, Arm2\Izz, Arm2\mass, Arm2\mass, Arm2\mass];
