    description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\Delay-Time.emx</LibraryPath>
  <TimeStamp>2007-12-6 15:29:52</TimeStamp>
</Description>';
    type 'Delay-Time'
     ports
      signal in input;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 176 152 208 184 color 0 fill 15132390;
      line 180.5 158.4 180.5 177.6 color 0;
      line 206.1 168 177.3 168 color 0;
      spline 180.8 161.8 185.8 161.3 188.8 166.4 191.7 172.3 195.9 174.6 color 16711680;
      spline 191.5 161.3 196.3 161.3 198.9 165.3 201.6 170.7 206.4 174.1 color 16711680;
      group
       line 196.8 163.9 196.8 165.3 color 16711680;
       group
        line 196.8 165.3 196.8 163.9 color 16711680;
        line 189.5 164.7 196.8 164.7 color 16711680;
       end;
      end;
    end;
    implementation eq
parameters
	real delay = 0.1 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
