   DiscreteDifferential 128 376
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Discrete\DiscreteDifferential.emx</LibraryPath>
  <TimeStamp>2007-9-27 15:21:20</TimeStamp>
</Description>';
    type DiscreteDifferential
     ports
      signal in input;
      signal out output;
    end;
    icon bg
     figures
      rectangle 112 359.7 144 392.3 color 0 fill 15132390;
      text '-1' 137.3 382 color 16711680 10;
      text 'z' 130.7 385.8 color 16711680 13;
      group
       text 'd' 122.2 368.7 color 16711680 14;
       text 'dt' 122.2 381.8 color 16711680 14;
       line 116.2 375.3 127 375.3 color 16711680;
      end;
    end;
    implementation eq
parameters
	real initial = 0.0;  	// initial output value
variables
	real hidden initial_input;
	boolean hidden initialized;
initialequations
	initialized = false;
equations
	if not initialized then 
		initial_input = initial - input/sampletime; 
		initialized = true;
	else
		initial_input = 0;
	end;
	output = (input - previous (input,0))/sampletime + initial_input;
implementation_end;
   EnergySampling 120 240
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      signal in position {m} ;
      signal in force {N} ;
      signal out energy;
    end;
    implementation eq
parameters
	real q0 	= 0.0;
	real f0 	= 0.0;

variables
	real qprev;		// previous sampled position x_k-1
	real fprev; 	// previous sampled force f_k-1
	
	real dq; 		// position increment
	real dE; 		// injected energy over one interval
	real E; 			// total injected energy
	real Pk;			// average power
	
equations
	qprev = previous(position, q0);
	fprev = previous(force, f0);
	
	// passive energy sampling
	dq = position - qprev;
	dE = fprev * dq;
	
	// total energy
	E = previous(E, 0.0) + dE;
	Pk = dE/sampletime;
	
	energy = E;implementation_end;
