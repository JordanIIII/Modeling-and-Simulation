   Imp_contr 312 344
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in q [3,1];
      signal in pos_des [3,1] {m} ;
      signal in dq [3,1] {rad} ;
      signal out u [3,1] {N.m} ;
    end;
    implementation eq
parameters
	real global grav = 9.8;		// m/s^2
	real global L[3] = [2; 4; 2];
	real global m[3] = [1; 1; 1];
	real K_imp[3,3] = [10,0,0; 0,10,0; 0,0,10];
	real b_imp[3,3] = [1,0,0; 0,1,0; 0,0,1];
	
variables
	real J[3,3];  // Jacobian
	real g[3];
	real pos[3];
	real vel[3];
	real F_imp[3];
	
equations
	pos = [
				-(L[2]*cos(q[2]) +  L[3]*cos(q[2]+q[3]))*sin(q[1]);	
				(L[2]*cos(q[2]) +  L[3]*cos(q[2]+q[3]))*cos(q[1]);	
				L[1] + L[2]*sin(q[2]) +  L[3]*sin(q[2]+q[3])
			];
	
	J = [
	    -(L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]))*cos(q[1]),
	    (L[2]*sin(q[2]) + L[3]*sin(q[2]+q[3]))*sin(q[1]),
	    L[3]*sin(q[2]+q[3])*sin(q[1]);
	
	    -(L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]))*sin(q[1]),
	    (-L[2]*sin(q[2]) - L[3]*sin(q[2]+q[3]))*cos(q[1]),
	    -L[3]*sin(q[2]+q[3])*cos(q[1]);
	
	    0,
	    L[2]*cos(q[2]) + L[3]*cos(q[2]+q[3]),
	    L[3]*cos(q[2]+q[3])
	];
	
	g = 	[	    			
				0;    			
				m[2]*grav*L[2]/2*cos(q[2]) + m[3]*grav*(L[2]*cos(q[2]) + L[3]/2*cos(q[2] + q[3]));    			
				m[3]*grav*L[3]/2*cos(q[2] + q[3])
			];
			
	vel = J * dq;
	F_imp = K_imp*(pos_des - pos) - b_imp*vel;
		
	u = transpose(J)*F_imp + g;
	// u = [1;1];

	
	implementation_end;
