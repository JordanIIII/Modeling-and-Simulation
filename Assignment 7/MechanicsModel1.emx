	real hidden wrenchGrav3[1,6];
	real hidden wrenchGrav4[1,6];
initialequations
	J1[1:6, 1] = 0;
	J1[1:6, 2] = 0;
	J1[1:6, 3] = 0;
	J2[1:6, 2] = 0;
	J2[1:6, 3] = 0;
	J3[1:6, 3] = 0;
equations
	World\AbsH = World\H;
	Body1Weld\ConnectionPoint1\AbsH = multiplyH (World\AbsH, Body1Weld\ConnectionPoint1\RelH);
	Body1Weld\AbsH = Body1Weld\ConnectionPoint1\AbsH;
	Body1Weld\ConnectionPoint2\AbsH = Body1Weld\AbsH;
	Body1\AbsH = multiplyH (Body1Weld\ConnectionPoint2\AbsH, Body1\RelH);
	RotationJointZ2\ConnectionPoint1\AbsH = multiplyH (Body1\AbsH, RotationJointZ2\ConnectionPoint1\RelH);
	RotationJointZ2\phi = int (RotationJointZ2\omega) + RotationJointZ2\phiInitial;
	RotationJointZ2\sinTh = sin (RotationJointZ2\phi);
	RotationJointZ2\CosTh = cos (RotationJointZ2\phi);
	RotationJointZ2\Rot = [RotationJointZ2\CosTh, -RotationJointZ2\sinTh, 0;
				RotationJointZ2\sinTh, RotationJointZ2\CosTh, 0;
				0, 0, 1];
	RotationJointZ2\Pos = 0;
	RotationJointZ2\RelH = homogeneous (RotationJointZ2\Rot, RotationJointZ2\Pos);
	RotationJointZ2\AbsH = multiplyH (RotationJointZ2\ConnectionPoint1\AbsH, RotationJointZ2\RelH);
	RotationJointZ2\ConnectionPoint2\AbsH = RotationJointZ2\AbsH;
	Body2\AbsH = multiplyH (RotationJointZ2\ConnectionPoint2\AbsH, Body2\RelH);
	Body2\InDiag[1, 1:6] = [Body2\Ixx, Body2\Iyy, Body2\Izz, Body2\mass, Body2\mass, Body2\mass];
	Body2\InDiag[2, 1:6] = [Body2\Ixx, Body2\Iyy, Body2\Izz, Body2\mass, Body2\mass, Body2\mass];
	Body2\InDiag[3, 1:6] = [Body2\Ixx, Body2\Iyy, Body2\Izz, Body2\mass, Body2\mass, Body2\mass];
	Body2\InDiag[4, 1:6] = [Body2\Ixx, Body2\Iyy, Body2\Izz, Body2\mass, Body2\mass, Body2\mass];
	Body2\InDiag[5, 1:6] = [Body2\Ixx, Body2\Iyy, Body2\Izz, Body2\mass, Body2\mass, Body2\mass];
	Body2\InDiag[6, 1:6] = [Body2\Ixx, Body2\Iyy, Body2\Izz, Body2\mass, Body2\mass, Body2\mass];
	RotationJointY1\ConnectionPoint1\AbsH = multiplyH (Body2\AbsH, RotationJointY1\ConnectionPoint1\RelH);
	RotationJointY1\phi = int (RotationJointY1\omega) + RotationJointY1\phiInitial;
	RotationJointY1\sinTh = sin (RotationJointY1\phi);
	RotationJointY1\CosTh = cos (RotationJointY1\phi);
	RotationJointY1\Rot = [RotationJointY1\CosTh, 0, RotationJointY1\sinTh;
				0, 1, 0;
				-RotationJointY1\sinTh, 0, RotationJointY1\CosTh];
	RotationJointY1\Pos = 0;
	RotationJointY1\RelH = homogeneous (RotationJointY1\Rot, RotationJointY1\Pos);
	RotationJointY1\AbsH = multiplyH (RotationJointY1\ConnectionPoint1\AbsH, RotationJointY1\RelH);
	RotationJointY1\ConnectionPoint2\AbsH = RotationJointY1\AbsH;
	Body3\AbsH = multiplyH (RotationJointY1\ConnectionPoint2\AbsH, Body3\RelH);
	Body3\InDiag[1, 1:6] = [Body3\Ixx, Body3\Iyy, Body3\Izz, Body3\mass, Body3\mass, Body3\mass];
	Body3\InDiag[2, 1:6] = [Body3\Ixx, Body3\Iyy, Body3\Izz, Body3\mass, Body3\mass, Body3\mass];
	Body3\InDiag[3, 1:6] = [Body3\Ixx, Body3\Iyy, Body3\Izz, Body3\mass, Body3\mass, Body3\mass];
	Body3\InDiag[4, 1:6] = [Body3\Ixx, Body3\Iyy, Body3\Izz, Body3\mass, Body3\mass, Body3\mass];
	Body3\InDiag[5, 1:6] = [Body3\Ixx, Body3\Iyy, Body3\Izz, Body3\mass, Body3\mass, Body3\mass];
	Body3\InDiag[6, 1:6] = [Body3\Ixx, Body3\Iyy, Body3\Izz, Body3\mass, Body3\mass, Body3\mass];
	RotationJointY2\ConnectionPoint1\AbsH = multiplyH (Body3\AbsH, RotationJointY2\ConnectionPoint1\RelH);
	RotationJointY2\phi = int (RotationJointY2\omega) + RotationJointY2\phiInitial;
	RotationJointY2\sinTh = sin (RotationJointY2\phi);
	RotationJointY2\CosTh = cos (RotationJointY2\phi);
	RotationJointY2\Rot = [RotationJointY2\CosTh, 0, RotationJointY2\sinTh;
				0, 1, 0;
				-RotationJointY2\sinTh, 0, RotationJointY2\CosTh];
	RotationJointY2\Pos = 0;
	RotationJointY2\RelH = homogeneous (RotationJointY2\Rot, RotationJointY2\Pos);
	RotationJointY2\AbsH = multiplyH (RotationJointY2\ConnectionPoint1\AbsH, RotationJointY2\RelH);
	RotationJointY2\ConnectionPoint2\AbsH = RotationJointY2\AbsH;
	Body4\AbsH = multiplyH (RotationJointY2\ConnectionPoint2\AbsH, Body4\RelH);
	Body4\InDiag[1, 1:6] = [Body4\Ixx, Body4\Iyy, Body4\Izz, Body4\mass, Body4\mass, Body4\mass];
	Body4\InDiag[2, 1:6] = [Body4\Ixx, Body4\Iyy, Body4\Izz, Body4\mass, Body4\mass, Body4\mass];
	Body4\InDiag[3, 1:6] = [Body4\Ixx, Body4\Iyy, Body4\Izz, Body4\mass, Body4\mass, Body4\mass];
	Body4\InDiag[4, 1:6] = [Body4\Ixx, Body4\Iyy, Body4\Izz, Body4\mass, Body4\mass, Body4\mass];
	Body4\InDiag[5, 1:6] = [Body4\Ixx, Body4\Iyy, Body4\Izz, Body4\mass, Body4\mass, Body4\mass];
	Body4\InDiag[6, 1:6] = [Body4\Ixx, Body4\Iyy, Body4\Izz, Body4\mass, Body4\mass, Body4\mass];
	RotationJointY2\ConnectionPoint2\AbsHinverse = inverseH (RotationJointY2\ConnectionPoint2\AbsH);
	RotationJointY2\Wrench = [0, RotationJointY2\torque, 0, 0, 0, 0] * Adjoint (RotationJointY2\ConnectionPoint2\AbsHinverse);
	RotationJointY1\ConnectionPoint2\AbsHinverse = inverseH (RotationJointY1\ConnectionPoint2\AbsH);
	RotationJointY1\Wrench = [0, RotationJointY1\torque, 0, 0, 0, 0] * Adjoint (RotationJointY1\ConnectionPoint2\AbsHinverse);
	RotationJointZ2\ConnectionPoint2\AbsHinverse = inverseH (RotationJointZ2\ConnectionPoint2\AbsH);
	RotationJointZ2\Wrench = [0, 0, RotationJointZ2\torque, 0, 0, 0] * Adjoint (RotationJointZ2\ConnectionPoint2\AbsHinverse);
	AdjX2[1:3] = RotationJointZ2\ConnectionPoint1\AbsH[1:3, 3];
	AdjX2[4] = RotationJointZ2\ConnectionPoint1\AbsH[2, 4] * RotationJointZ2\ConnectionPoint1\AbsH[3, 3] - RotationJointZ2\ConnectionPoint1\AbsH[3, 4] * RotationJointZ2\ConnectionPoint1\AbsH[2, 3];
	AdjX2[5] = RotationJointZ2\ConnectionPoint1\AbsH[3, 4] * RotationJointZ2\ConnectionPoint1\AbsH[1, 3] - RotationJointZ2\ConnectionPoint1\AbsH[1, 4] * RotationJointZ2\ConnectionPoint1\AbsH[3, 3];
	AdjX2[6] = RotationJointZ2\ConnectionPoint1\AbsH[1, 4] * RotationJointZ2\ConnectionPoint1\AbsH[2, 3] - RotationJointZ2\ConnectionPoint1\AbsH[2, 4] * RotationJointZ2\ConnectionPoint1\AbsH[1, 3];
	AdjX2_T = transpose (AdjX2);
	adjAdjX2 = adjoint (AdjX2);
	AdjX3[1:3] = RotationJointY1\ConnectionPoint1\AbsH[1:3, 2];
	AdjX3[4] = RotationJointY1\ConnectionPoint1\AbsH[2, 4] * RotationJointY1\ConnectionPoint1\AbsH[3, 2] - RotationJointY1\ConnectionPoint1\AbsH[3, 4] * RotationJointY1\ConnectionPoint1\AbsH[2, 2];
	AdjX3[5] = RotationJointY1\ConnectionPoint1\AbsH[3, 4] * RotationJointY1\ConnectionPoint1\AbsH[1, 2] - RotationJointY1\ConnectionPoint1\AbsH[1, 4] * RotationJointY1\ConnectionPoint1\AbsH[3, 2];
	AdjX3[6] = RotationJointY1\ConnectionPoint1\AbsH[1, 4] * RotationJointY1\ConnectionPoint1\AbsH[2, 2] - RotationJointY1\ConnectionPoint1\AbsH[2, 4] * RotationJointY1\ConnectionPoint1\AbsH[1, 2];
	AdjX3_T = transpose (AdjX3);
	adjAdjX3 = adjoint (AdjX3);
	AdjX4[1:3] = RotationJointY2\ConnectionPoint1\AbsH[1:3, 2];
	AdjX4[4] = RotationJointY2\ConnectionPoint1\AbsH[2, 4] * RotationJointY2\ConnectionPoint1\AbsH[3, 2] - RotationJointY2\ConnectionPoint1\AbsH[3, 4] * RotationJointY2\ConnectionPoint1\AbsH[2, 2];
	AdjX4[5] = RotationJointY2\ConnectionPoint1\AbsH[3, 4] * RotationJointY2\ConnectionPoint1\AbsH[1, 2] - RotationJointY2\ConnectionPoint1\AbsH[1, 4] * RotationJointY2\ConnectionPoint1\AbsH[3, 2];
	AdjX4[6] = RotationJointY2\ConnectionPoint1\AbsH[1, 4] * RotationJointY2\ConnectionPoint1\AbsH[2, 2] - RotationJointY2\ConnectionPoint1\AbsH[2, 4] * RotationJointY2\ConnectionPoint1\AbsH[1, 2];
	AdjX4_T = transpose (AdjX4);
	adjAdjX4 = adjoint (AdjX4);
	J2[1:6, 1] = AdjX2;
	J3[1:6, 1] = AdjX2;
	J3[1:6, 2] = AdjX3;
	J4[1:6, 1] = AdjX2;
	J4[1:6, 2] = AdjX3;
	J4[1:6, 3] = AdjX4;
	T1_00 = J1 * v;
	T1_00T = transpose (T1_00);
	T2_00 = J2 * v;
	T2_00T = transpose (T2_00);
	T3_00 = J3 * v;
	T3_00T = transpose (T3_00);
	T4_00 = J4 * v;
	T4_00T = transpose (T4_00);
	AdjInv2 = Adjoint (inverseH (Body2\AbsH));
	M2 = (transpose (AdjInv2) .* Body2\InDiag) * AdjInv2;
	TM2 = T2_00T * M2;
	AdjInv3 = Adjoint (inverseH (Body3\AbsH));
	M3 = (transpose (AdjInv3) .* Body3\InDiag) * AdjInv3;
	TM3 = T3_00T * M3;
	AdjInv4 = Adjoint (inverseH (Body4\AbsH));
	M4 = (transpose (AdjInv4) .* Body4\InDiag) * AdjInv4;
	TM4 = T4_00T * M4;
	M2_2 = AdjX2_T * ((M2 + M3 + M4) * AdjX2);
	M3_2 = AdjX3_T * ((M3 + M4) * AdjX2);
	M3_3 = AdjX3_T * ((M3 + M4) * AdjX3);
	M4_2 = AdjX4_T * (M4 * AdjX2);
	M4_3 = AdjX4_T * (M4 * AdjX3);
	M4_4 = AdjX4_T * (M4 * AdjX4);
	MassMatrix[1, 1] = M2_2;
	MassMatrix[1, 2] = M3_2;
	MassMatrix[1, 3] = M4_2;
	MassMatrix[2, 1] = M3_2;
	MassMatrix[2, 2] = M3_3;
	MassMatrix[2, 3] = M4_3;
	MassMatrix[3, 1] = M4_2;
	MassMatrix[3, 2] = M4_3;
	MassMatrix[3, 3] = M4_4;
	wrenchGrav2 = Body2\mass * [gravity[3] * Body2\AbsH[2, 4] - gravity[2] * Body2\AbsH[3, 4], gravity[1] * Body2\AbsH[3, 4] - gravity[3] * Body2\AbsH[1, 4], gravity[2] * Body2\AbsH[1, 4] - gravity[1] * Body2\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav3 = Body3\mass * [gravity[3] * Body3\AbsH[2, 4] - gravity[2] * Body3\AbsH[3, 4], gravity[1] * Body3\AbsH[3, 4] - gravity[3] * Body3\AbsH[1, 4], gravity[2] * Body3\AbsH[1, 4] - gravity[1] * Body3\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	wrenchGrav4 = Body4\mass * [gravity[3] * Body4\AbsH[2, 4] - gravity[2] * Body4\AbsH[3, 4], gravity[1] * Body4\AbsH[3, 4] - gravity[3] * Body4\AbsH[1, 4], gravity[2] * Body4\AbsH[1, 4] - gravity[1] * Body4\AbsH[2, 4], gravity[1], gravity[2], gravity[3]];
	PDotBodies[1] = -((TM2 + TM3 + TM4) * (adjAdjX2 * T2_00));
	PDotBodies[2] = -((TM3 + TM4) * (adjAdjX3 * T3_00));
	PDotBodies[3] = -(TM4 * (adjAdjX4 * T4_00));
	PDot = PDotBodies + transpose (wrenchGrav2 * J2 + wrenchGrav3 * J3 + wrenchGrav4 * J4 + RotationJointZ2\Wrench * (J2 - J1) + RotationJointY1\Wrench * (J3 - J2) + RotationJointY2\Wrench * (J4 - J3));
	P = int (PDot) + PDotInitial;
	v = linsolve (MassMatrix, P, 'cholesky');
	RotationJointZ2\omega = v[1];
	RotationJointY1\omega = v[2];
	RotationJointY2\omega = v[3];
	RotationJointZ2\torque = RotationJointZ2.e;
	RotationJointZ2.f = RotationJointZ2\omega;
	RotationJointY1\torque = RotationJointY1.e;
	RotationJointY1.f = RotationJointY1\omega;
	RotationJointY2\torque = RotationJointY2.e;
	RotationJointY2.f = RotationJointY2\omega;
implementation_end;
