       line 84.5 318.4 84.5 337.6 color 0;
       line 110.1 328 81.3 328 color 0;
       spline 84.9 327.9 88.1 319.8 91.3 327.9 94.6 336 97.7 327.9 100.8 319.8 104.1 327.9 107.6 336.2 110.8 328.2 color 16711680;
      end;
    end;
    implementation eq
parameters
	real amplitude = 0.3;			// amplitude of the wave
	real omega = 1.0 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * sin ( omega * time);
implementation_end;
  end;
  connections
   Constant1\output -> Mux\input2;
   Constant2\output -> PlusMinus1\plus;
   Constant3\output -> Mux\input1;
   Demux\output1 -> MSe\effort;
   Demux\output2 -> MSe1\effort;
   Demux\output3 -> MSe2\effort;
   Imp_contr\u -> Demux\input;
   MSe\p => MechanicsModel1\RotationJointZ2;
   MSe1\p => MechanicsModel1\RotationJointY1;
   MSe2\p => MechanicsModel1\RotationJointY2;
   Mux\output -> Imp_contr\pos_des;
   PlusMinus1\output -> Mux\input3;
   WaveGenerator1\output -> PlusMinus1\plus;
  end;
 implementation_end;
]]></Sidops>
