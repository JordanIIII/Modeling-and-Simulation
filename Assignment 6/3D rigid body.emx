   TF 232 168
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Bond Graph\3D\TF-3.emx</LibraryPath>
  <TimeStamp>2007-9-25 12:11:35</TimeStamp>
</Description>';
    type 'TF-3'
     ports
      rotation in body [3,1];
      translation out world [3,1];
     restrictions
      causality constraint not_equal body world;
    end;
    icon bg ellipse bottom
     figures
      text 'TF' 232 168 color 0 18 bold;
    end;
    implementation eq
parameters
	real r_B[3] = [0.2;
						0.0;
						0.0]; // point [x; y; z]
						
variables 
	real A[3,3];
	
equations		
	A = [0.0,		r_B[3],	-r_B[2];
		  -r_B[3],	0.0,		r_B[1];
		  r_B[2],	-r_B[1],	0.0];
		
	world.v = A*body.omega;
	body.T = transpose(A)*world.F;
				
implementation_end;
   Translation 152 440
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\I-3.emx</LibraryPath><TimeStamp>2007-9-25 12:12:14</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
