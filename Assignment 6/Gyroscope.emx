      RotorConnection 584 120
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\TF-3.emx</LibraryPath><TimeStamp>2007-9-25 12:11:35</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'TF-3'
        ports
         rotation in body_r [3,1];
         translation out body_t [3,1];
        restrictions
         causality constraint not_equal body_r body_t;
       end;
       icon bg ellipse bottom
        figures
         text 'TF' 584 120 color 0 18 bold;
       end;
       implementation eq
parameters
	real r_B[3] = [0.0;
						0.0;
						0.0]; // point [x; y; z]
						
variables 
	real A[3,3];
	
equations		
	A = [0.0,		r_B[3],	-r_B[2];
		  -r_B[3],	0.0,		r_B[1];
		  r_B[2],	-r_B[1],	0.0];
		
	body_t.v = A*body_r.omega;
	body_r.T = transpose(A)*body_t.F;
				
implementation_end;
      RTF 504 232
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\MTF-3.emx</LibraryPath><TimeStamp>2007-9-25 12:11:21</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'MTF-3'
        ports
         translation out world [3,1];
         translation in body [3,1];
         signal in omega [3,1] {rad/s} ;
        restrictions
         causality constraint not_equal world body;
       end;
       icon bg ellipse
        figures
         text 'RTF' 504 232 color 2124031 18 bold;
       end;
       implementation eq
parameters
	real R0[3,3] = [1,0,0;
						 0,1,0;
						 0,0,1];
						
variables
	real R[3,3]; // Rotation matrix
	real S[3,3]; // Skew-symmetric matrix
	real Rdot[3,3];

equations					
	// Skew-symmetric matrix of the body-fixed angular velocity
	S = [0,		  -omega[3],	omega[2];
		  omega[3],	0,			  -omega[1];
		 -omega[2],	omega[1],	0		 ];
		
	// Orientation
	Rdot = R*S;
	R = int(Rdot, R0);

	// Rransformations
	world.v = R * body.v;
	body.F = transpose(R)*world.F;implementation_end;
      RTFT 800 232
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\MTF-3.emx</LibraryPath><TimeStamp>2007-9-25 12:11:21</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'MTF-3'
        ports
         translation out world [3,1];
         translation in body [3,1];
         signal in omega [3,1] {rad/s} ;
        restrictions
         causality constraint not_equal world body;
       end;
       icon bg ellipse bottom
        figures
         text 'RTF(T)' 800 232 color 2124031 18 bold;
       end;
       implementation eq
parameters
	real R0[3,3] = [1,0,0;
						 0,1,0;
						 0,0,1];
						
variables
	real R[3,3]; // Rotation matrix
	real S[3,3]; // Skew-symmetric matrix
	real Rdot[3,3];

equations					
	// Skew-symmetric matrix of the body-fixed angular velocity
	S = [0,		  -omega[3],	omega[2];
		  omega[3],	0,			  -omega[1];
		 -omega[2],	omega[1],	0		 ];
		
	// Orientation
	Rdot = R*S;
	R = int(Rdot, R0);

	// Rransformations
	world.v = R * body.v;
	body.F = transpose(R)*world.F;implementation_end;
