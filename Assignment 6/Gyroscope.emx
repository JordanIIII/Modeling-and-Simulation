      Rotation 136 120
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\3D\I-3.emx</LibraryPath><TimeStamp>2007-9-25 12:12:14</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'I-3'
        ports
         rotation in p [3,1];
         signal out state [3,1];
        restrictions
         causality fixed in p;
       end;
       icon bg ellipse bottom
        figures
         text 'I' 136 120 color 0 18 bold;
       end;
       implementation eq
parameters
	real global m_rotor = 0.1;	// kg
	real global R_rotor = 0.05; // m
	real global L_rotor = 0.1; // m
	real w0 = 100; // rad/s

	 real J[3] = [(1.0/12.0)*m_rotor*(3*R_rotor^2 + L_rotor^2);                 (1.0/12.0)*m_rotor*(3*R_rotor^2 + L_rotor^2);                  0.5*m_rotor*R_rotor^2];

	real omega_init[3] = [0.0; 0.0; w0];
	real p_init[3] = J .* omega_init;
	
equations
    state = int(p.e) + p_init;
    p.f = state ./ J;implementation_end;
