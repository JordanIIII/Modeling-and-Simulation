    implementation bg
     submodels
      AdHb0 264 200
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MTF.emx</LibraryPath><TimeStamp>2011-11-29 16:15:31</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type MTF
        ports
         power in p0 [6,1];
         power out pB [6,1];
         signal out Hb0 [4,4];
        restrictions
         causality constraint not_equal p0 pB;
       end;
       icon bg ellipse right
        figures
         text 'MTF' 264 200 color 0 18 bold;
       end;
       implementation eq
// 0 frame to rotor body frame
parameters
	real global Lf;
	real global m;
	real Hb0_init[4,4] = homogeneous(eye(3),[0;0;Lf/2]);		// rotor is at the middle of frame height
variables
	real AdH[6,6];
	real PE;
equations
	Hb0 = int(Hb0 * tilde(pB.f),Hb0_init);
	AdH = Adjoint(Hb0);
	p0.f = AdH * pB.f;
	pB.e = transpose(AdH) * p0.e;
	PE = m * g_n * (Hb0[3,4] - Hb0_init[3,4]);implementation_end;
      AdHb1 672 128
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MTF.emx</LibraryPath><TimeStamp>2011-11-29 16:15:31</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type MTF
        ports
         power in p0 [6,1];
         power out pB [6,1];
         signal out Hb0 [4,4];
        restrictions
         causality constraint not_equal p0 pB;
       end;
       icon bg ellipse right
        figures
         text 'MTF' 672 128 color 0 18 bold;
       end;
       implementation eq
parameters
	real global Lf;
	real global mf;
	real Hb0_init[4,4] = homogeneous(eye(3),[0;0;Lf/2]);		// frame's frame(coordinate) is at center of frame, same initial position as rotor
variables
	real AdH[6,6];
	real PE;
equations
	Hb0 = int(Hb0 * tilde(pB.f),Hb0_init);
	AdH = Adjoint(Hb0);
	p0.f = AdH * pB.f;
	pB.e = transpose(AdH) * p0.e;
	PE = mf * g_n * (Hb0[3,4] - Hb0_init[3,4]);implementation_end;
      AdHj1 376 384
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MTF.emx</LibraryPath><TimeStamp>2011-11-29 16:15:31</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type MTF
        ports
         power out pj [6,1];
         power in p0 [6,1];
         signal in Hb0 [4,4];
        restrictions
         causality constraint not_equal pj p0;
       end;
       icon bg ellipse bottom
        figures
         text 'MTF' 376 384 color 0 18 bold;
       end;
       implementation eq
// 0 frame to joint frame
parameters
	real pj_b[3] = [0; 0; 0];		// joint frame is at rotor body frame
	real Hj_b[4,4] = homogeneous(eye(3), pj_b);
variables
	real AdH0j[6,6];		// in frame 0
	real Hj0[4,4];
equations
	Hj0 = Hb0 * Hj_b;
	AdH0j = Adjoint(inverseH(Hj0));
	pj.f = AdH0j * p0.f;
	p0.e = transpose(AdH0j) * pj.e;
implementation_end;
      AdHj2 736 248
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MTF.emx</LibraryPath><TimeStamp>2011-11-29 16:15:31</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type MTF
        ports
         power in pj [6,1];
         power out p0 [6,1];
         signal in Hb0 [4,4];
        restrictions
         causality constraint not_equal pj p0;
       end;
       icon bg ellipse bottom
        figures
         text 'MTF' 736 248 color 0 18 bold;
       end;
       implementation eq
parameters
	real global Lf;
	real pj_b[3] = [0; 0; -Lf/2];
	real Hj_b[4,4] = homogeneous(eye(3), pj_b);
variables
	real AdHj0[6,6];
	real Hj0[4,4];
equations
	Hj0 = Hb0 * Hj_b;
	AdHj0 = Adjoint(Hj0);
	p0.f = AdHj0 * pj.f;
	pj.e = transpose(AdHj0) * p0.e;
implementation_end;
      AdHk0 192 320
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MTF.emx</LibraryPath><TimeStamp>2011-11-29 16:15:31</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type MTF
        ports
         power in pK [6,1];
         power out p0 [6,1];
         signal in Hb0 [4,4];
        restrictions
         causality constraint not_equal pK p0;
       end;
       icon bg ellipse bottom
        figures
         text 'MTF' 192 320 color 0 18 bold;
       end;
       implementation eq
// Assume k-frame (at where forces are applied) is same position as rotor body frame with no orientation (z-axis upward)
// Coordinate transformer from k frame to 0 frame
variables
	real AdH0k[6,6];
	real H0k[4,4];
equations
	H0k = homogeneous(eye(3),-Hb0[1:3,4]);		// no rotation but shifted position
	AdH0k = Adjoint(H0k);
	pK.f = AdH0k * p0.f;
	p0.e = transpose(AdH0k) * pK.e;
implementation_end;
