      I_frame 616 0
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type I
        ports
         power in p [6,1];
         signal out state [6,1];
        restrictions
         causality preferred in p;
       end;
       icon bg ellipse bottom
        figures
         text 'I' 616 0 color 0 18 bold;
       end;
       implementation eq
// frame consist of a rod (along local z axis) and two rings connected at both ends
parameters
	real global mrod = 0.1;
	real global Rrod = 0.007;		// radius of rod
	real global Lf = 0.2;			// length of frame (rod)
	
	real global mring = 0.03;
	real global Rring = Lf/2 - 0.025;
	real global mf = mrod + 2*mring;
	
	// rod
	real Jrod[3] = [(1/12)*mrod*(3*Rrod^2+Lf^2); (1/12)*mrod*(3*Rrod^2+Lf^2); (1/2)*mrod*Rrod^2];
	real Jring_xz[3] = [(1/2)*mring*Rring^2; mring*Rring^2; (1/2)*mring*Rring^2];
	real Jring_yz[3] = [mring*Rring^2; (1/2)*mring*Rring^2; (1/2)*mring*Rring^2];

	real J[3] = Jrod + Jring_xz + Jring_yz;
	real i[6] = transpose([J[1],J[2],J[3],mf,mf,mf]);
	
variables
	real KE;
equations
   state = int(p.e);
   p.f = state ./ i;
	KE = (1/2) * transpose(state) * p.f;
implementation_end;
      I_rotor 208 72
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type I
        ports
         power in p [6,1];
         signal out state [6,1];
        restrictions
         causality preferred in p;
       end;
       icon bg ellipse bottom
        figures
         text 'I' 208 72 color 0 18 bold;
       end;
       implementation eq
parameters
	real global m = 0.6;		// mass
	real global R = 0.07;	// radius
	real global L = 0.01;		// length
	real w0 = 20 * 6.28; // rps to rad/s
	real J[3] = [(1/12)*m*(3*R^2+L^2); (1/12)*m*(3*R^2+L^2); (1/2)*m*R^2];
	real i[6] = transpose([J[1],J[2],J[3],m,m,m]);
	real p_init[6] = i .* [0; 0; w0; 0; 0; 0];
variables
	real KE;
equations
   state = int(p.e, p_init);		// momentum
   p.f = state ./ i;				// twist = P * M^-1
	KE = (1/2) * transpose(state) * p.f;
implementation_end;
      Joint1Constraints 432 456
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type R
        ports
         power in p [6,1];
       end;
       icon bg ellipse bottom
        figures
         text 'RC' 432 456 color 0 18 bold;
       end;
       implementation eq
// rotor-frame joint model (only z-axis is allowed to rotate)
// so the bearing. assume perfect constraints to 5 constraints
parameters
	real r = 1e4;	// damping - physically constraint viscos friction etc...
	real k = 1e6;	// stiffness
variables
	real q[6];
	real E_dissipated;
	real E_spring;
equations
	q = int(p.f);
	p.e = [r;r;0;r;r;r] .* p.f + [k;k;0;k;k;k] .* q;	// wench = r*twist + k*pose
	E_dissipated = int(transpose(p.e) * p.f);
	E_spring = (1/2) * transpose(q) * ([k;k;0;k;k;k] .* q);implementation_end;
      Joint1Friction 312 456
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type R
        ports
         power in p [6,1];
       end;
       icon bg ellipse bottom
        figures
         text 'R' 312 456 color 0 18 bold;
       end;
       implementation eq
parameters
	real rv = 0.0001;		// viscus
	real rc = 0.00005;		// coulumb
	real eps = 0.00005;
equations
	p.e = rv * p.f + rc * tanh(p.f / eps);
	
implementation_end;
      Joint2Constraints 800 360
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type R
        ports
         power in p [6,1];
       end;
       icon bg ellipse bottom
        figures
         text 'RC' 800 360 color 0 18 bold;
       end;
       implementation eq
// 3DOF at frame-base joint
parameters
	real r = 1e2;
	real k = 1e5;
variables
	real q[6];
	real E_dissipated;
	real E_spring;
equations
	q = int(p.f);
	p.e = [0;0;0;r;r;r] .* p.f + [0;0;0;k;k;k] .* q;
	E_dissipated = int(transpose(p.e) * p.f);
	E_spring = (1/2) * transpose(q) * ([0;0;0;k;k;k] .* q);implementation_end;
      Joint2Friction 856 304
