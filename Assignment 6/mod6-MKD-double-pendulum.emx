   R 800 360
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\R.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:35:37</TimeStamp>
</Description>
</Information>';
    type R
     ports
      power in p [6,1];
    end;
    icon bg ellipse bottom
     figures
      text 'RC' 800 360 color 0 18 bold;
    end;
    implementation eq
// 3DOF at frame-base joint
parameters
	real r = 1e2;
	real k = 1e5;
variables
	real q[6];
	real E_dissipated;
equations
	q = int(p.f);
	p.e = [0;0;0;r;r;r] .* p.f + [0;0;0;k;k;k] .* q;
	E_dissipated = int(transpose(p.e) * p.f);implementation_end;
   R1 432 456
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\R.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:35:37</TimeStamp>
</Description>
</Information>';
    type R
     ports
      power in p [6,1];
    end;
    icon bg ellipse bottom
     figures
      text 'RC' 432 456 color 0 18 bold;
    end;
    implementation eq
// rotor-frame joint model (only z-axis is allowed to rotate)
parameters
	real r = 1e5;	// damping
	real k = 1e7;	// stiffness
variables
	real q[6];
	real E_dissipated;
equations
	q = int(p.f);
	p.e = [r;r;0;r;r;r] .* p.f + [k;k;0;k;k;k] .* q;	// wench = r*twist + k*pose
	E_dissipated = int(transpose(p.e) * p.f);implementation_end;
