    implementation eq
parameters
	real global mf = 0.05;
	real global Rf = 0.06;
	real global Lf = 0.14;
	real J[3] = [0.5 * mf * Rf^2 ; 0.5 * mf * Rf^2; mf * Rf^2];
	real i[6] = transpose([J[1],J[2],J[3],mf,mf,mf]);
equations
    state = int(p.e);
    p.f = state ./ i;
implementation_end;
