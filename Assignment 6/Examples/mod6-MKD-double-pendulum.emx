   I 208 128
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\I.emx</LibraryPath>
  <TimeStamp>2011-11-29 15:55:55</TimeStamp>
</Description>
</Information>';
    type I
     ports
      power in p [6,1];
      signal out state [6,1];
     restrictions
      causality preferred in p;
    end;
    icon bg ellipse bottom
     figures
      text 'I' 208 128 color 0 18 bold;
    end;
    implementation eq
parameters
	real global m = 0.1;
	real global R = 0.05;
	real global L = 0.1;
	real w0 = 0;//20 * 6.28; // rps to rad/s
	real J[3] = [m * R^2; 0.5 * m * R^2 ; 0.5 * m * R^2];
	real i[6] = transpose([J[1],J[2],J[3],m,m,m]);
	real p_init[6] = i .* [w0;0;0; 0;0;0];
equations
    state = int(p.e, p_init);
    p.f = state ./ i;
implementation_end;
