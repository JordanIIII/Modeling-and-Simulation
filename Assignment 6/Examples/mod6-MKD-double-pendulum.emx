      text 'MTF' 736 248 color 0 18 bold;
    end;
    implementation eq
parameters
	real global Rf, Lf;
	real pj_b[3] = [0; 0.5*Lf; 0];
	real Hj_b[4,4] = homogeneous(eye(3), pj_b);
variables
	real AdHj0[6,6];
	real Hj0[4,4];
equations
	Hj0 = Hb0 * Hj_b;
	AdHj0 = Adjoint(Hj0);
	p0.f = AdHj0 * pj.f;
	pj.e = transpose(AdHj0) * p0.e;
implementation_end;
