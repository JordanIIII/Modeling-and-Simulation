    implementation eq
parameters
	real r = 1e2;
	real k = 1e5;
variables
	real q[6];
	real E_dissipated;
equations
	q = int(p.f);
	p.e = [0;0;0;r;r;r] .* p.f + [0;0;0;k;k;k] .* q;
	E_dissipated = int(transpose(p.e) * p.f);implementation_end;
