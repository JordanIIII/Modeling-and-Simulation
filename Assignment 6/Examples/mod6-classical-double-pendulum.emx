   I 752 136
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Bond Graph\3D\I-3.emx</LibraryPath>
  <TimeStamp>2007-9-25 12:12:14</TimeStamp>
</Description>';
    type 'I-3'
     ports
      power in p [3,1];
      signal out state [3,1];
     restrictions
      causality preferred in p;
    end;
    icon bg ellipse bottom
     figures
      text 'I' 752 136 color 0 18 bold;
    end;
    implementation eq
parameters
	real global m = 0.1;
	real global R = 0.05;
	real global L = 0.1;
	real w0 = 0;//20 * 6.28; // rps to rad/s
	real J[3] = [m * R^2; 0.5 * m * R^2 ; 0.5 * m * R^2];
	real p_init[3] = J .* [w0;0;0];
equations
    state = int(p.e) + p_init;
    p.f = state ./ J;
implementation_end;
