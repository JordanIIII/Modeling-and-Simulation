   R 232 268
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type R
     ports
      power in p;
      thermal out dQ;
     restrictions
      causality fixed in dQ;
    end;
    icon bg ellipse bottom
     figures
      text 'RS' 232 268 color 0 18 bold;
    end;
    implementation eq
parameters
	real r = 0.6;
equations
	//p.e = r * p.f; // regenerative braking
	p.e = if p.f >= 0 then r * p.f else r * p.f * 100000 end; // no regenerative braking
	dQ.dS = p.e * p.f / dQ.T;implementation_end;
   R1 324 384
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type R
     ports
      thermal in dQ_in;
      thermal out dQ_out;
     restrictions
      causality fixed in dQ_out;
    end;
    icon bg ellipse bottom
     figures
      text 'SRS' 324 384 color 0 18 bold;
    end;
    implementation eq
parameters
	real k = 0.6;
equations
	dQ_in.dS = k * (dQ_in.T - dQ_out.T)/ dQ_in.T;
	dQ_out.dS = k * (dQ_in.T - dQ_out.T)/ dQ_out.T;
	implementation_end;
   Sine 416 -104
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\WaveGenerator-Sine.emx</LibraryPath>
  <TimeStamp>2007-9-27 16:12:6</TimeStamp>
</Description>';
    type 'WaveGenerator-Sine'
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      group
       rectangle 400 -120 432 -88 color 0 fill 15132390;
       line 404.5 -113.6 404.5 -94.4 color 0;
       line 430.1 -104 401.3 -104 color 0;
       spline 404.9 -104.1 408.1 -112.2 411.3 -104.1 414.6 -96 417.7 -104.1 420.8 -112.2 424.1 -104.1 427.6 -95.8 430.8 -103.8 color 16711680;
      end;
    end;
    implementation eq
parameters
	real amplitude = 40*2*pi/60;			// amplitude of the wave
	real T = 1.0/6 {s};		// period of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / T;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * sin ( 2*pi * time/T);
implementation_end;
