    type 'Delay-Time'
     ports
      signal in input;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 88 8 120 40 color 0 fill 15132390;
      line 92.5 14.4 92.5 33.6 color 0;
      line 118.1 24 89.3 24 color 0;
      spline 92.8 17.8 97.8 17.3 100.8 22.4 103.7 28.3 107.9 30.6 color 16711680;
      spline 103.5 17.3 108.3 17.3 110.9 21.3 113.6 26.7 118.4 30.1 color 16711680;
      group
       line 108.8 19.9 108.8 21.3 color 16711680;
       group
        line 108.8 21.3 108.8 19.9 color 16711680;
        line 101.5 20.7 108.8 20.7 color 16711680;
       end;
      end;
    end;
    implementation eq
parameters
	real delay = 0.001 {s};	// time delay (s)
	real initial = 0;		// initial value
variables
	real delayOutput;
equations
	delayOutput =  tdelay (input,delay);
	if (time <= delay) then
		output = initial;
	else
		output = delayOutput;
	end;
       implementation_end;
