    end;
    icon bg ellipse bottom
     figures
      text 'RS' 320 328 color 0 18 bold;
    end;
    implementation eq
parameters
	real r = 1.0;
	real k = 0.6;
equations
	Q_system.dS = k*((Q_system.T-Q_env.T)/(Q_system.T+1));
	Q_env.dS 	= k*((Q_system.T-Q_env.T)/(Q_env.T+1));
	
implementation_end;
