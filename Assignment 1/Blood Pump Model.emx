   MotionProfile 512 -32
    description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\MotionProfile.emx</LibraryPath>
  <TimeStamp>2007-12-19 13:45:54</TimeStamp>
  <AllowLibraryUpdate>False</AllowLibraryUpdate>
</Description>';
    type 'MotionProfile-Wizard'
     ports
      signal out x;
     parameters
      real stroke = 8.3776;
      real start_time = 0;
      real stop_time = 0.15;
    end;
    icon bg bottom
     figures
      rectangle 497 -47 527 -17 color 0 fill 15132390;
      line 515 -35.7 521.4 -35.7 color 16711680;
      line 499.7 -24.5 524.3 -24.5 color 0;
      line 502.3 -25.4 506.6 -25.4 515.1 -36.1 color 16711680;
      line 501.8 -39.5 501.8 -22.4 color 0;
      rectangle 497 -47 527 -17 color -1;
      line 517.6 -42.7 519.6 -42.9 color 16711680;
      line 518.8 -44.7 520.8 -45 color 16711680;
      line 521.1 -42.8 523.1 -43 color 16711680;
      line 520.7 -41.7 523.5 -31 color 5855577 width 2;
    end;
    implementation eq
// 20-sim User Editor
// MotionProfile.dll
/*
MotionType	Step
Stroke	8.3776
StartTime	0
StopTime	0.15
ReturnTime	3
EndTime	4
Period	5
CV	0.2
CA	0.2
n	3
alpha	0.1
BB	0
BM	0
ProfileType	Cycloidal
DoOutputPosition	1
DoOutputVelocity	0
DoOutputAcceleration	0
InputChoice	0
GenerateEvents	1
DescriptionEnd
*/
 variables
  real hidden u;
  real hidden fu;
  real hidden rise_time;
  boolean hidden evt1, evt2;
  real hidden two_pi;
 equations
	rise_time = (stop_time - start_time);
	x = stroke * fu;
	if time < start_time then
		u = 0;
	else
		if time < stop_time then
			u = ( time - start_time ) / rise_time;
		else
			u = 1;
		end;
	end;
	evt1 = timeevent(start_time);
	evt2 = timeevent(stop_time);
	two_pi = 6.283185307179586;
	if u == 0 then
		fu = 0;
	else
		if u == 1 then
			fu = 1;
		else
			fu = (u - ( sin ( two_pi * u ) ) / two_pi );
		end;
	end;
implementation_end;
