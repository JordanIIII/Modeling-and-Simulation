  terminals
   p_in 408 216 fixed;
   p_out 472 216 fixed;
 end;
 implementation eq
parameters
	real i = 60.0 {};				// gearbox ratio
	real eff = 0.9 {};			// gearbox efficiency (0 < eff <= 1)
variables
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p_out.T = p_in.T*i*dyn_eff;
	p_out.omega = p_in.omega/i;
	dQ.dS = p_out.T*p_out.omega / (dQ.T+1);
	dyn_eff = if (sign(dly(p_in.T,0.0))*sign(dly(p_in.omega,0.0))) >= 0 then eff else 1/eff end;
	
                     implementation_end;
specification_end;
