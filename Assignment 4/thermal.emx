   Gas 329.2 208
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\CC.emx</LibraryPath><TimeStamp>2011-11-29 15:33:22</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type CC
     ports
      thermal in thermal;
      hydraulic out hydraulic;
      signal out S;
      signal out V;
     restrictions
      causality preferred out thermal;
      causality preferred out hydraulic;
    end;
    icon bg ellipse bottom
     figures
      text 'CC' 329.2 208 color 0 18 bold;
    end;
    implementation eq
 parameters
    real c = 130;        // heat capacity relation
    real T0 = 25 + 273.15;     // reference temperature
    real R = 287;        // gas constant
    real m = 0.01;       // gas mass
	 real V0 = 1e-4; 		 // initial volume
equations
    S = int(thermal.f);
    V = int(hydraulic.f, V0);

    thermal.e = T0 * exp((S - m*R*log(V/V0)) / (m*c));

    hydraulic.e = m * R * thermal.e / V;implementation_end;
   Mass 576 208
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type I
     ports
      mechanical in p;
      signal out state;
     restrictions
      causality preferred in p;
    end;
    icon bg ellipse bottom
     figures
      text 'I' 576 208 color 0 18 bold;
    end;
    implementation eq
parameters
	real i = 1;
equations
    state = int(p.e);
    p.f = state / i;
implementation_end;
