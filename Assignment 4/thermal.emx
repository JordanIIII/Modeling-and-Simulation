   Piston 400 208
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\TF.emx</LibraryPath><TimeStamp>2011-11-29 16:43:47</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type TF
     ports
      mechanical out mechanical;
      hydraulic in hydraulic;
     restrictions
      causality constraint not_equal mechanical hydraulic;
    end;
    icon bg ellipse bottom
     figures
      text 'TF' 400 208 color 0 18 bold;
    end;
    implementation eq
parameters
	real r = 0.001;
equations
	mechanical.F = r * hydraulic.p;
	hydraulic.phi = r * mechanical.v;
implementation_end;
   Position 528 207.9
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\QSensor.emx</LibraryPath><TimeStamp>2011-11-29 16:34:15</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
