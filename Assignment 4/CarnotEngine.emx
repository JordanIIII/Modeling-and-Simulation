  connections
   AtmosphericPressure\p => OneJunction4\p;
   Cold\output -> MSe1\effort;
   eff\input <- MultiplyDivide1\output;
   Gas\hydraulic => OneJunction4\p;
   Gas\thermal <= ZeroJunction1\p;
   Hot\output -> MSe2\effort;
   HotContact\p <= OneJunction2\p;
   MSe1\p => Pcold\p1;
   MSe2\p => Phot\p1;
   OneJunction2\p => ZeroJunction1\p;
   OneJunction3\p => ColdContact\p;
   OneJunction3\p => ZeroJunction1\p;
   OneJunction4\p => Piston\hydraulic;
   OneJunction5\p => Pout\p1;
   Pcold\P -> PlusMinus1\plus 432 352;
   Pcold\p2 => OneJunction3\p;
   Phot\P -> PlusMinus1\plus;
   Phot\p2 => OneJunction2\p;
   Piston\mechanical => OneJunction1\p;
   PlusMinus1\output -> MultiplyDivide1\multiply;
   Pout\P -> MultiplyDivide1\divide 792 64;
   Pout\p2 => Mass\p;
   SliderCrank\rot => theta\p1;
   SliderCrank\trans <= OneJunction1\p;
   Splitter1\output -> ColdContact\position 72 280;
   Splitter1\output -> HotContact\position 72 136;
   theta\p2 => OneJunction5\p;
   theta\q -> Splitter1\input 664 -48 72 -48;
  end;
 implementation_end;
