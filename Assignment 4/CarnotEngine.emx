   ColdContact 152 280
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MR.emx</LibraryPath><TimeStamp>2011-11-29 16:09:29</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type MR
     ports
      power in p;
      signal in position;
    end;
    icon bg ellipse bottom
     figures
      text 'MR' 152 280 color 0 18 bold;
    end;
    implementation eq
parameters
	real qlimU = 4.7122 + 0.85;
	real qlimL = 3.1416;
	real RnoContact = 1e10;
	real RContact = 1e-4;
variables 
	real r;
	real Endstroke;
initialequations
	Endstroke = 0.0;
equations
	//Endstroke = if (position >= qlimU) or (Endstroke==1.0) then
	//	if (position >= qlimL) then
	//		1.0
	//	else 
	//		0.0
	//	end
	//else 
	//	0.0
	//end;	
	//Endstroke = if (position >= qlim) then 1.0 else previous(Endstroke) end;
	//r = if (Endstroke == 1.0) then RContact else RnoContact end;
	r = if (position > qlimL) and (position < qlimU) then RContact else RnoContact end;
	p.e = r * p.f;
implementation_end;
