   SliderCrank 592 208
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\TF.emx</LibraryPath><TimeStamp>2011-11-29 16:43:47</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type TF
     ports
      translation in trans;
      rotation out rot;
     restrictions
      causality constraint not_equal trans rot;
    end;
    icon bg ellipse bottom
     figures
      text 'TF' 592 208 color 0 18 bold;
    end;
    implementation eq
parameters
	real r = 0.1;
variables
	real theta;
equations
	theta = int(rot.omega, 0.1);
	
	trans.v = (r * sin(theta)) * rot.omega;
	rot.T   = (r * sin(theta)) * trans.F;implementation_end;
