   HotContact 152 136
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\MR.emx</LibraryPath><TimeStamp>2011-11-29 16:09:29</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type MR
     ports
      power in p;
      signal in position;
    end;
    icon bg ellipse bottom
     figures
      text 'MR' 152 136 color 0 18 bold;
    end;
    implementation eq
parameters
	real qlim = 1.5707;
	real RnoContact = 1e10;
	real RContact = 1e-4;
variables 
	real r;
equations
	r = if (position < qlim) and (position > 0) then RContact else RnoContact end;
	p.e = r * p.f;
implementation_end;
