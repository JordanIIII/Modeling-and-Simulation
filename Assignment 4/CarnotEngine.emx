   Gas 313.2 208
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\CC.emx</LibraryPath><TimeStamp>2011-11-29 15:33:22</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type CC
     ports
      thermal in thermal;
      hydraulic out hydraulic;
      signal out S;
      signal out V;
     restrictions
      causality preferred out thermal;
      causality preferred out hydraulic;
    end;
    icon bg ellipse bottom
     figures
      text 'CC' 313.2 208 color 0 18 bold;
    end;
    implementation eq
 parameters
    real c = 718;        // heat capacity relation
    real T0 = 150 + 273.15;     // reference temperature
    real R = 287;        // gas constant
    real m = 0.01;       // gas mass
	 real V0 = 3e-4; 		 // initial volume
	 real S0 = 0.0; 		 // initial Entropy (obtained via running 1 loop with S0 = 0
equations
    S = int(thermal.f,S0);
    V = max(int(hydraulic.f, V0),V0);

    thermal.e = T0 * exp((S - m*R*log(V/V0)) / (m*c));

    hydraulic.e = m * R * thermal.e / V;implementation_end;
