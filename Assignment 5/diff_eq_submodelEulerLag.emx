   Pendulum 408 160
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description><Attributes><GlobalRelations></GlobalRelations></Attributes></Information>';
    type 'Submodel-Equation'
     ports
      rotation in port1;
      rotation in port2;
      signal out q1_out;
      signal out dq1_out;
      signal out q2_out;
      signal out dq2_out;
     restrictions
      causality fixed in port1;
    end;
    implementation eq
	/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/
parameters
	real global grav = 9.81;		// m/s^2
	real global x01[4] = [-pi/2;0;0;0]; // Initial joint state
	real global x02[4] = [-pi/2;0;0;0]; // Initial rotor state
	real global L[2] = [1;1];
	real global R[2] = [0.1;0.1];
	real global m[2] = [1,1];
	real global I[2] = [1/12 * (L[1]^2 + 3*R[1]^2) * m[1]; 1/12 * (L[2]^2 + 3*R[2]^2) * m[2]]; // Inertia (cylinders)
	real global J[2,2] = [0.001, 0; 0, 0.001]; // Rotot inertia
	real global K_spring[2,2] = [5, 0; 0, 5];
	real global D_spring[2,2] = [1, 0; 0, 1];
	real load[2] = [2; 2];
	
variables
	real x1[4]; // Joint state
	real x2[4]; // Rotor state
	real D[2,2];  // "Mass inertia" matrix
	real h; // Coriolis common term
	real C[2,2]; // Centrifugal and Coriolis matrix (Christoffel?)
	real g[2]; // Gravity matrix
	real u[2]; // Input torques
	real ddq1[2]; // Joint accelerations
	real ddq2[2]; // Rotor accelerations
	real Jac[2,2]; // Jacobian
	real tau_s[2];
	
equations
	// State vector x = [q1, q1_dot, q2, q2_dot];
	// Where q is the angle of the pendulum
	
	// EULER LAGRANGE 
	// M(q1)ddq1 + C(q1,dq1)dq1 + g(q1) + K(q1 - q2)= 0 // Joint dynamics
	// J*ddq2 - K(q1 - q2) = u // Rotor dynamics

	// Inertia matrix D(q)
	D = [	I[1] + I[2] + m[1]*(L[1]/2)^2 + m[2]*(L[1]^2 + (L[2]/2)^2 + 2*L[1]*(L[2]/2)^2 + 2*L[1]*(L[2]/2)*cos(x1[3])), I[2] + m[2]*((L[2]/2)^2 + L[1]*(L[2]/2)*cos(x1[3]));
		  	I[2] + m[2]*((L[2]/2)^2 + L[1]*(L[2]/2)*cos(x1[3])), I[2] + m[2]*(L[2]/2)^2
		 	];

	// Centrifugal and Coriolis C(q,dq)
	h = -m[2]*L[1]*(L[2]/2)*sin(x1[3]);
	C = [ h*x1[4], h*(x1[2] + x1[4]);
			-h*x1[2], 0
			];	
			
	// Gravity g(q)
	g = [	(m[1]*(L[1]/2) + m[2]*L[1])*grav*cos(x1[1]) + m[2]*(L[2]/2)*grav*cos(x1[1] + x1[3]);
			m[2]*(L[2]/2)*grav*cos(x1[1] + x1[3])
			];
	
	// Input torques
	u = [	port1.T;
			port2.T
			];
			
	// Jacobian	
	Jac = [
				-L[1]*sin(x1[1]) - L[2]*sin(x1[1]+x1[3]), -L[2]*sin(x1[1]+x1[3]); 
				L[1]*cos(x1[1]) + L[2]*cos(x1[1]+x1[3]), L[2]*cos(x1[1]+x1[3])
			];
	
	// Accelerations
	tau_s = K_spring*([x2[1]; x2[3]] - [x1[1]; x1[3]]) + D_spring*([x2[2]; x2[4]] - [x1[2]; x1[4]]);
	 
	ddq1 = (1/D)*(tau_s - g - C*[x1[2]; x1[4]] + transpose(Jac)*load);
			
	ddq2 = (1/J)*(u - tau_s);
	
	// 20-sim does not like it when we define elements of the vector x separately, so we can this:	
	x1 = int([	x1[2]; 
					ddq1[1];
					x1[4];
					ddq1[2]
				], x01);
				
	x2 = int([	x2[2]; 
					ddq2[1];
					x2[4];
					ddq2[2]
				], x02);
	
	// You can of course do the same with ddt() for differential form:
	//ddt(x) = [	x[2];
	//				(1/m) * (-sin(x[1]) + port1.T)
	//			];
	
	// Set port variable
	port1.omega = x2[2];
	port2.omega = x2[4];
 	q1_out  = x1[1];
	dq1_out = x1[2];
	q2_out  = x1[3];
	dq2_out = x1[4];implementation_end;
  end;
  connections
   Constant\output -> Mux\input1;
   Constant1\output -> Mux\input2;
   Demux\output1 -> MSe\effort;
   Demux\output2 -> MSe1\effort;
   Imp_contr\u -> Demux\input;
   MSe\p => Pendulum\port1 408 104;
   MSe1\p => Pendulum\port2 408 216;
   Mux\output -> Imp_contr\pos_des;
   Pendulum\dq1_out -> Imp_contr\dq1 344 120 256 120;
   Pendulum\dq2_out -> Imp_contr\dq2 352 200 256 200;
   Pendulum\q1_out -> Imp_contr\q1 352 144 288 144;
   Pendulum\q2_out -> Imp_contr\q2 352 176 288 176;
  end;
 implementation_end;
]]></Sidops>
