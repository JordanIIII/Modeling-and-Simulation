         PI2 -8 136
          description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Control\PID Control\Continuous\PI.emx</LibraryPath>
  <TimeStamp>2008-1-17 10:49:17</TimeStamp>
</Description>';
          type PI
           ports
            signal in error;
            signal out output;
          end;
          icon bg bottom
           figures
            rectangle -24 120 8 152 color 0 fill 15132390;
            text 'PI' -7.5 136.1 color 16711680 18 bold;
          end;
          implementation eq
parameters
	real kp = 100.0 {};			// Proportional gain
	real tauI = 0.1 {s};		// Integral time constant: tauI > 0
variables
	real uP,uI;
equations
	uP = kp * error;
	uI = (kp / tauI) * int (error);
	output = uP + uI;   
     implementation_end;
