      MaxonMotor 256 240
       description '<Information><Description><Version>5.1</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate><LibraryPath>C:\Users\solis\Documents\M-ROB\Q2B\MS\A3\MaxonMotor.emx</LibraryPath><TimeStamp>2026-5-8 10:38:28</TimeStamp></Description></Information>';
       type Submodel
        ports
         signal in Ides;
         power out p2;
