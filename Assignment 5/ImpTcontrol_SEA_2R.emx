    description '<Information><Description><Version>5.1</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate><LibraryPath>C:\Users\solis\Documents\M-ROB\Q2B\MS\A3\MaxonTcontrol.emx</LibraryPath><TimeStamp>2026-5-8 12:40:27</TimeStamp></Description></Information>';
