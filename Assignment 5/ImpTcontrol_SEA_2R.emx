   Dynamics2R 568 160
    description '<Information><Description><Version>5.1</Version><LibraryPath>C:\Users\solis\Documents\M-ROB\Q2B\MS\A5\Dynamics2R.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2026-5-22 09:54:58</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      rotation in port1;
      rotation in port2;
      signal out q [2,1];
      signal out dq [2,1];
     restrictions
      causality fixed in port1;
    end;
    implementation eq
/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/
parameters
	real global grav = 0.0;		// m/s^2
	real x0[4] = [0;0;0;0]; // Initial state
	real global L[2] = [1;1];
	real R[2] = [0.1;0.1];
	real global m[2] = [1,1];
	real m_ee = 0.2; // End effector mass
	real I[2] = [1/12 * (L[1]^2 + 3*R[1]^2) * m[1]; 1/12 * (L[2]^2 + 3*R[2]^2) * m[2]]; // Inertia (cylinders)
	
variables
	real x[4]; // State
	real D[2,2];  // "Mass inertia" matrix
	real Lambda[2,2];
	real h; // Coriolis common term
	real C[2,2]; // Centrifugal and Coriolis matrix (Christoffel?)
	real g[2]; // Gravity matrix
	real u[2]; // Input torques
	real ddq[2]; // Joint accelerations
	real v_ee[2]; // End effector velocities
	real Jac[2,2]; // Jacobian
	real E_arm; // Arm energy
	real E_ee; // End effector energy
	
equations
	// State vector x = [q1, q1_dot, q2, q2_dot];
	// Where q is the angle of the pendulum
	dq = [x[2]; x[4]];
	q = [x[1]; x[3]];
	
	// EULER LAGRANGE 
	// M(q)ddq + C(q,dq)dq + g(q) = u
	
	// Inertia matrix D(q)
	D = [	I[1] + I[2] + m[1]*(L[1]/2)^2 + m[2]*(L[1]^2 + (L[2]/2)^2 + 2*L[1]*(L[2]/2)*cos(x[3])), I[2] + m[2]*((L[2]/2)^2 + L[1]*(L[2]/2)*cos(x[3]));
		  	I[2] + m[2]*((L[2]/2)^2 + L[1]*(L[2]/2)*cos(x[3])), I[2] + m[2]*(L[2]/2)^2
		 	];

	// Centrifugal and Coriolis C(q,dq)
	h = -m[2]*L[1]*(L[2]/2)*sin(x[3]);
	C = [ h*x[4], h*(x[2] + x[4]);
			-h*x[2], 0
			];	
			
	// Gravity g(q)
	g = [	(m[1]*(L[1]/2) + m[2]*L[1])*grav*cos(x[1]) + m[2]*(L[2]/2)*grav*cos(x[1] + x[3]);
			m[2]*(L[2]/2)*grav*cos(x[1] + x[3])
			];
	
	// Input torques
	u = [	port1.T;
			port2.T
			];
	
	// Accelerations
	ddq = (1/D)*(u - g - C*dq);
	
	
	// 20-sim does not like it when we define elements of the vector x separately, so we can this:	
	x = int([	x[2]; 
					ddq[1];
					x[4];
					ddq[2]
				], x0);
				
	// Jacobian	
	Jac = [
				-L[1]*sin(x[1]) - L[2]*sin(x[1]+x[3]), -L[2]*sin(x[1]+x[3]); 
				L[1]*cos(x[1]) + L[2]*cos(x[1]+x[3]), L[2]*cos(x[1]+x[3])
			];
			
	// ee velocities
	v_ee = Jac*dq;
				
	// Energy
	E_arm = 0.5 * transpose(dq) * D * dq;
	E_ee = 0.5 * transpose(v_ee) * m_ee * v_ee;
	
	// You can of course do the same with ddt() for differential form:
	//ddt(x) = [	x[2];
	//				(1/m) * (-sin(x[1]) + port1.T)
	//			];

	// Set port variable
	port1.omega = x[2];
	port2.omega = x[4];
	
	
 implementation_end;
   Imp_contr 208 168
    description '<Information><Description><Version>4.0</Version><LibraryPath>System\Submodel.emx</LibraryPath><TimeStamp>2007-10-31 11:32:54</TimeStamp><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Submodel
     ports
      signal in q [2,1];
      signal in pos_des [2,1] {m} ;
      signal in dq [2,1] {rad} ;
      signal out u [2,1] {N.m} ;
    end;
    implementation eq
parameters
	real global grav;		// m/s^2
	real global L[2];
	real global m[2];
	real K_imp[2,2] = [5,0; 0,5];
	real b_imp[2,2] = [2,0; 0,2];
	
variables
	real J[2,2];  // Jacobian
	real g[2];
	real pos[2];
	real vel[2];
	real F_imp[2];
	
equations
	pos = [
				L[1]*cos(q[1]) + L[2]*cos(q[1]+q[2]); 
				L[1]*sin(q[1]) + L[2]*sin(q[1]+q[2])
			];
			
	J = 	[
				-L[1]*sin(q[1]) - L[2]*sin(q[1]+q[2]), 	-L[2]*sin(q[1]+q[2]);
				L[1]*cos(q[1]) + L[2]*cos(q[1]+q[2]), 		L[2]*cos(q[1]+q[2])
			];
	
	g = 	[	
				(m[1]*(L[1]/2) + m[2]*L[1])*grav*cos(q[1]) + m[2]*(L[2]/2)*grav*cos(q[1] + q[2]);
				m[2]*(L[2]/2)*grav*cos(q[1] + q[2])
			];
			
	vel = J * dq;
	F_imp = K_imp*(pos_des - pos) - b_imp*vel;
		
	u = transpose(J)*F_imp + g;
	// u = [1;1];

	
	implementation_end;
