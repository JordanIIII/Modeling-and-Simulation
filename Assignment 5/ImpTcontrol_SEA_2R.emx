       implementation bg
        submodels
         GearFric 400 320
          description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type R
           ports
            power in p;
          end;
          icon bg ellipse bottom
           figures
            text 'R' 400 320 color 0 18 bold;
          end;
          implementation eq
parameters
    real tau_c = 9.4e-5;     // Coulomb friction torque [Nm] (old 1.0e-4)
    real b = 6.8e-5;        // viscous friction coefficient (old 3.22e-4)
    real k = 50.0;          // smoothing factor
variables
	real P;
equations
    p.e =
        tau_c * tanh(k * p.f)
        + b * p.f;
	P = p.e * p.f;

	
implementation_end;
         GY 200 264
          description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\GY.emx</LibraryPath>
  <TimeStamp>2011-11-29 15:53:45</TimeStamp>
</Description>
</Information>';
          type GY
           ports
            electric in p1;
            power out p2;
           restrictions
            causality constraint equal p1 p2;
          end;
          icon bg ellipse bottom
           figures
            text 'GY_eff' 200 264 color 0 18 bold;
          end;
          implementation eq
parameters
	real r = 53.8e-3;
	real eff = 0.88; 
variables
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p1.e * dyn_eff = r * p2.f;
	p2.e = r * p1.f; //ideal based on torque constant
	dyn_eff = if (sign(p1.e)*sign(p1.f)) >= 0 then eff else 1/eff end;
implementation_end;
         HBridge 32 328
          description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type R
           ports
            power in p;
          end;
          icon bg ellipse bottom
           figures
            text 'R' 32 328 color 0 18 bold;
          end;
          implementation eq
parameters
	real r = 0.3;
variables
	real P;
equations
	p.e = r * p.f;
	P = p.e * p.f;
implementation_end;
         Inductance 168 328
          description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type I
           ports
            power in p;
            signal out state;
           restrictions
            causality preferred in p;
          end;
          icon bg ellipse right
           figures
            text 'I' 168 328 color 0 18 bold;
          end;
          implementation eq
parameters
	real i = 0.513;
equations
    //state = state + p.e*sampletime;
	 state = int(p.e);
    p.f = state / i;
implementation_end;
         MotorLoadInertia 288 200
          description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\I.emx</LibraryPath><TimeStamp>2011-11-29 15:55:55</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
          type I
           ports
            power in p;
            signal out state;
           restrictions
            causality preferred in p;
          end;
          icon bg ellipse right
           figures
            text 'I_max' 288 200 color 0 18 bold;
          end;
          implementation eq
parameters
	real i = 34.7e-7 + 0.8e-7; //motor, gearbox, load
	real lim = 120000/60*2*pi; 	// max rpm
equations
    //state = state + p.e*sampletime;
	 state = int(p.e);
    p.f = if abs(state / i) >= lim then sign(state/i)*lim else state/i end; //max rpm
implementation_end;
