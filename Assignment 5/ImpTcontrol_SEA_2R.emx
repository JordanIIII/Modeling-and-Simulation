</Information>';
       type PD
        ports
         signal in error;
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle 48 224 80 256 color 0 fill 15132390;
         text 'PD' 64.5 240.1 color 16711680 18 bold;
       end;
       implementation eq
parameters
	real kp = 0.0 {};			// Proportional gain
	real kd = 0.01 {}; 		// Derivative gain
variables
	real rate;
equations
