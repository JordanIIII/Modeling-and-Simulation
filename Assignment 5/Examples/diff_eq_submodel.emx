 implementation bg
  submodels
   Constant 136 120
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\Constant.emx</LibraryPath>
  <TimeStamp>2007-10-19 14:48:44</TimeStamp>
</Description>';
    type Constant
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 120.1 104 151.9 136 color 0 fill 15132390;
      line 124.9 115.6 146.9 115.6 color 16711680 width 2;
      line 122.2 126.7 147.9 126.7 color 0;
      line 124.5 110.7 124.5 129 color 0;
    end;
    implementation eq
parameters
	real C = 0.1;		// output value
equations
	if time>1 then
		output = C;
	else
		output = 0;
	end;
     implementation_end;
   MSe 208 120
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\MSe.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:12:33</TimeStamp>
</Description>
</Information>';
    type MSe
     ports
      power out p;
      signal in effort;
     restrictions
      causality fixed out p;
    end;
    icon bg ellipse bottom
     figures
      text 'MSe' 208 120 color 0 18 bold;
    end;
    implementation eq
variables
	real flow;
equations
	p.e = effort;
	flow = p.f;
implementation_end;
   Pendulum 344 120
    description '<Information><Description><Version>4.0</Version><LibraryPath>Template\Submodel-Equation.emx</LibraryPath><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><TimeStamp>2007-11-1 22:32:1</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'Submodel-Equation'
     ports
      rotation in port1;
     restrictions
      causality fixed in port1;
    end;
    implementation eq
/* Equation Submodel
Enter your equations here. You can use the Toolbar buttons at the top ( Add , f(x) etc. ).
*/
parameters
	real x0[2] = [0;0]; // Initial state
	real m = 1; // Inertia
	
variables
	real x[2]; // State
	
equations
	// State vector x = [q, q_dot];
	// Where q is the angle of the pendulum
	
	// Dynamics written in differential form
	//ddt(x[1]) = x[2];
	//ddt(x[2]) = -sin(x[1]) + port1.T;
	
	// Dynamics written in integral form
	// Note the addition of initial state
	//x[1] = int(x[2], x0[1]);
	//x[2] = int(-sin(x[1]) + port1.T, x0[2]);
	
	// 20-sim does not like it when we define elements of the vector x separately, so we can this:	
	x = int([	x[2]; 
					(1/m) * (-sin(x[1]) + port1.T)
				], x0);
	
	// You can of course do the same with ddt() for differential form:
	//ddt(x) = [	x[2];
	//				(1/m) * (-sin(x[1]) + port1.T)
	//			];
	
	// Set port variable
	port1.omega = x[2];
 implementation_end;
   QSensor1 264 119.9
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\QSensor.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:34:15</TimeStamp>
</Description>
</Information>';
    knot QSensor
     ports
      power knot in p1 [1];
      rotation knot out p2 [1];
      signal knot out q [1];
     restrictions
      causality constraint not_equal p1 p2;
    end;
    icon bg ellipse
     figures
      ellipse 257.1 112.9 270.9 127 color 0 fill 16777215;
      text 'q' 263.5 117.2 color 0;
    end;
    implementation eq
equations
	p2.f = p1.f;
	p1.e = p2.e;
	q = int (p1.f);
implementation_end;
  end;
  connections
   Constant\output -> MSe\effort;
   MSe\p => QSensor1\p1;
   QSensor1\p2 => Pendulum\port1;
  end;
 implementation_end;
]]></Sidops>
