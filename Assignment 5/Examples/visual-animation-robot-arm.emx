 type Mainmodel
 end;
 implementation bg
  submodels
   Cosine 232 288
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\WaveGenerator-Cosine.emx</LibraryPath>
  <TimeStamp>2007-9-27 16:10:5</TimeStamp>
</Description>';
    type 'WaveGenerator-Cosine'
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 216 272 248 304 color 0 fill 15132390;
      spline 217.3 287.4 220.5 279.3 223.7 287.4 227 295.6 230.1 287.4 233.2 279.3 236.5 287.4 240.1 295.7 243.3 287.8 color 16711680;
      rectangle 216.9 278.1 220.5 293 color -1 fill 15132390;
      line 246.1 288 217.3 288 color 0;
      line 219.4 278.4 219.4 297.6 color 0;
    end;
    implementation eq
parameters
	real amplitude = 1.0;			// amplitude of the wave
	real omega = 1 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half);

	"calculate the cosine wave"
	output = amplitude * cos (omega * time);
implementation_end;
   q1 312 208
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Block Diagram\SignalMonitor.emx</LibraryPath><TimeStamp>2007-9-26 12:14:4</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
