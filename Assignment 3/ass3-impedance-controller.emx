      stiffness 16 88
       description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Block Diagram\Gain.emx</LibraryPath><TimeStamp>2007-9-26 12:15:12</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type Gain
        ports
         signal in input;
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle 0.1 72 31.9 104 color 0 fill 15132390;
         text 'K' 16 88 color 16711680 16 bold;
       end;
       implementation eq
parameters
	real global impedance_stiffness;
equations
	output = impedance_stiffness * input;
    implementation_end;
     end;
     connections
      Attenuate1\output -> MSe\effort;
      damping\output -> PlusMinus2\plus;
      Differentiate\output -> damping\input;
      LPF\output -> Attenuate1\input;
      MSe\p => QSensor1\p1;
      PlusMinus1\output -> Splitter3\input 48 0 -32 0;
      PlusMinus2\output -> LPF\input;
      q_set -> PlusMinus1\plus;
      QSensor1\p2 => p2;
      QSensor1\q -> PlusMinus1\minus 976 -40;
      Splitter1\output -> Differentiate\input -32 136;
      Splitter1\output -> dq\input -32 232;
      Splitter3\output -> Splitter1\input;
      Splitter3\output -> stiffness\input;
      stiffness\output -> PlusMinus2\plus 104 88;
     end;
     figures
      rectangle -48 64 120 200 color 0 fill 15980262;
      rectangle 136 -16 952 424 color 255 width 5;
      text 'work inside this area (or at least leave the things outside the box in place)' 680 408 color 255 21;
      text 'your mission, should you choose to accept it, 
is to replace this MSe (and the LPF & 1/K)
with a realistic motor-series-elastics drivetrain' 416 224 color 16711935 21;
      line 336 184 304 160 color 16711935 end;
      text 'you may want to use the signals (q_set, q_measured, dq) in your actuator' 560 56 color 32768 21;
      line 640 40 696 -32 color 32768 end;
      line 552 48 504 24 160 8 -8 -32 color 32768 end;
      line 688 72 664 88 184 72 48 8 color 32768 end;
      text 'impedance control law' 40 184 color 8388736 16;
    implementation_end;
  end;
  connections
   Disturbance\position -> MultiplyDivide\multiply;
   DisturbanceAmplitude\output -> MultiplyDivide\multiply;
   imp_stiffness\output -> expected_stiffness_dq\input;
   impedance_control_perfect\p2 => OneJunction1\p;
   MSe\p => OneJunction\p;
   MSe1\p => OneJunction1\p;
   MSe2\p => OneJunction2\p;
   MultiplyDivide\output -> Splitter2\input;
   MultiplyDivide2\output -> physical\v_set;
   MultiplyDivide3\output -> Splitter3\input;
   OneJunction\p => I\p;
   OneJunction1\p => I1\p;
   OneJunction2\p => I2\p;
   physical\p2 => OneJunction\p;
   PositionSetpoint\position -> MultiplyDivide3\multiply;
   PositionSetpoint\velocity -> MultiplyDivide2\multiply;
   SetpointAmplitude\output -> Splitter1\input;
   Splitter1\output -> MultiplyDivide2\multiply;
   Splitter1\output -> MultiplyDivide3\multiply;
   Splitter2\output -> imp_stiffness\input;
   Splitter2\output -> MSe\effort;
   Splitter2\output -> MSe1\effort;
   Splitter2\output -> MSe2\effort;
   Splitter3\output -> impedance_control_perfect\q_set;
   Splitter3\output -> physical\q_set;
   Splitter3\output -> your_impedance_controller\q_set;
   your_impedance_controller\p2 => OneJunction2\p;
  end;
  figures
   line 304 376 248 416 color 2763429 start;
   text 'impedance control parameters inside "physical" block' 272 8 color 128 16;
   line 328 88 352 24 color 2763429 start;
   text 'put your model (series elastic impedance control) in here' 192 432 color 128 16;
 implementation_end;
