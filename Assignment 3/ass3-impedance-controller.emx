   Disturbance 744 120
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Sources\MotionProfileWizard.emx</LibraryPath><TimeStamp>2007-12-19 14:33:18</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'MotionProfile-Wizard'
     ports
      signal out position;
    end;
    icon bg bottom
     figures
      group
       rectangle 728 104 760 136 color 0 fill 15132390;
       group
        group
         rectangle 739.3 113.1 752.8 130.5 color -1 fill 8454143;
         line 739.1 113.2 739.1 130.6 color 0;
         line 752.2 113.1 752.2 130.5 color 0;
         spline 739.5 129.7 742.4 127.5 746.2 120.5 748.7 116.3 752.2 114.7 color 16711680;
         line 752 114.7 758.1 114.7 color 16711680;
         line 733.2 129.8 740.1 129.8 color 16711680;
        end;
       end;
       line 733.1 109.8 733.1 134 color 0;
       line 729.7 130.5 758.6 130.5 color 0;
      end;
    end;
    implementation eq
// 20-sim User Editor
// MotionProfileWizard.dll
parameters
	real hidden period = 60;	// the total period of all regions
	real hidden totalStroke = 0;
	integer nrTimes = 1;

variables
	real hidden fu;
	real hidden offsetTime, modTime, divTime;
	real hidden stroke;
	real hidden duration;
	real hidden normalizedRegionTime;
	real hidden runningTime;
	integer hidden localProfileCounter;
	integer hidden region;
	integer hidden ProfileCounter;

	real hidden globalStrokeOffset;
	real hidden localStrokeOffset;

	// dll-variables
	real hidden dllInput;

	real hidden dllOutput[3];

	boolean change1;
	boolean change2;
	boolean change3;
	boolean change4;
	boolean change5;
	boolean change6;
	boolean change7;
	boolean change8;
	boolean change9;
	boolean change10;
	boolean change11;
	boolean change12;

initialequations

	fu = 0.0;
	offsetTime = 0.0;
	modTime = 0.0;
	region = 0;
	stroke = 1.0;
	duration = 1.0;

	dllInput = 0.0;

	dllOutput = 0.0;

			change1 = false;
			change2 = false;
			change3 = false;
			change4 = false;
			change5 = false;
			change6 = false;
			change7 = false;
			change8 = false;
			change9 = false;
			change10 = false;
			change11 = false;
			change12 = false;

	modTime = 0.0;
	divTime = 0.0;
	offsetTime = 0.0;	

	globalStrokeOffset = 0.0;
	position = 0;
	localStrokeOffset = 0;
	normalizedRegionTime = 1.0;

	runningTime = 0.0;
	ProfileCounter = 1;
	localProfileCounter = 1;
	
code

		runningTime = time - offsetTime;
		modTime = runningTime mod period;
		divTime = runningTime div period;
		localProfileCounter = 1 + round(divTime);

		if localProfileCounter <= nrTimes then
			ProfileCounter = localProfileCounter;
			change1 = frequencyevent(period, 0);
			change2 = frequencyevent(period, 30);
			change3 = frequencyevent(period, 31);
			change4 = frequencyevent(period, 33);
			change5 = frequencyevent(period, 34);
			change6 = frequencyevent(period, 36);
			change7 = frequencyevent(period, 37);
			change8 = frequencyevent(period, 38);
			change9 = frequencyevent(period, 39);
			change10 = frequencyevent(period, 40);
			change11 = frequencyevent(period, 41);
			change12 = frequencyevent(period, 42);

			globalStrokeOffset = divTime * totalStroke;
			// determine in which region we are
			if modTime < 30 then
				region = 1;
				normalizedRegionTime = modTime / 30;
			else
				if modTime < 31 then
					region = 2;
					normalizedRegionTime = modTime - 30;
				else
					if modTime < 33 then
						region = 3;
						normalizedRegionTime = ( modTime - 31) / 2;
					else
						if modTime < 34 then
							region = 4;
							normalizedRegionTime = modTime - 33;
						else
							if modTime < 36 then
								region = 5;
								normalizedRegionTime = ( modTime - 34) / 2;
							else
								if modTime < 37 then
									region = 6;
									normalizedRegionTime = modTime - 36;
								else
									if modTime < 38 then
										region = 7;
										normalizedRegionTime = modTime - 37;
									else
										if modTime < 39 then
											region = 8;
											normalizedRegionTime = modTime - 38;
										else
											if modTime < 40 then
												region = 9;
												normalizedRegionTime = modTime - 39;
											else
												if modTime < 41 then
													region = 10;
													normalizedRegionTime = modTime - 40;
												else
													if modTime < 42 then
														region = 11;
														normalizedRegionTime = modTime - 41;
													else
														region = 12;
														normalizedRegionTime = ( modTime - 42) / 18;
													end;
												end;
											end;
										end;
									end;
								end;
							end;
						end;
					end;
				end;
			end;

			switch(region)

				case 1 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 30;

				case 2 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0;
					stroke = 1;
					duration = 1;

				case 3 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 1;
					stroke = 0;
					duration = 2;

				case 4 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 1;
					stroke = 0;
					duration = 1;

				case 5 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 1;
					stroke = -1;
					duration = 2;

				case 6 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 1;

				case 7 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0;
					stroke = -1;
					duration = 1;

				case 8 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = -1;
					stroke = 1;
					duration = 1;

				case 9 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 1;

				case 10 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0;
					stroke = 2;
					duration = 1;

				case 11 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 2;
					stroke = -2;
					duration = 1;

				case 12 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 18;

			end;

			fu = dllOutput[1];

			position = (globalStrokeOffset + localStrokeOffset) + stroke * fu;
		end; //nrTimes
implementation_end;
