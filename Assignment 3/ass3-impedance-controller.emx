      LPF 192 128
       description '<Information><Description><Version>4.1</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Filters\LowPassFilter-FO.emx</LibraryPath><TimeStamp>2012-10-10 13:06:47</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type 'LowPassFilter-FO'
        ports
         signal in input;
         signal out output;
       end;
       icon bg bottom
        figures
         rectangle 176 112 208 144 color 0 fill 15132390;
         text 'LPF' 192.5 120.7 color 16711680 14;
         text 'FO' 192.5 134.6 color 16711680 14;
       end;
       implementation eq
parameters
	real BW = 2 {Hz};		// Bandwidth
	real initial = 0.0;		// initial value of the output
variables
   real hidden rate, w;
	real state;
equations
	w = twopi*BW;
    rate = (input - state) * w;
    state = int (rate, initial);
    output = state;                    implementation_end;
      MSe 296 128
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\MSe.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:12:33</TimeStamp>
</Description>
</Information>';
       type MSe
        ports
         power out p;
         signal in effort;
        restrictions
         causality fixed out p;
       end;
       icon bg ellipse bottom
        figures
         text 'MSe' 296 128 color 0 18 bold;
       end;
       implementation eq
variables
	real flow;
equations
	p.e = effort;
	flow = p.f;
implementation_end;
      plug q_set -24 -40;
      plug p2 1014.9 128;
      PlusMinus1 48 -40
       description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\PlusMinus.emx</LibraryPath>
  <TimeStamp>2007-9-27 10:15:13</TimeStamp>
</Description>';
       knot PlusMinus
        ports
         signal knot duplicatable in plus [1];
         signal knot duplicatable in minus [1];
         signal knot out output [1];
       end;
       icon bg ellipse
        figures
         ellipse 40 -48 56 -32 color 0 fill 16777215;
       end;
       implementation eq
equations
    output = sum (collect (plus)) - sum (collect (minus));
    implementation_end;
      PlusMinus2 104 128
       description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Block Diagram\PlusMinus.emx</LibraryPath>
  <TimeStamp>2007-9-27 10:15:13</TimeStamp>
</Description>';
       knot PlusMinus
        ports
         signal knot duplicatable in plus [1];
         signal knot duplicatable in minus [1];
         signal knot out output [1];
       end;
       icon bg ellipse
        figures
         ellipse 96 120 112 136 color 0 fill 16777215;
       end;
       implementation eq
equations
    output = sum (collect (plus)) - sum (collect (minus));
    implementation_end;
      QSensor1 976 127.9
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\QSensor.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:34:15</TimeStamp>
</Description>
</Information>';
       knot QSensor
        ports
         power knot in p1 [1];
         power knot out p2 [1];
         signal knot out q [1];
        restrictions
         causality constraint not_equal p1 p2;
       end;
       icon bg ellipse
        figures
         ellipse 969.1 120.9 982.9 135 color 0 fill 16777215;
         text 'q' 975.5 125.2 color 0;
       end;
       implementation eq
equations
	p2.f = p1.f;
	p1.e = p2.e;
	q = int (p1.f);
implementation_end;
      Splitter1 -32 136
       description '<Description><Version>4.0</Version>
   <LibraryPath>Signal\Block Diagram\Splitter.emx</LibraryPath>
  <TimeStamp>2008-01-17 11:28:29</TimeStamp>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
</Description>';
       knot Splitter
        ports
         signal knot duplicatable out output [1];
         signal knot in input [1];
       end;
       icon bg ellipse
        figures
         ellipse -35.2 132.8 -28.8 139.2 color -1 fill 0;
         ellipse -36.3 131.7 -27.7 140.3 color -1;
        terminals
         input -32 136 fixed;
       end;
       implementation eq
equations
    collect (output) = input;
implementation_end;
      Splitter3 -32 88
       description '<Description><Version>4.0</Version>
   <LibraryPath>Signal\Block Diagram\Splitter.emx</LibraryPath>
  <TimeStamp>2008-01-17 11:28:29</TimeStamp>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
</Description>';
       knot Splitter
