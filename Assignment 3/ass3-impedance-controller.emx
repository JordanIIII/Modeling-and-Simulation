   PositionSetpoint 8 120
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Sources\MotionProfileWizard.emx</LibraryPath><TimeStamp>2007-12-19 14:33:18</TimeStamp><AllowLibraryUpdate>False</AllowLibraryUpdate></Description></Information>';
    type 'MotionProfile-Wizard'
     ports
      signal out position;
      signal out velocity;
    end;
    icon bg bottom
     figures
      group
       rectangle -8 104 24 136 color 0 fill 15132390;
       group
        group
         rectangle 3.3 113.1 16.8 130.5 color -1 fill 8454143;
         line 3.1 113.2 3.1 130.6 color 0;
         line 16.2 113.1 16.2 130.5 color 0;
         spline 3.5 129.7 6.4 127.5 10.2 120.5 12.7 116.3 16.2 114.7 color 16711680;
         line 16 114.7 22.1 114.7 color 16711680;
         line -2.8 129.8 4.1 129.8 color 16711680;
        end;
       end;
       line -2.9 109.8 -2.9 134 color 0;
       line -6.3 130.5 22.6 130.5 color 0;
      end;
    end;
    implementation eq
// 20-sim User Editor
// MotionProfileWizard.dll
parameters
	real hidden period = 60;	// the total period of all regions
	real hidden totalStroke = 0;
	integer nrTimes = 1;

variables
	real hidden fu;
	real hidden dfu;
	real hidden offsetTime, modTime, divTime;
	real hidden stroke;
	real hidden duration;
	real hidden normalizedRegionTime;
	real hidden runningTime;
	integer hidden localProfileCounter;
	integer hidden region;
	integer hidden ProfileCounter;

	real hidden globalStrokeOffset;
	real hidden lastposition;
	real hidden localStrokeOffset;

	// dll-variables
	real hidden dllInput;

	real hidden dllOutput[3];

	boolean change1;
	boolean change2;
	boolean change3;
	boolean change4;
	boolean change5;
	boolean change6;
	boolean change7;
	boolean change8;
	boolean change9;
	boolean change10;
	boolean change11;
	boolean change12;

initialequations

	fu = 0.0;
	dfu = 0.0;
	offsetTime = 0.0;
	modTime = 0.0;
	region = 0;
	stroke = 1.0;
	duration = 1.0;

	dllInput = 0.0;

	dllOutput = 0.0;

			change1 = false;
			change2 = false;
			change3 = false;
			change4 = false;
			change5 = false;
			change6 = false;
			change7 = false;
			change8 = false;
			change9 = false;
			change10 = false;
			change11 = false;
			change12 = false;

	modTime = 0.0;
	divTime = 0.0;
	offsetTime = 0.0;	

	globalStrokeOffset = 0.0;
	position = 0;
	velocity = 0.0;
	localStrokeOffset = 0;
	normalizedRegionTime = 1.0;

	runningTime = 0.0;
	ProfileCounter = 1;
	localProfileCounter = 1;
	
	lastposition = 0.0;
code

		runningTime = time - offsetTime;
		modTime = runningTime mod period;
		divTime = runningTime div period;
		localProfileCounter = 1 + round(divTime);

		if localProfileCounter <= nrTimes then
			ProfileCounter = localProfileCounter;
			change1 = frequencyevent(period, 0);
			change2 = frequencyevent(period, 10);
			change3 = frequencyevent(period, 12);
			change4 = frequencyevent(period, 15);
			change5 = frequencyevent(period, 17);
			change6 = frequencyevent(period, 18);
			change7 = frequencyevent(period, 18.5);
			change8 = frequencyevent(period, 19);
			change9 = frequencyevent(period, 19.5);
			change10 = frequencyevent(period, 22);
			change11 = frequencyevent(period, 22.5);
			change12 = frequencyevent(period, 23);

			globalStrokeOffset = divTime * totalStroke;
			// determine in which region we are
			if modTime < 10 then
				region = 1;
				normalizedRegionTime = modTime / 10;
			else
				if modTime < 12 then
					region = 2;
					normalizedRegionTime = ( modTime - 10) / 2;
				else
					if modTime < 15 then
						region = 3;
						normalizedRegionTime = ( modTime - 12) / 3;
					else
						if modTime < 17 then
							region = 4;
							normalizedRegionTime = ( modTime - 15) / 2;
						else
							if modTime < 18 then
								region = 5;
								normalizedRegionTime = modTime - 17;
							else
								if modTime < 18.5 then
									region = 6;
									normalizedRegionTime = ( modTime - 18) / 0.5;
								else
									if modTime < 19 then
										region = 7;
										normalizedRegionTime = ( modTime - 18.5) / 0.5;
									else
										if modTime < 19.5 then
											region = 8;
											normalizedRegionTime = ( modTime - 19) / 0.5;
										else
											if modTime < 22 then
												region = 9;
												normalizedRegionTime = ( modTime - 19.5) / 2.5;
											else
												if modTime < 22.5 then
													region = 10;
													normalizedRegionTime = ( modTime - 22) / 0.5;
												else
													if modTime < 23 then
														region = 11;
														normalizedRegionTime = ( modTime - 22.5) / 0.5;
													else
														region = 12;
														normalizedRegionTime = ( modTime - 23) / 37;
													end;
												end;
											end;
										end;
									end;
								end;
							end;
						end;
					end;
				end;
			end;

			switch(region)

				case 1 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 10;

				case 2 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0;
					stroke = 1;
					duration = 2;

				case 3 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 1;
					stroke = 0;
					duration = 3;

				case 4 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 1;
					stroke = -1;
					duration = 2;

				case 5 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 1;

				case 6 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0;
					stroke = -1;
					duration = 0.5;

				case 7 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = -1;
					stroke = 0;
					duration = 0.5;

				case 8 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = -1;
					stroke = 1;
					duration = 0.5;

				case 9 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 2.5;

				case 10 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 0;
					stroke = 2;
					duration = 0.5;

				case 11 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileSine', dllInput);

					localStrokeOffset = 2;
					stroke = -2;
					duration = 0.5;

				case 12 do
					dllInput = normalizedRegionTime;
					dllOutput = dll('MotionProfiles.dll', 'ProfileFlat', dllInput);

					localStrokeOffset = 0;
					stroke = 0;
					duration = 37;

			end;

			fu = dllOutput[1];
			dfu = dllOutput[2];

			position = (globalStrokeOffset + localStrokeOffset) + stroke * fu;
			lastposition = position;
			velocity = dfu * stroke / duration;
		else
			position = lastposition;
			velocity = 0.0;
		end; //nrTimes
implementation_end;
