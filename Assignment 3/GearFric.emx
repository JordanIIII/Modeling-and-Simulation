      TF 448 264
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\TF.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:43:47</TimeStamp>
</Description>
</Information>';
       type TF
        ports
         power in p1;
         power out p2;
         signal in Pin;
        restrictions
         causality constraint not_equal p1 p2;
       end;
       icon bg ellipse bottom
        figures
         text 'TF' 448 264 color 0 18 bold;
       end;
       implementation eq
parameters
	real r = 1/33;
variables
	real eff;
	real efftest;
initialequations
	eff = 1.0;
	efftest = 1.0;
equations
	p1.e = r * p2.e;
	p2.f = r * p1.f;
	// efficiency check
	if Pin <> 0 then
		eff = if Pin >= 0 then
			max(min((p2.e*p2.f)/(Pin),1.0),0.0)
		else
			max(min(Pin/(p1.e*p1.f),1.0),0.0)
		end;
	else 
		eff = 1.0;
	end;
	efftest = int(max(min(eff,1.0),0.0))/(time+1e-5);implementation_end;
     end;
     connections
      GearFric\p <= OneJunction3\p;
      GY\p2 => OneJunction1\p;
      Ides -> PlusMinus1\plus;
      MSe\p => OneJunction\p;
      OneJunction\flow -> PlusMinus1\minus;
      OneJunction\p => GY\p1;
      OneJunction\p => HBridge\p;
      OneJunction\p => Inductance\p;
      OneJunction\p => R\p;
      OneJunction1\p => MotorLoadInertia\p;
      OneJunction3\p <= PowerSensorIn\p2;
      OneJunction3\p => TF\p1;
      PI2\output -> MSe\effort;
      PlusMinus1\output -> PI2\error;
      PowerSensorIn\P -> TF\Pin 344 224 448 224;
      PowerSensorIn\p1 <= OneJunction1\p;
      PowerSensorIn1\p2 => p2;
      TF\p2 => PowerSensorIn1\p1;
     end;
    implementation_end;
