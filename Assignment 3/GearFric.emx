    knot Splitter
     ports
      signal knot duplicatable out output [1];
      signal knot in input [1];
    end;
    icon bg ellipse
     figures
      ellipse -67.2 236.8 -60.8 243.2 color -1 fill 0;
      ellipse -68.3 235.7 -59.7 244.3 color -1;
     terminals
      input -64 240 fixed;
    end;
    implementation eq
equations
    collect (output) = input;
implementation_end;
   Tspring 256 88
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Block Diagram\Gain.emx</LibraryPath><TimeStamp>2007-9-26 12:15:12</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type Gain
     ports
      signal in input;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 240.1 72 271.9 104 color 0 fill 15132390;
      text 'K' 256 88 color 16711680 16 bold;
    end;
    implementation eq
parameters
	real global k;		// spring stiffness
equations
	output = k * input;
    implementation_end;
   WaveGenerator2 608 240
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\WaveGenerator-Sine.emx</LibraryPath>
  <TimeStamp>2007-9-27 16:12:6</TimeStamp>
</Description>';
    type 'WaveGenerator-Sine'
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      group
       rectangle 592 224 624 256 color 0 fill 15132390;
       line 596.5 230.4 596.5 249.6 color 0;
       line 622.1 240 593.3 240 color 0;
       spline 596.9 239.9 600.1 231.8 603.3 239.9 606.6 248 609.7 239.9 612.8 231.8 616.1 239.9 619.6 248.2 622.8 240.2 color 16711680;
      end;
    end;
    implementation eq
parameters
	real amplitude = 10.5;			// amplitude of the wave
	real omega = 3.0 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * sin ( omega * time);
implementation_end;
   WaveGenerator3 -112 240
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\WaveGenerator-Sine.emx</LibraryPath>
  <TimeStamp>2007-9-27 16:12:6</TimeStamp>
</Description>';
    type 'WaveGenerator-Sine'
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      group
       rectangle -128 224 -96 256 color 0 fill 15132390;
       line -123.5 230.4 -123.5 249.6 color 0;
       line -97.9 240 -126.7 240 color 0;
       spline -123.1 239.9 -119.9 231.8 -116.7 239.9 -113.4 248 -110.3 239.9 -107.2 231.8 -103.9 239.9 -100.4 248.2 -97.2 240.2 color 16711680;
      end;
    end;
    implementation eq
parameters
	real amplitude = 3.0;			// amplitude of the wave
	real omega = 1.0 {rad/s};		// angular frequency of the wave
variables
	boolean hidden change;
	real hidden half;
equations
	"calculate at least 2 points per cycle to get a triangle"
	half = pi / omega;
	change = frequencyevent (half, half / 2);

	"calculate the sine wave"
	output = amplitude * sin ( omega * time);
implementation_end;
   ZeroJunction1 376 240
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\ZeroJunction.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:45:16</TimeStamp>
</Description>
</Information>';
    knot ZeroJunction
     ports
      rotation knot duplicatable none p [1];
      signal knot out effort [1];
     restrictions
      causality constraint one_in p;
    end;
    icon bg ellipse
     figures
      text '0' 376 240 color 0 18 bold;
    end;
    implementation eq
equations
	sum (direct (p.f)) = 0;
	equal (collect (p.e));
	effort = first (p.e);
implementation_end;
  end;
  connections
   C1\state -> Tspring\input 376 88;
   dQspring\p2 => C1\p;
   Feedforward\output -> PlusMinus1\plus;
   FlowSensor1\p2 => Q\p1;
   MaxonMotor\p2 => ZeroJunction1\p;
   MSe2\effort <- SignalGenerator1\output;
   MSe2\p => OneJunction2\p;
   OneJunction2\p => FlowSensor1\p1;
   PD1\output -> PlusMinus1\plus;
   PlusMinus1\output -> MaxonMotor\Ides;
   PlusMinus2\output -> PD1\error;
   Q\p2 => Load\p;
   Splitter1\output -> Feedforward\input -64 312;
   Splitter1\output -> PlusMinus2\plus;
   Tspring\output -> PlusMinus2\minus -16 88;
   WaveGenerator3\output -> Splitter1\input;
   ZeroJunction1\p => dQspring\p1;
   ZeroJunction1\p => OneJunction2\p;
  end;
 implementation_end;
]]></Sidops>
