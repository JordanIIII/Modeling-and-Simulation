   PD1 64 240
    description '<Description>
 <Version>4.0</Version>
 <IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Control\PID Control\Continuous\PD.emx</LibraryPath>
  <TimeStamp>2008-1-17 10:49:7</TimeStamp>
</Description>';
    type PD
     ports
      signal in error;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 48 224 80 256 color 0 fill 15132390;
      text 'PD' 64.5 240.1 color 16711680 18 bold;
    end;
    implementation eq
parameters
	real kp = 1.352 {};			// Proportional gain
	real tauD = 7.54 {s};		// Derivative time constant: tauD > 0
	real beta = 0.098 {};		// Tameness constant: 0 < beta << 1
variables
	real state, rate;
equations
	rate = (kp * error - output) / (beta * tauD);
	state = int (rate);
	output = state + kp * error /  beta;
      implementation_end;
