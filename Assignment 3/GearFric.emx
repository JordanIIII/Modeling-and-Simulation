      GearFric 400 312
       description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
       type R
        ports
         power in p;
       end;
       icon bg ellipse bottom
        figures
         text 'R' 400 312 color 0 18 bold;
       end;
       implementation eq
parameters
    real tau_c = 1.31e-4;     // Coulomb friction torque [Nm]
    real b = 1e-3;        // viscous friction coefficient
    real k = 50.0;          // smoothing factor
variables
	real P;
equations
    p.e =
        tau_c * tanh(k * p.f)
        + b * p.f;
	P = p.e * p.f;

	
implementation_end;
      GY 200 264
       description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\GY.emx</LibraryPath>
  <TimeStamp>2011-11-29 15:53:45</TimeStamp>
</Description>
</Information>';
       type GY
        ports
         electric in p1;
         power out p2;
        restrictions
         causality constraint equal p1 p2;
       end;
       icon bg ellipse bottom
        figures
         text 'GY_eff' 200 264 color 0 18 bold;
       end;
       implementation eq
parameters
	real r = 53.8e-3;
	real eff = 0.88; 
variables
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p1.e * dyn_eff = r * p2.f;
	p2.e = r * p1.f; //ideal based on torque constant
	dyn_eff = if (sign(p1.e)*sign(p1.f)) >= 0 then eff else 1/eff end;
implementation_end;
