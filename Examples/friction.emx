 implementation bg
  submodels
   I 176 96
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\I.emx</LibraryPath>
  <TimeStamp>2011-11-29 15:55:55</TimeStamp>
</Description>
</Information>';
    type I
     ports
      power in p;
      signal out state;
     restrictions
      causality preferred in p;
    end;
    icon bg ellipse bottom
     figures
      text 'I' 176 96 color 0 18 bold;
    end;
    implementation eq
parameters
	real i = 1;
equations
    state = int(p.e);
    p.f = state / i;
implementation_end;
   MSe 88.1 32
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\MSe.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:12:33</TimeStamp>
</Description>
</Information>';
    type MSe
     ports
      power out p;
      signal in effort;
     restrictions
      causality fixed out p;
    end;
    icon bg ellipse bottom
     figures
      text 'MSe' 88.1 32 color 0 18 bold;
    end;
    implementation eq
variables
	real flow;
equations
	p.e = effort;
	flow = p.f;
implementation_end;
   OneJunction1 176 32
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\OneJunction.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:17:51</TimeStamp>
</Description>
</Information>';
    knot OneJunction
     ports
      power knot duplicatable none p [1];
      signal knot out flow [1];
     restrictions
      causality constraint one_out p;
    end;
    icon bg ellipse
     figures
      text '1' 176 32 color 0 18 bold;
    end;
    implementation eq
equations
	sum (direct (p.e)) = 0;
	equal (collect (p.f));
	flow = first (p.f);
implementation_end;
   OneTriangleWave 8 32
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Sources\One.emx</LibraryPath><TimeStamp>2007-9-27 15:54:39</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type One
     ports
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle -7.9 16 23.9 48 color 0 fill 15132390;
      text '1' 8 32 color 16711680 18 bold;
    end;
    implementation eq
parameters
	real slope = 1;
	real t_ramp = 1;
code
	output = 0;
	if time < t_ramp then // Up
		output = slope * time;
	end;
	if time >= t_ramp and time < 2*t_ramp then // Down
		output = slope*t_ramp - slope*(time-t_ramp);
	end;
	if time >= 2*t_ramp then // Zero after
		output = 0;
	end;
   implementation_end;
   R 248 32
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\R.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:35:37</TimeStamp>
</Description>
</Information>';
    type R
     ports
      power in p;
    end;
    icon bg ellipse bottom
     figures
      text 'R' 248 32 color 255 18 bold;
    end;
    implementation eq
parameters
	real dv = 0.1;
	real dc = 0.1;
equations
	p.e = dc * sign(p.f) + dv * p.f;
	//p.e = dc * tanh(5000*p.f) + dv * p.f;
implementation_end;
  end;
  connections
   MSe\p => OneJunction1\p;
   OneJunction1\p => I\p;
   OneJunction1\p => R\p;
   OneTriangleWave\output -> MSe\effort;
  end;
  figures
   text '(Double click for full instructions) 

Try running this with the naive implementation using sign(), 
and then with the tanh(),using different steepness values.

Simultaneously, compare how different integrators behave
(e.g. BDF, RK4, Euler..)' 472 64 color 0 16;
 implementation_end;
]]></Sidops>
