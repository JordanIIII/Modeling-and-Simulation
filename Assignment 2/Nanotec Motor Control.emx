   p_out 192 512.8 fixed;
 end;
 implementation eq
parameters
	real i = 10.0 {};					// gearbox ratio
	real eff = 0.97 {};					// gearbox efficiency (0 < eff <= 1)
	real J = 1.0e-5 {kg.m2/rad};		// rotational inertia
variables
	real p_in_T;
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p_in.omega = (1/J)*int(p_in.T - p_in_T);
	p_out.T = p_in_T*i*dyn_eff;
	p_out.omega = p_in.omega/i;
	dyn_eff = if (sign(dly(p_in_T,0.0))*sign(dly(p_in.omega,0.0))) >= 0 then eff else 1/eff end;
implementation_end;
specification_end;
			end;
  end;
