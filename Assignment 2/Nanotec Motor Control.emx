      signal in error;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 176 120 208 152 color 0 fill 15132390;
      text 'PID' 192 135.5 color 1336868 18 bold;
    end;
    implementation eq
parameters
	real kp = 1.0 {};			// Proportional gain
	real tauD = 1.0 {s};		// Derivative time constant: tauD > 0
	real beta = 0.1 {};		// Tameness constant: 0 < beta << 1
	real tauI = 1.0 {s};		// Integral time constant: tauI > 0
variables
	real hidden factor,uD,uI;
equations
	factor = 1 / ( sampletime + tauD * beta );
	uD = factor * ( tauD * previous ( uD ) * beta + tauD * kp * ( error - previous ( error )) + sampletime * kp * error );
	uI = previous( uI ) +  sampletime * uD / tauI;
	output = uI + uD;implementation_end;
