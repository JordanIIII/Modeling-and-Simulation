   Current 64 136
    description '<Information><Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Signal\Control\PID Control\Discrete\PI.emx</LibraryPath><TimeStamp>2007-9-27 14:49:39</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type PI
     ports
      signal out output;
      signal in error;
    end;
    icon bg top
     figures
      rectangle 48 120 80 152 color 0 fill 15132390;
      text 'PI' 64 136 color 1336868 18 bold;
    end;
    implementation eq
parameters
	real kp = 1.9756 {};			// Proportional gain
	real tauI = 8.03 {s};		// Integral time constant: tauI > 0
variables
	real bi;
	real uP;
	real uI;
equations
	bi = kp*sampletime / tauI;
	uP = kp * error;
	uI = previous(uI) + bi*error;
	output = uP+uI;
              implementation_end;
   DA 64 200
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
  <LibraryPath>Signal\Discrete\DA.emx</LibraryPath>
  <TimeStamp>2017-09-08 16:16:00</TimeStamp>
</Description>
';
    type DA
     ports
      signal in input;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 48 184 80 216 color 0 fill 15132390;
      spline 54.4 209.3 72 191.7 color 16711680;
      text 'A' 70.2 205.5 color 16711680 14;
      text 'D' 57.2 194.8 color 16711680 14;
      text '_max' 96 200 color 0 16;
    end;
    implementation eq
parameters
	real bits = 12;         // Quantization levels (bits)
	real minimum = -48;     // Minimum output value
	real maximum = 48;      // Maximum output value
variables
	real windowed_signal, quantisized_signal, rounded_signal;
	real lsb, half_lsb;
equations
	lsb = (maximum - minimum) / (exp2 (bits) -1);
	half_lsb = lsb / 2;
	windowed_signal = if input <= minimum then
		minimum+ half_lsb
	else
		if input >= maximum then 
			maximum - half_lsb
		else 
			input
		end
	end;
	quantisized_signal = if windowed_signal < 0.0 then
		windowed_signal - half_lsb
	else
		 windowed_signal + half_lsb
	end;

	rounded_signal =  quantisized_signal - (quantisized_signal mod lsb);
	output = hold (rounded_signal);
      implementation_end;
