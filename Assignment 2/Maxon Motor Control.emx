   load 632 320
    description '<Information><Description><Version>4.2</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues><LibraryPath>Bond Graph\R.emx</LibraryPath><TimeStamp>2011-11-29 16:35:37</TimeStamp><AllowLibraryUpdate>True</AllowLibraryUpdate></Description></Information>';
    type R
     ports
      power in p;
    end;
    icon bg ellipse bottom
     figures
      text 'R' 632 320 color 0 18 bold;
    end;
    implementation eq
parameters
	real stick = 2;       // friction coefficient for sticktion
	real tau_c = 0.1;     // Coulomb friction torque [Nm]
   real b = 0.3;        // viscous friction coefficient
   real k = 12;          // smoothing factor
variables
	real true_fric;
	real sticktion_switch;
initialequations
	sticktion_switch = 0;
equations
		
	if abs(p.f) > 0.1 then
		sticktion_switch = 1;
	elsif sticktion_switch == 0 then
		sticktion_switch = 0;
	end;
	
	true_fric = if time == 0 then 
		stick
	else
		if sticktion_switch == 0 then
			stick
		else tau_c * tanh(k * p.f)/p.f + b
		end
	end;
	p.e = true_fric * p.f;
	
implementation_end;
