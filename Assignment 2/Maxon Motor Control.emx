    description '<Description><Version>4.0</Version>
   <LibraryPath>Template\Submodel-Equation.emx</LibraryPath>
<IsMainModel>1</IsMainModel>
 <KeepParameterValues>False</KeepParameterValues>
   <TimeStamp>2007-11-1 22:32:1</TimeStamp>
   <AllowLibraryUpdate>False</AllowLibraryUpdate>
</Description>';
    type 'Submodel-Equation'
     ports
      signal in input;
      signal out output;
    end;
    implementation eq
parameters
	real initial = 0.0;  	// initial output value
variables
	real count;
equations
		output = if time == 0 then 
			initialvalue(input) 
		else
			if count <> 9 then
				previous(output)
			else
				input
				end
			end;
	next (count) = if count < 9 then count + 1 else 0 end; implementation_end;
