   line 145.8 554.1 152.2 554.1 color -1;
   text '1' 141.4 504.9;
   text 'i' 172.3 497.7 color 16711680;
  terminals
   p_in 88 512.8 fixed;
   p_out 192 512.8 fixed;
 end;
 implementation eq
parameters
	real i = 10.0 {};					// gearbox ratio
	real eff = 0.97 {};					// gearbox efficiency (0 < eff <= 1)
	real J = 1.0e-5 {kg.m2/rad};		// rotational inertia
variables
	real p_in_T;
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p_in.omega = (1/J)*int(p_in.T - p_in_T);
	p_out.T = p_in_T*i*dyn_eff;
	p_out.omega = p_in.omega/i;
	dyn_eff = if (sign(dly(p_in_T,0.0))*sign(dly(p_in.omega,0.0))) >= 0 then eff else 1/eff end;
implementation_end;
specification_end;
			end;
  end;
  connections
   AD\output -> PlusMinus1\minus;
   AD1\output -> DiscreteIntegral\input 680 136;
   Current\output -> DA\input;
   DA\output -> MSe\effort;
   DiscreteIntegral\output -> PlusMinus\minus;
   Freq2Sampler\output -> Position\error;
   GY\p2 => OneJunction1\p;
   max3_4Nm\p2 => OneJunction2\p;
   MSe\p => OneJunction\p;
   OneJunction\flow -> AD\input;
   OneJunction\p => GY\p1;
   OneJunction\p => HBridge\p;
   OneJunction\p => Inductance\p;
   OneJunction\p => R\p;
   OneJunction1\p => MotorLoadInertia\p;
   OneJunction1\p => Transmission\p_in;
   OneJunction2\flow -> AD1\input 680 264;
   OneJunction2\p => load\p;
   PlusMinus\output -> Freq2Sampler\input;
   PlusMinus1\output -> Current\error;
   Position\output -> PlusMinus1\plus;
   Step\output -> PlusMinus\plus;
   Transmission\p_out => max3_4Nm\p1;
  end;
 implementation_end;
]]></Sidops>
