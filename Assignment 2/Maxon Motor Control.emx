   p_out 512 264 fixed;
 end;
 implementation eq
parameters
	real i = 33.0 {};				// gearbox ratio
	real eff = 0.75 {};			// gearbox efficiency (0 < eff <= 1)
variables
	real dyn_eff;
initialequations
	dyn_eff = eff;
equations
	p_out.T = p_in.T*i*dyn_eff;
	p_out.omega = p_in.omega/i;
	dyn_eff = if (sign(p_in.T)*sign(p_in.omega)) >= 0 then eff else 1/eff end;
	
                     implementation_end;
specification_end;
