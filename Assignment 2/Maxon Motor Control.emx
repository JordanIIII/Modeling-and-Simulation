   Step 464 56
    description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Signal\Sources\SignalGenerator-Step.emx</LibraryPath>
  <TimeStamp>2007-9-27 16:2:44</TimeStamp>
</Description>';
    type 'SignalGenerator-Step'
     ports
      signal out output;
    end;
    icon bg top
     figures
      group
       rectangle 448 40 480 72 color 0 fill 15132390;
       line 457.6 52.8 474.6 52.8 color 16711680 width 2;
       line 450.9 64 477.1 64 color 0;
       line 453.1 64.1 457.7 64.1 457.7 52.7 color 16711680 width 2;
       line 453.1 48 453.1 66.2 color 0;
      end;
    end;
    implementation eq
parameters
	real amplitude = 1;
	real start_time = 1.0 {s};
variables
	boolean hidden change;
equations
	"calculate at least at the start time"
	change = timeevent (start_time);
	
	"calculate the step signal"
	output = amplitude * step (start_time);     implementation_end;
   TF 520 264
    description '<Information>
 <Description>
    <Version>4.2</Version>
<IsMainModel>1</IsMainModel>
  <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>Bond Graph\TF.emx</LibraryPath>
  <TimeStamp>2011-11-29 16:43:47</TimeStamp>
</Description>
</Information>';
    type TF
     ports
      power in p1;
      power out p2;
      signal in Pin;
     restrictions
      causality constraint not_equal p1 p2;
    end;
    icon bg ellipse bottom
     figures
      text 'TF' 520 264 color 0 18 bold;
    end;
    implementation eq
parameters
	real r = 1/33;
variables
	real eff;
initialequations
	eff = 1.0;
equations
	p1.e = r * p2.e;
	p2.f = r * p1.f;
	// efficiency check
	if Pin <> 0 then
		eff = if Pin >= 0 then
			(p2.e*p2.f)/(Pin)
		else
			(p1.e*p1.f)/(Pin)
		end;
	else 
		eff = 1.0;
	end;implementation_end;
   T_settling1 408 64
    description '<Information>
  <Description>
    <Version>5.1</Version>
    <IsMainModel>1</IsMainModel>
    <KeepParameterValues>False</KeepParameterValues>
    <LibraryPath>C:\Users\solis\Documents\M-ROB\Q2B\MS\T_settling.emx</LibraryPath>
    <TimeStamp>2026-5-1 10:18:55</TimeStamp>
    <AllowLibraryUpdate>True</AllowLibraryUpdate>
  </Description>
</Information>';
    type T_settling
     ports
      signal in input;
      signal out output;
    end;
    icon bg bottom
     figures
      rectangle 388 48 428 80 color 0 fill 14013909;
      text 'T_sett' 408 64 color 16711680 'Symbol' 14 bold;
    end;
    implementation eq
parameters
	real tol = 0.05; //tolerance for error (band style _+tol)
variables
	real last_set;
	real set;
initialequations
	set = false;
equations
	last_set = if (abs(input)<=tol) then
		if previous(set)==0.0 then
			time-1.0
		else 
			previous(last_set)
		end
	else 
		3.0
	end;	
	set = if abs(input) >= tol then
		0.0
	else 
		1.0
	end;
	output = if time == 0.0 then
					3.0
				 else 
					last_set
				 end;
implementation_end;
  end;
  connections
   AD\output -> PlusMinus1\minus;
   AD1\output -> DiscreteIntegral\input 680 136;
   Current\output -> DA\input;
   DA\output -> MSe\effort;
   DiscreteIntegral\output -> PlusMinus\minus;
   Freq2Sampler\output -> Position\error;
   GearFric\p <= OneJunction3\p;
   GY\p2 => OneJunction1\p;
   max3_4Nm\p1 <= PowerSensorOut\p2;
   max3_4Nm\p2 => OneJunction2\p;
   MSe\p => OneJunction\p;
   OneJunction\flow -> AD\input;
   OneJunction\p => GY\p1;
   OneJunction\p => HBridge\p;
   OneJunction\p => Inductance\p;
   OneJunction\p => R\p;
   OneJunction1\p => MotorLoadInertia\p;
   OneJunction2\flow -> AD1\input 680 264;
   OneJunction2\p => load\p;
   OneJunction3\p <= PowerSensorIn\p2;
   OneJunction3\p => TF\p1;
   PlusMinus\output -> Splitter1\input;
   PlusMinus1\output -> Current\error;
   Position\output -> PlusMinus1\plus;
   PowerSensorIn\P -> TF\Pin 416 224 520 224;
   PowerSensorIn\p1 <= OneJunction1\p;
   PowerSensorOut\p1 <= TF\p2;
   Splitter1\output -> Freq2Sampler\input;
   Splitter1\output -> T_settling1\input;
   Step\output -> PlusMinus\plus;
  end;
 implementation_end;
]]></Sidops>
