specification_end;
				specification 'Lossy'
description '<Description><Version>4.0</Version><IsMainModel>1</IsMainModel><KeepParameterValues>False</KeepParameterValues>
   <LibraryPath>Iconic Diagrams\Mechanical\Rotation\Gears\Transmission.emx</LibraryPath>
  <TimeStamp>2008-1-24 10:10:10</TimeStamp>
</Description>';
 type Transmission
  ports
   rotation psi in p_in;
   rotation psi out p_out;
  restrictions
   orientation constraint not_equal p_in p_out;
   causality preferred in p_out;
   causality preferred in p_in;
 end;
